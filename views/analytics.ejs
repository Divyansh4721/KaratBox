<% activeNav = 'analytics' %>
<%- include('reports/_tokens') %>
<% const shopGold = goldPrice ? goldPrice.value * 1 : 0; %>
<% const kpiCard = "bg-surface-container-lowest dark:bg-dark-container rounded-xl border border-surface-container dark:border-white/10 shadow-whisper p-4 sm:p-5"; %>
<% const kpiLabel = "text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1"; %>
<% const kpiVal = "text-2xl sm:text-3xl font-bold text-on-surface dark:text-dark-text tracking-tight"; %>

<div class="space-y-5 w-full pb-10">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-5">
    <div class="<%= kpiCard %>">
      <p class="<%= kpiLabel %>">In Stock</p>
      <p id="kpi-in-stock" class="<%= kpiVal %>">—</p>
    </div>
    <div class="<%= kpiCard %>">
      <p class="<%= kpiLabel %>">Out of Stock</p>
      <p id="kpi-out-stock" class="<%= kpiVal %>">—</p>
    </div>
    <div class="<%= kpiCard %>">
      <p class="<%= kpiLabel %>">Gold Rate Manager</p>
      <p class="<%= kpiVal %> text-primary dark:text-dark-brand">₹<%= shopGold.toLocaleString('en-IN') %></p>
      <p class="text-[10px] text-secondary mt-1">Shop / gm</p>
    </div>
    <div class="<%= kpiCard %>">
      <p class="<%= kpiLabel %>">Live Gold / gm</p>
      <p id="kpi-live-gold" class="<%= kpiVal %> text-emerald-700 dark:text-emerald-400">—</p>
      <p id="kpi-live-updated" class="text-[10px] text-secondary mt-1"></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 sm:gap-4 lg:gap-5">
    <div class="<%= sectionCard %> p-5 sm:p-6">
      <p class="<%= kpiLabel %> mb-1">Inventory Value</p>
      <p id="kpi-inv-value" class="text-3xl font-bold text-primary dark:text-dark-brand">—</p>
      <p class="text-sm text-secondary mt-1">In-stock selling price total</p>
    </div>
    <div class="<%= sectionCard %> p-5 sm:p-6">
      <p class="<%= kpiLabel %> mb-1">Total Net Weight</p>
      <p id="kpi-net-wt" class="text-3xl font-bold text-on-surface dark:text-dark-text">—</p>
      <p class="text-sm text-secondary mt-1">In-stock net gold (gm)</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 sm:gap-4 lg:gap-5">
    <div class="<%= sectionCard %> p-5 sm:p-6">
      <h3 class="text-sm font-bold text-on-surface dark:text-dark-text mb-4">By Ornament</h3>
      <div id="chart-ornament" class="space-y-2.5 min-h-[120px]">
        <p class="text-sm text-secondary">Loading…</p>
      </div>
    </div>
    <div class="<%= sectionCard %> p-5 sm:p-6">
      <h3 class="text-sm font-bold text-on-surface dark:text-dark-text mb-4">By Stock Type</h3>
      <div id="chart-stocktype" class="space-y-2.5 min-h-[120px]">
        <p class="text-sm text-secondary">Loading…</p>
      </div>
    </div>
  </div>

  <div class="<%= sectionCard %> overflow-hidden">
    <div class="px-5 py-4 border-b border-surface-container dark:border-white/10">
      <h3 class="text-sm font-bold text-on-surface dark:text-dark-text">Top Items by Value</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface-container-low dark:bg-dark-container text-[10px] font-semibold uppercase tracking-widest text-secondary">
          <tr>
            <th class="text-left py-3 px-5">Item</th>
            <th class="text-right py-3 px-4">Net Wt</th>
            <th class="text-right py-3 px-5">Price</th>
          </tr>
        </thead>
        <tbody id="top-items-body">
          <tr>
            <td colspan="3" class="py-8 text-center text-secondary">Loading…</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div>
    <h3 class="text-sm font-bold text-on-surface dark:text-dark-text mb-3 sm:mb-4">Quick Links</h3>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-5">
      <%- include('reports/_link_card', { href: '/dailySheet', icon: 'fa-calendar-day', cardTitle: 'Daily Sheet', description: "Today's arrivals, edits, sales." }) %>
      <%- include('reports/_link_card', { href: '/allStock', icon: 'fa-boxes-stacked', cardTitle: 'All Stock', description: 'Full inventory report.' }) %>
      <%- include('reports/_link_card', { href: '/dataPage', icon: 'fa-database', cardTitle: 'Reports', description: 'Reports and date lists.' }) %>
      <%- include('reports/_link_card', { href: '/billPage', icon: 'fa-file-invoice', cardTitle: 'Bills', description: 'Customer sale bills.' }) %>
    </div>
  </div>
</div>

<script>
  (function() {
    const fmt = (n) => Number(n || 0).toLocaleString('en-IN');
    const fmtWt = (n) => (Number(n) || 0).toFixed(3);
    const fmtPrice = (n) => '₹' + fmt(Math.round((n || 0) / 1000) * 1000);

    async function loadLiveGold() {
      const el = document.getElementById('kpi-live-gold');
      const updatedEl = document.getElementById('kpi-live-updated');
      try {
        const res = await fetch('/api/liveGoldRate');
        if (!res.ok) throw new Error('fail');
        const data = await res.json();
        const perGm = data.rate != null ? Math.round(Number(data.rate) / 10) : null;
        el.textContent = perGm != null ? '₹' + fmt(perGm) : '—';
        if (updatedEl) updatedEl.textContent = 'Updated ' + new Date().toLocaleTimeString('en-IN');
      } catch (e) {
        el.textContent = '—';
        el.classList.add('text-secondary');
        if (updatedEl) updatedEl.textContent = 'Offline';
      }
    }

    function groupCount(rows, keyFn) {
      const map = {};
      rows.forEach((r) => {
        const k = keyFn(r) || 'Other';
        map[k] = (map[k] || 0) + 1;
      });
      return Object.entries(map).sort((a, b) => b[1] - a[1]).slice(0, 8);
    }

    function renderBars(containerId, entries) {
      const el = document.getElementById(containerId);
      if (!entries.length) {
        el.innerHTML = '<p class="text-sm text-secondary">No data</p>';
        return;
      }
      const max = entries[0][1];
      el.innerHTML = entries.map(([label, count]) => `
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="font-medium text-on-surface dark:text-dark-text truncate pr-2">${label}</span>
          <span class="text-secondary shrink-0">${count}</span>
        </div>
        <div class="h-2 rounded-full bg-surface-container-low dark:bg-dark-container overflow-hidden">
          <div class="h-full rounded-full bg-primary-container dark:bg-dark-brand" style="width:${Math.max(8, Math.round((count / max) * 100))}%"></div>
        </div>
      </div>
    `).join('');
    }

    function itemLabel(s) {
      const p = s.prefix && s.prefix.name ? s.prefix.name : '';
      const o = s.ornament && s.ornament.name ? s.ornament.name : '';
      const t = s.tag ? '-' + s.tag : '';
      return (p + ' ' + o + t).trim() || '—';
    }

    async function loadInventory() {
      try {
        const res = await fetch('/inventory-query', {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const data = await res.json();
        if (!data.success || !data.stockTable) throw new Error('fail');

        const all = data.stockTable;
        const inStock = all.filter((s) => s.isInStock === true);
        const outStock = all.filter((s) => !s.isInStock);

        document.getElementById('kpi-in-stock').textContent = fmt(inStock.length);
        document.getElementById('kpi-out-stock').textContent = fmt(outStock.length);

        const totalValue = inStock.reduce((sum, s) => sum + (s.sellingPrice || 0) * 1, 0);
        const totalWt = inStock.reduce((sum, s) => sum + (s.netWt || 0) * 1, 0);
        document.getElementById('kpi-inv-value').textContent = fmtPrice(totalValue);
        document.getElementById('kpi-net-wt').textContent = fmtWt(totalWt) + ' gm';

        renderBars('chart-ornament', groupCount(inStock, (s) => s.ornament && s.ornament.name));
        renderBars('chart-stocktype', groupCount(inStock, (s) => s.stockType && s.stockType.name));

        const top = inStock.slice().sort((a, b) => (b.sellingPrice || 0) - (a.sellingPrice || 0)).slice(0, 5);
        const tbody = document.getElementById('top-items-body');
        if (!top.length) {
          tbody.innerHTML = '<tr><td colspan="3" class="py-8 text-center text-secondary">No in-stock items</td></tr>';
        } else {
          tbody.innerHTML = top.map((s) => `
          <tr class="border-t border-surface-container dark:border-white/10 hover:bg-surface-container-low/40">
            <td class="py-3 px-5 font-medium text-primary"><a href="/stock/${s._id}" class="hover:underline">${itemLabel(s)}</a></td>
            <td class="py-3 px-4 text-right tabular-nums">${fmtWt(s.netWt)}</td>
            <td class="py-3 px-5 text-right tabular-nums font-semibold">${fmtPrice(s.sellingPrice)}</td>
          </tr>
        `).join('');
        }
      } catch (e) {
        ['kpi-in-stock', 'kpi-out-stock', 'kpi-inv-value', 'kpi-net-wt'].forEach((id) => {
          document.getElementById(id).textContent = '—';
        });
        document.getElementById('chart-ornament').innerHTML = '<p class="text-sm text-secondary">Could not load inventory</p>';
        document.getElementById('chart-stocktype').innerHTML = '<p class="text-sm text-secondary">Could not load inventory</p>';
        document.getElementById('top-items-body').innerHTML = '<tr><td colspan="3" class="py-8 text-center text-secondary">Could not load inventory</td></tr>';
      }
    }

    loadLiveGold();
    loadInventory();
    setInterval(loadLiveGold, 10000);
  })();
</script>