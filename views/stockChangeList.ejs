    <div id="detailList">
        <span id="heading">Arrival Table</span>
        <%- include('layoutStockTableCartLink',{stockTable:arrivalTable}); %>
        <br>
        <span id="heading">Sold Table</span>
        <%- include('layoutStockTableCartLink',{stockTable:soldTable}); %>
        <br>
        <span id="heading">Deleted Table</span>
