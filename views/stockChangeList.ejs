<link rel="stylesheet" href="<%= assetPath('css/home.css') %>">
<style>
    table {
        font-size: 20px !important;
    }

    @media (max-width: 640px) {
        table {
            font-size: 6px !important;
        }

        #detailList {
            width: 100%;
        }
    }

    #detailList {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
</style>
<div id="home-container">
    <form action="">
        <br>
        <span class="PageDate" id="heading"><%= date %></span>
        <br>
        <button type="button" onclick="printTable('fullList')">Print Full List</button>
        <br>
        <button type="button" onclick="printTable('shortFullList')">Print Short List</button>
        <br>
        <button type="button" onclick="printTableDetail('printList')">Print Detail List</button>
    </form>
    <table id="fullList" border="1" cellspacing="0" hidden>
        <thead>
            <tr class="bold backgroundDark">
                <td></td>
                <td colspan="3">Opening</td>
                <td colspan="3">Day Arrival</td>
                <td colspan="3">Day Sale</td>
                <td colspan="3">Day Delete</td>
                <td colspan="3">Approval</td>
                <td colspan="3">Closing</td>
                <td colspan="3">Total</td>
            </tr>
            <tr class="bold backgroundDark">
                <td>Item</td>
                <td>No.</td>
                <td>St Wt (ct)</td>
                <td>Gr Wt (gm)</td>
                <td>No.</td>
                <td>St Wt (ct)</td>
                <td>Gr Wt (gm)</td>
                <td>No.</td>
                <td>St Wt (ct)</td>
                <td>Gr Wt (gm)</td>
                <td>No.</td>
                <td>St Wt (ct)</td>
                <td>Gr Wt (gm)</td>
                <td>No.</td>
                <td>St Wt (ct)</td>
                <td>Gr Wt (gm)</td>
                <td>No.</td>
                <td>St Wt (ct)</td>
                <td>Gr Wt (gm)</td>
                <td>No.</td>
                <td>St Wt (ct)</td>
                <td>Gr Wt (gm)</td>
            </tr>
        </thead>
        <tbody>
            <% for(let i of fullList){ %>
            <tr>
                <td><%= i.name %></td>
                <td><%= i.opening && i.opening.total ? i.opening.total : "" %></td>
                <td><%= i.opening && i.opening.stoneWt ? (i.opening.stoneWt*5).toFixed(3) : "" %></td>
                <td><%= i.opening && i.opening.grossWt ? (i.opening.grossWt*1).toFixed(3) : "" %></td>
                <td><%= i.arrival && i.arrival.total ? i.arrival.total : "" %></td>
                <td><%= i.arrival && i.arrival.stoneWt ? (i.arrival.stoneWt*5).toFixed(3) : "" %></td>
                <td><%= i.arrival && i.arrival.grossWt ? (i.arrival.grossWt*1).toFixed(3) : "" %></td>
