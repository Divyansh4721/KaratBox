<% activeNav = 'khata' %>
<% const fmt = n => new Intl.NumberFormat('en-IN').format(Math.abs(n * 1)); %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const dtLocal = new Date(new Date().getTime() + 19800000).toISOString().substring(0, 16); %>
<% const initials = (party.name || 'K').trim().charAt(0).toUpperCase(); %>
<% const isCustomer = party.partyType === 'customer'; %>
<% const gaveLabel = isCustomer ? 'You Gave (Udhar)' : 'You Gave (Payment)'; %>
<% const gotLabel = isCustomer ? 'You Got (Jama)' : 'You Got (Purchase)'; %>
<% const fmtInvoiceDate = d => { if (!d) return ''; const x = new Date(d); return x.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }); }; %>
<div class="pb-10">
  <div class="rounded-xl bg-primary text-on-primary overflow-hidden shadow-whisper mb-4">
    <div class="p-6 sm:p-8">
      <div class="flex flex-wrap items-center gap-5">
        <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl bg-surface-container-lowest/20 border border-on-primary/20 flex items-center justify-center shrink-0">
          <span class="text-2xl sm:text-3xl font-bold text-on-primary/70"><%= initials %></span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <h2 class="text-2xl sm:text-3xl font-bold tracking-tight truncate"><%= party.name %></h2>
            <% if (isCustomer) { %>
            <span class="text-[10px] font-bold uppercase tracking-wide bg-on-primary/15 px-2.5 py-1 rounded-full">Customer</span>
            <% } else { %>
            <span class="text-[10px] font-bold uppercase tracking-wide bg-on-primary/15 px-2.5 py-1 rounded-full">Supplier</span>
            <% } %>
          </div>
          <p class="text-sm text-on-primary/75">
            <% if (party.phNum) { %>+91 <%= party.phNum %><% if (party.address) { %> &middot; <% } %><% } %>
            <%= party.address || '' %>
          </p>
        </div>
        <button type="button" onclick="openEditModal()" class="inline-flex items-center gap-2 px-4 py-2.5 border border-on-primary/40 hover:bg-on-primary/10 text-on-primary text-sm font-semibold rounded-lg transition-colors shrink-0">
          <i class="fas fa-pen text-xs"></i>
          <span class="hidden sm:inline">Edit Party</span>
        </button>
      </div>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="lg:col-span-1 bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6">
      <p class="<%= label %>">Current Balance</p>
      <% if (display.tone === 'settled') { %>
      <p class="text-2xl font-bold text-on-surface mt-1">&#8377; 0</p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-wide text-secondary bg-surface-container px-2.5 py-1 rounded-full">Settled</span>
      <% } else if (display.tone === 'receivable') { %>
      <p class="text-2xl font-bold text-emerald-600 dark:text-emerald-400 mt-1">&#8377; <%= fmt(display.amount) %></p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-wide text-emerald-700 bg-emerald-100 dark:text-emerald-300 dark:bg-emerald-900/40 px-2.5 py-1 rounded-full"><%= display.label %></span>
      <% } else { %>
      <p class="text-2xl font-bold text-rose-600 dark:text-rose-400 mt-1">&#8377; <%= fmt(display.amount) %></p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-wide text-rose-700 bg-rose-100 dark:text-rose-300 dark:bg-rose-900/40 px-2.5 py-1 rounded-full"><%= display.label %></span>
      <% } %>
      <p class="text-xs text-secondary mt-4 leading-relaxed">
        <% if (isCustomer) { %>
        <strong>You Gave</strong> = sale on credit (they owe you). <strong>You Got</strong> = payment received.
        <% } else { %>
        <strong>You Got</strong> = purchase on credit (you owe them). <strong>You Gave</strong> = payment made.
        <% } %>
      </p>
    </div>
    <div class="lg:col-span-2 bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden">
      <div class="px-6 sm:px-8 pt-6 pb-0">
        <h3 class="text-sm font-bold text-primary mb-4 flex items-center gap-2">
          <i class="fas fa-plus text-xs"></i> Add Transaction
        </h3>
      </div>
      <div class="flex items-end gap-0 px-6 sm:px-8 border-b border-surface-container shrink-0">
        <button type="button" id="txnTabGave" data-txn-tab="gave" class="txn-tab txn-tab-active min-w-[10rem] h-10 inline-flex items-center justify-center gap-2 rounded-t-lg border border-b-0 border-surface-container bg-surface-container-lowest px-4 text-sm font-semibold text-on-surface -mb-px relative z-[1]">
          <i class="fas fa-arrow-up text-xs text-rose-500"></i> <%= gaveLabel %>
        </button>
        <button type="button" id="txnTabGot" data-txn-tab="got" class="txn-tab min-w-[10rem] h-10 inline-flex items-center justify-center gap-2 rounded-t-lg border border-transparent px-4 text-sm font-semibold text-secondary hover:text-on-surface hover:bg-surface-container-low/60 -mb-px">
          <i class="fas fa-arrow-down text-xs text-emerald-500"></i> <%= gotLabel %>
        </button>
      </div>
      <div class="p-6 sm:p-8 pt-6">
        <form action="/khataBook/addEntryForm" method="post" id="entryForm" enctype="multipart/form-data" class="space-y-4">
          <input type="hidden" name="id" value="<%= party.id %>">
          <input type="hidden" name="type" id="entryType" value="gave">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="<%= label %>">Amount (&#8377;)</label>
              <input type="number" name="amount" step="0.01" min="0.01" placeholder="Enter amount..." required class="<%= field %>">
            </div>
            <div>
              <label class="<%= label %>">Transaction Date</label>
              <input type="datetime-local" name="date" value="<%= dtLocal %>" required class="<%= field %>">
            </div>
          </div>
          <div>
            <label class="<%= label %>">Remarks / Notes</label>
            <textarea name="remark" rows="2" placeholder="Optional note..." autocomplete="off" class="<%= field %> resize-none"></textarea>
          </div>
          <div class="rounded-xl border border-surface-container bg-surface-container-low/40 overflow-hidden">
            <button type="button" id="invoiceToggle" class="w-full flex items-center justify-between gap-3 px-4 py-3 text-left hover:bg-surface-container-low/60 transition-colors">
              <span class="text-sm font-semibold text-on-surface flex items-center gap-2">
                <i class="fas fa-file-invoice text-primary text-xs"></i>
                Invoice Details <span class="text-[10px] font-bold uppercase tracking-widest text-secondary">(Optional)</span>
              </span>
              <i id="invoiceToggleIcon" class="fas fa-chevron-down text-secondary text-xs transition-transform"></i>
            </button>
            <div id="invoicePanel" class="hidden px-4 pb-4 pt-1 space-y-4 border-t border-surface-container">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="<%= label %>">Invoice Number</label>
                  <input type="text" name="invoiceNo" placeholder="e.g. INV-1024" class="<%= field %>">
                </div>
                <div>
                  <label class="<%= label %>">Invoice Date</label>
                  <input type="date" name="invoiceDate" class="<%= field %>">
                </div>
              </div>
              <div>
                <label class="<%= label %>">Invoice Image</label>
                <label class="flex flex-col items-center justify-center gap-2 w-full px-4 py-6 border-2 border-dashed border-outline-variant/50 rounded-xl bg-surface-container-lowest cursor-pointer hover:border-primary-container transition-colors">
                  <i class="fas fa-cloud-upload-alt text-xl text-secondary"></i>
                  <span class="text-xs text-secondary text-center">Upload bill / invoice photo<br><span class="text-[10px] uppercase tracking-wider">PNG, JPG, WEBP up to 5MB</span></span>
                  <input type="file" name="invoiceImage" id="invoiceImageInput" accept="image/png,image/jpeg,image/jpg,image/webp" class="hidden" onchange="previewInvoiceImage(this)">
                </label>
                <div id="invoicePreviewWrap" class="hidden mt-3">
                  <img id="invoicePreview" src="" alt="Invoice preview" class="max-h-40 rounded-lg border border-surface-container object-contain bg-surface-container-lowest">
                  <button type="button" onclick="clearInvoicePreview()" class="mt-2 text-xs font-semibold text-error hover:underline">Remove image</button>
                </div>
              </div>
            </div>
          </div>
          <button type="submit" id="entrySubmitBtn" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all">
            <i class="fas fa-check text-xs"></i> <span id="entrySubmitLabel">Add — You Gave</span>
          </button>
        </form>
      </div>
    </div>
  </div>
  <div class="bg-surface-container-low/60 rounded-xl border border-dashed border-outline-variant/50 p-5 mb-6 flex items-start gap-4 opacity-80">
    <span class="w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center shrink-0 text-secondary"><i class="fas fa-bell"></i></span>
    <div>
      <p class="text-sm font-bold text-on-surface">Payment Reminders &amp; Collections</p>
      <p class="text-xs text-secondary mt-1 leading-relaxed">SMS reminders, auto-collection links, and follow-up schedules — planned for a future release.</p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-widest text-secondary bg-surface-container px-2.5 py-1 rounded-full">Coming Soon</span>
    </div>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden">
    <div class="px-5 py-4 border-b border-surface-container flex items-center justify-between">
      <h3 class="text-sm font-bold text-on-surface">Transaction History</h3>
      <span class="text-xs text-secondary"><%= entries.length %> entr<%= entries.length === 1 ? 'y' : 'ies' %></span>
    </div>
    <% if (entries.length) { %>
    <div class="divide-y divide-surface-container">
      <% for (let e of entries) { %>
      <div class="flex items-start justify-between gap-4 px-5 py-4 hover:bg-surface-container-low/30">
        <div class="flex items-start gap-4 min-w-0 flex-1">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 mt-0.5 <%= e.type === 'gave' ? 'bg-rose-100 text-rose-600 dark:bg-rose-900/40 dark:text-rose-300' : 'bg-emerald-100 text-emerald-600 dark:bg-emerald-900/40 dark:text-emerald-300' %>">
            <i class="fas fa-<%= e.type === 'gave' ? 'arrow-up' : 'arrow-down' %> text-sm"></i>
          </span>
          <div class="min-w-0 flex-1">
            <p class="font-bold text-on-surface">&#8377; <%= fmt(e.amount) %> /-</p>
            <p class="text-xs font-semibold <%= e.type === 'gave' ? 'text-rose-600 dark:text-rose-400' : 'text-emerald-600 dark:text-emerald-400' %>">
              <%= e.type === 'gave' ? gaveLabel : gotLabel %>
            </p>
            <p class="text-xs text-secondary mt-1"><%= convertDate(e.date) %><% if (e.remark) { %> &middot; <%= e.remark %><% } %></p>
            <% if (e.invoiceNo || e.invoiceDate) { %>
            <p class="text-xs text-on-surface mt-2 flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center gap-1.5 px-2 py-1 rounded-md bg-surface-container-low text-[11px] font-semibold">
                <i class="fas fa-file-invoice text-primary text-[10px]"></i>
                <% if (e.invoiceNo) { %>#<%= e.invoiceNo %><% } %>
                <% if (e.invoiceNo && e.invoiceDate) { %> &middot; <% } %>
                <% if (e.invoiceDate) { %><%= fmtInvoiceDate(e.invoiceDate) %><% } %>
              </span>
            </p>
            <% } %>
            <% if (e.invoiceImage) { %>
            <button type="button" onclick="openInvoiceModal('/uploads/<%= e.invoiceImage %>')" class="mt-2 inline-flex items-center gap-2 group">
              <img src="/uploads/<%= e.invoiceImage %>" alt="Invoice" class="w-16 h-16 rounded-lg border border-surface-container object-cover bg-surface-container-lowest group-hover:opacity-90 transition-opacity">
              <span class="text-xs font-semibold text-primary group-hover:underline">View invoice</span>
            </button>
            <% } %>
            <% if (e.user) { %><p class="text-xs text-secondary mt-1">By: <%= e.user.name %></p><% } %>
          </div>
        </div>
        <a href="/khataBook/delEntry?id=<%= e.id %>&party=<%= party.id %>" onclick="return confirm('Delete this transaction?')" class="p-2 text-secondary hover:text-error rounded-lg shrink-0" title="Delete"><i class="fas fa-trash"></i></a>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div class="py-12 text-center text-secondary text-sm">
      <i class="fas fa-book-open text-2xl mb-3 opacity-40"></i>
      <p>No transactions yet. Add your first entry above.</p>
    </div>
    <% } %>
  </div>
</div>
<div id="invoiceModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm" onclick="closeInvoiceModal()">
  <div class="relative max-w-4xl w-full max-h-[90vh]" onclick="event.stopPropagation()">
    <button type="button" onclick="closeInvoiceModal()" class="absolute -top-10 right-0 text-on-primary hover:text-white/80"><i class="fas fa-times text-xl"></i></button>
    <img id="invoiceModalImg" src="" alt="Invoice" class="w-full max-h-[85vh] object-contain rounded-xl bg-surface-container-lowest">
  </div>
</div>
<div id="editModal" class="fixed inset-0 z-50 hidden items-start justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-lg my-8 max-h-[calc(100vh-4rem)] overflow-y-auto">
    <div class="flex items-start justify-between px-6 py-4 border-b border-surface-container">
      <div class="flex items-center gap-3">
        <span class="w-10 h-10 rounded-lg bg-primary-fixed/40 flex items-center justify-center text-primary"><i class="fas fa-pen"></i></span>
        <div>
          <h3 class="text-lg font-bold text-on-surface">Edit Party</h3>
          <p class="text-[10px] font-semibold uppercase tracking-widest text-primary">Ledger Update</p>
        </div>
      </div>
      <button type="button" onclick="closeEditModal()" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form action="/khataBook/editPartyForm" method="post" class="p-6 space-y-5">
      <input type="hidden" name="id" value="<%= party.id %>">
      <input type="hidden" name="returnTo" value="/khataBook/party?id=<%= party.id %>">
      <div>
        <label class="<%= label %>">Party Type</label>
        <div class="grid grid-cols-2 gap-3">
          <label class="flex items-center gap-2 px-4 py-3 rounded-lg border border-surface-container bg-surface-container-low cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary-fixed/20">
            <input type="radio" name="partyType" value="customer" <%= isCustomer ? 'checked' : '' %> class="accent-primary">
            <span class="text-sm font-medium">Customer</span>
          </label>
          <label class="flex items-center gap-2 px-4 py-3 rounded-lg border border-surface-container bg-surface-container-low cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary-fixed/20">
            <input type="radio" name="partyType" value="supplier" <%= !isCustomer ? 'checked' : '' %> class="accent-primary">
            <span class="text-sm font-medium">Supplier</span>
          </label>
        </div>
      </div>
      <div><label class="<%= label %>">Party Name</label><input type="text" name="name" value="<%= party.name %>" required class="<%= field %>"></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div><label class="<%= label %>">Phone Number</label><input type="tel" name="phNum" value="<%= party.phNum || '' %>" inputmode="numeric" maxlength="10" placeholder="10-digit mobile (optional)" class="<%= field %>"></div>
        <div><label class="<%= label %>">Address</label><input type="text" name="address" value="<%= party.address || '' %>" class="<%= field %>"></div>
      </div>
      <div class="flex gap-3 pt-2 border-t border-surface-container">
        <button type="submit" class="flex-1 py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg transition-all">Save Changes</button>
        <button type="button" onclick="closeEditModal()" class="px-6 py-3 bg-surface-container-low text-on-surface text-sm font-semibold rounded-lg hover:bg-surface-container transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
  const gaveLabel = <%- JSON.stringify(gaveLabel) %>;
  const gotLabel = <%- JSON.stringify(gotLabel) %>;

  function setTxnTabActive(btn, on) {
    btn.classList.toggle('txn-tab-active', on);
    btn.classList.toggle('border-surface-container', on);
    btn.classList.toggle('border-b-0', on);
    btn.classList.toggle('bg-surface-container-lowest', on);
    btn.classList.toggle('text-on-surface', on);
    btn.classList.toggle('z-[1]', on);
    btn.classList.toggle('border-transparent', !on);
    btn.classList.toggle('text-secondary', !on);
  }

  function selectTxnTab(tab) {
    const typeInput = document.getElementById('entryType');
    const submitLabel = document.getElementById('entrySubmitLabel');
    const tabGave = document.getElementById('txnTabGave');
    const tabGot = document.getElementById('txnTabGot');
    const isGave = tab === 'gave';
    typeInput.value = isGave ? 'gave' : 'got';
    submitLabel.textContent = isGave ? 'Add — ' + gaveLabel : 'Add — ' + gotLabel;
    setTxnTabActive(tabGave, isGave);
    setTxnTabActive(tabGot, !isGave);
  }

  function openEditModal() {
    document.getElementById('editModal').classList.replace('hidden', 'flex');
  }

  function closeEditModal() {
    document.getElementById('editModal').classList.replace('flex', 'hidden');
  }

  document.getElementById('txnTabGave')?.addEventListener('click', () => selectTxnTab('gave'));
  document.getElementById('txnTabGot')?.addEventListener('click', () => selectTxnTab('got'));

  document.getElementById('invoiceToggle')?.addEventListener('click', () => {
    const panel = document.getElementById('invoicePanel');
    const icon = document.getElementById('invoiceToggleIcon');
    const open = panel.classList.toggle('hidden') === false;
    icon.classList.toggle('rotate-180', open);
  });

  function previewInvoiceImage(input) {
    const wrap = document.getElementById('invoicePreviewWrap');
    const img = document.getElementById('invoicePreview');
    if (!input.files || !input.files[0]) {
      wrap.classList.add('hidden');
      img.removeAttribute('src');
      return;
    }
    img.src = URL.createObjectURL(input.files[0]);
    wrap.classList.remove('hidden');
    document.getElementById('invoicePanel').classList.remove('hidden');
    document.getElementById('invoiceToggleIcon').classList.add('rotate-180');
  }

  function clearInvoicePreview() {
    const input = document.getElementById('invoiceImageInput');
    input.value = '';
    document.getElementById('invoicePreviewWrap').classList.add('hidden');
    document.getElementById('invoicePreview').removeAttribute('src');
  }

  function openInvoiceModal(src) {
    document.getElementById('invoiceModalImg').src = src;
    document.getElementById('invoiceModal').classList.replace('hidden', 'flex');
  }

  function closeInvoiceModal() {
    document.getElementById('invoiceModal').classList.replace('flex', 'hidden');
    document.getElementById('invoiceModalImg').removeAttribute('src');
  }
</script>
