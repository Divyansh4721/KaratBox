<% activeNav = 'inventory' %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-brand-almond border border-transparent rounded-md text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors appearance-none"; %>
<% const q = typeof query !== 'undefined' ? query : {}; %>
<% const prefixes = typeof prefixTable !== 'undefined' ? prefixTable : []; %>
<% const ornaments = typeof ornamentTable !== 'undefined' ? ornamentTable : []; %>
<% const stockTypes = typeof stockTypeTable !== 'undefined' ? stockTypeTable : []; %>
<div class="pb-10">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6 sm:p-8 mb-8">
    <div class="flex items-center gap-2 mb-6">
      <i class="fas fa-sliders-h text-primary text-sm"></i>
      <h3 class="text-sm font-bold text-primary">Inventory Filters</h3>
    </div>
    <form id="filterForm" method="get" action="/inventorySelection">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-5">
        <div>
          <label class="<%= label %>">Select Prefix</label>
          <div class="relative">
            <select name="prefix" class="<%= field %> cursor-pointer pr-10">
              <option value="" <%= !q.prefix ? 'selected' : '' %>> All Prefixes </option>
              <% for (let i of prefixes) { %>
              <option value="<%= i._id %>" <%= String(q.prefix) === String(i._id) ? 'selected' : '' %>><%= i.name || '-' %></option>
              <% } %>
            </select>
            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-secondary text-xs pointer-events-none"></i>
          </div>
        </div>
        <div>
          <label class="<%= label %>">Select Ornament</label>
          <div class="relative">
            <select name="ornament" class="<%= field %> cursor-pointer pr-10">
              <option value="">Select Ornament...</option>
              <% for (let i of ornaments) { %>
              <option value="<%= i._id %>" <%= String(q.ornament) === String(i._id) ? 'selected' : '' %>><%= i.name %></option>
              <% } %>
            </select>
            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-secondary text-xs pointer-events-none"></i>
          </div>
        </div>
        <div>
          <label class="<%= label %>">Stock Type</label>
          <div class="relative">
            <select name="stockType" class="<%= field %> cursor-pointer pr-10">
              <option value="">Select Stock Type...</option>
              <% for (let i of stockTypes) { %>
              <option value="<%= i._id %>" <%= String(q.stockType) === String(i._id) ? 'selected' : '' %>><%= i.name %></option>
              <% } %>
            </select>
            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-secondary text-xs pointer-events-none"></i>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8">
        <div>
          <label class="<%= label %>">Tag Number</label>
          <input type="text" name="tag" value="<%= q.tag || '' %>" placeholder="e.g. KB-892" class="<%= field %>" autocomplete="off">
        </div>
        <div class="sm:col-span-2">
          <label class="<%= label %>">SKU Number</label>
          <input type="text" name="item" value="<%= q.item || '' %>" placeholder="Search by SKU identifier..." class="<%= field %>" autocomplete="off">
        </div>
      </div>
      <div class="flex flex-col sm:flex-row sm:justify-end gap-3">
        <button type="button" onclick="setFilterAction('/addToCart')" class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-primary-container text-primary text-xs font-bold uppercase tracking-wider rounded-lg hover:bg-primary-fixed/20 transition-colors">
          <i class="fas fa-shopping-cart text-sm"></i>
          Add to Cart
        </button>
        <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary-container hover:brightness-105 text-on-primary text-xs font-bold uppercase tracking-wider rounded-lg transition-colors">
          <i class="fas fa-search text-sm"></i>
          Search Stock
        </button>
      </div>
    </form>
  </div>
</div>
<div id="inventoryToast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden px-5 py-3 rounded-lg shadow-lg text-sm font-medium text-on-primary bg-primary"></div>
<script>
  let searchTimer = null;

  function showToast(message) {
    const toast = document.getElementById('inventoryToast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 2500);
  }

  function setFilterAction(url) {
    document.getElementById('filterForm').action = url;
    document.getElementById('filterForm').submit();
  }
  async function searchByTagOrSku() {
    const form = document.getElementById('filterForm');
    const fd = new FormData(form);
    const tag = (fd.get('tag') || '').toString().trim();
    const item = (fd.get('item') || '').toString().trim();
    if (!tag && !item) return;
    const params = new URLSearchParams();
    ['prefix', 'ornament', 'stockType', 'tag', 'item'].forEach((key) => {
      const val = (fd.get(key) || '').toString().trim();
      if (val) params.set(key, val);
    });
    try {
      const res = await fetch('/inventory-query?' + params.toString(), {
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      });
      const data = await res.json();
      if (data.success && data.redirectUrl) {
        window.location.href = window.kbRoutes.normalizeLegacyRoute(data.redirectUrl);
        return;
      }
      showToast(data.message || 'Item not found');
    } catch (err) {
      showToast('Could not search inventory');
    }
  }

  function scheduleTagSkuSearch() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(searchByTagOrSku, 1000);
  }
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('filterForm');
    const tagInput = form?.querySelector('input[name="tag"]');
    const itemInput = form?.querySelector('input[name="item"]');
    tagInput?.addEventListener('input', scheduleTagSkuSearch);
    itemInput?.addEventListener('input', scheduleTagSkuSearch);
    form?.addEventListener('submit', (e) => {
      if (form.action && form.action.includes('/addToCart')) return;
      const fd = new FormData(form);
      const tag = (fd.get('tag') || '').toString().trim();
      const item = (fd.get('item') || '').toString().trim();
      if (!tag && !item) return;
      e.preventDefault();
      clearTimeout(searchTimer);
      searchByTagOrSku();
    });
  });
</script>