<script>
  function getPerPage() {
    return window.innerWidth < 1024 ? 10 : 12;
  }

  function getWindowSize() {
    return window.innerWidth < 640 ? 3 : 5;
  }
  const pager = new KbPagination({
    perPage: getPerPage(),
    windowSize: getWindowSize(),
    activeClass: "bg-primary text-on-primary shadow-sm",
    onPageChange: LoadTable
  });

  function syncPerPage() {
    const nextPerPage = getPerPage();
    const nextWindow = getWindowSize();
    let changed = false;
    if (pager.perPage !== nextPerPage) {
      pager.perPage = nextPerPage;
      changed = true;
    }
    if (pager.windowSize !== nextWindow) {
      pager.windowSize = nextWindow;
      changed = true;
    }
    if (!changed) return;
    pager.resetPage();
    LoadTable();
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function getSearchParams() {
    return new URLSearchParams(window.location.search);
  }

  function getFilterParams() {
    const form = document.getElementById("filterForm");
    if (!form) return getSearchParams();
    const params = new URLSearchParams();
    ["prefix", "ornament", "stockType"].forEach((key) => {
      const selected = getSelectedServerFilters(key);
      if (selected === null) return;
      if (!selected.length) return;
      selected.forEach((val) => params.append(key, val));
    });
    const fd = new FormData(form);
    ["tag", "item"].forEach((key) => {
      const val = (fd.get(key) || "").toString().trim();
      if (val) params.set(key, val);
    });
    return params;
  }

  function getDesktopFilterInputName(group) {
    return group === "ornament" ? "ornamentSelectFilter" : group + "Filter";
  }

  function getSelectedServerFilters(group) {
    if (isMobileFilters()) {
      const form = document.getElementById("mobileFilterForm");
      if (!form) return null;
      const selected = Array.from(
        form.querySelectorAll('[data-filter-group="' + group + '"]:checked:not([data-filter-value=""])')
      ).map((el) => el.dataset.filterValue);
      const total = form.querySelectorAll('[data-filter-group="' + group + '"]:not([data-filter-value=""])').length;
      if (!total) return null;
      if (!selected.length) return [];
      if (selected.length >= total) return null;
      return selected;
    }
    const inputName = getDesktopFilterInputName(group);
    const selected = Array.from(document.querySelectorAll('input[name="' + inputName + '"]:checked')).map((el) => el.value);
    const total = document.querySelectorAll('input[name="' + inputName + '"]').length;
    if (!total) return null;
    if (!selected.length) return [];
    if (selected.length >= total) return null;
    return selected;
  }

  function generateTagName(item) {
    return (
      (item.prefix ? item.prefix.name + " " : "") +
      (item.ornament ? item.ornament.name : "") +
      (item.tag ? " - " + item.tag : "")
    );
  }

  function isMobileFilters() {
    return window.innerWidth < 1024;
  }

  function buildPurityHtml(purities, inputName, isMobile) {
    const labelClass = "flex items-start gap-2.5 cursor-pointer text-sm text-on-surface hover:text-primary leading-snug";
    const inputClass = (isMobile ? "w-5 h-5 " : "w-4 h-4 ") + "mt-0.5 rounded border-outline-variant text-primary focus:ring-primary-container shrink-0 cursor-pointer";
    return purities
      .map(
        (name) =>
          '<label class="' + labelClass + '">' +
          '<input type="checkbox" name="' + inputName + '" value="' +
          escapeHtml(name) +
          '" checked onchange="filterTable();if(typeof updateMobileFilterUI===\'function\')updateMobileFilterUI()" class="' + inputClass + '">' +
          "<span>" + escapeHtml(name) + " Gold</span></label>"
      )
      .join("");
  }

  function updateDynamicFilters(items) {
    const purities = [];
    const seenPur = {};
    items.forEach((item) => {
      if (item.purity && !seenPur[item.purity.name]) {
        seenPur[item.purity.name] = 1;
        purities.push(item.purity.name);
      }
    });
    const purityWrap = document.getElementById("purityFilter");
    const purityList = document.getElementById("purityFilterList");
    const mobilePurityNav = document.getElementById("mobileNavPurity");
    const mobilePurityList = document.getElementById("mobilePurityFilterList");
    if (purityWrap) purityWrap.classList.toggle("hidden", !purities.length);
    if (mobilePurityNav) mobilePurityNav.classList.toggle("hidden", !purities.length);
    const purityHtml = purities.length ? buildPurityHtml(purities, "purityFilter", false) : "";
    const mobilePurityHtml = purities.length ? buildPurityHtml(purities, "purityFilterMobile", true) : "";
    if (purityList) purityList.innerHTML = purityHtml;
    if (mobilePurityList) mobilePurityList.innerHTML = mobilePurityHtml;
    if (typeof updateMobileFilterUI === "function") updateMobileFilterUI();
  }

  function getFiltered() {
    const cards = Array.from(document.querySelectorAll("[data-stock-card]"));
    let rows = cards.map((el) => ({
      el,
      ...el.dataset
    }));
    const inStockOnly = isMobileFilters()
      ? document.getElementById("mobileCheckbox") || document.getElementById("checkbox")
      : document.getElementById("checkbox") || document.getElementById("mobileCheckbox");
    if (inStockOnly && inStockOnly.checked) {
      rows = rows.filter((row) => row.inStock === "true");
    }
    const purityName = isMobileFilters() ? "purityFilterMobile" : "purityFilter";
    const purityChecks = document.querySelectorAll('input[name="' + purityName + '"]:checked');
    if (purityChecks.length) {
      const names = Array.from(purityChecks).map((el) => el.value);
      const purityTotal = document.querySelectorAll('input[name="' + purityName + '"]').length;
      if (names.length < purityTotal) {
        rows = rows.filter((row) => names.includes(row.purity));
      }
    } else if (document.querySelectorAll('input[name="' + purityName + '"]').length) {
      rows = [];
    }
    for (const [group, attr] of [
      ["prefix", "prefix"],
      ["ornament", "ornament"],
      ["stockType", "stockTypeId"]
    ]) {
      const selected = getSelectedServerFilters(group);
      if (selected === null) continue;
      if (!selected.length) {
        rows = [];
        break;
      }
      rows = rows.filter((row) => selected.includes(row[attr]));
    }
    const sortField = document.getElementById("sortOrder") ? document.getElementById("sortOrder").value : "tag";
    const sortDir = document.getElementById("sortDirection") ? document.getElementById("sortDirection").value : "asc";
    const ascMul = sortDir === "asc" ? 1 : -1;
    rows.sort((a, b) => {
      let cmp = 0;
      if (sortField === "tag") cmp = (a.tag * 1 || 0) - (b.tag * 1 || 0);
      else if (sortField === "grossWt") cmp = (a.grossWt * 1 || 0) - (b.grossWt * 1 || 0);
      else if (sortField === "netWt") cmp = (a.netWt * 1 || 0) - (b.netWt * 1 || 0);
      else if (sortField === "sellingPrice") cmp = (a.sellingPrice * 1 || 0) - (b.sellingPrice * 1 || 0);
      return cmp * ascMul;
    });
    return rows;
  }

  function updateSummary(total) {
    const el = document.getElementById("resultSummary");
    if (!el) return;
    let label = window.categoryOrnamentLabelDefault || "Inventory";
    const selectedOrnaments = getSelectedServerFilters("ornament");
    if (selectedOrnaments && selectedOrnaments.length) {
      const names = selectedOrnaments.map((id) => {
        const input = isMobileFilters()
          ? document.querySelector('[data-filter-group="ornament"][data-filter-value="' + id + '"]')
          : document.querySelector('input[name="ornamentSelectFilter"][value="' + id + '"]');
        return input?.closest("label")?.querySelector("span")?.textContent?.trim() || "";
      }).filter(Boolean);
      if (names.length) label = names.join(", ");
    }
    if (!total) {
      el.innerHTML = `No products found in <span class="text-primary font-medium">${escapeHtml(label)}</span>`;
      return;
    }
    el.innerHTML = `Showing ${total} exquisite product${total > 1 ? "s" : ""} in <span class="text-primary font-medium">${escapeHtml(label)}</span>`;
  }

  function filterTable() {
    pager.resetPage();
    LoadTable();
  }

  function LoadTable() {
    const allCards = Array.from(document.querySelectorAll("[data-stock-card]"));
    const filteredRows = getFiltered();
    const {
      page
    } = pager.apply(filteredRows);
    const emptyState = document.getElementById("emptyState");
    updateSummary(filteredRows.length);
    allCards.forEach((card) => card.classList.add("hidden"));
    page.forEach((row) => row.el.classList.remove("hidden"));
    if (emptyState) {
      emptyState.classList.toggle("hidden", page.length > 0);
    }
    if (typeof updateMobileFilterUI === "function") updateMobileFilterUI();
    initCardSlideshows();
  }

  function showToast(message) {
    const toast = document.getElementById("cartToast");
    if (!toast) return;
    toast.textContent = message;
    toast.classList.remove("hidden");
    setTimeout(() => toast.classList.add("hidden"), 2500);
  }
  async function searchByTagOrSku() {
    const form = document.getElementById("filterForm");
    if (!form) return;
    const fd = new FormData(form);
    const tag = (fd.get("tag") || "").toString().trim();
    const item = (fd.get("item") || "").toString().trim();
    if (!tag && !item) return;
    const params = new URLSearchParams();
    ["prefix", "ornament", "stockType", "tag", "item"].forEach((key) => {
      const val = (fd.get(key) || "").toString().trim();
      if (val) params.set(key, val);
    });
    try {
      const res = await fetch("/inventory-query?" + params.toString(), {
        headers: {
          "X-Requested-With": "XMLHttpRequest"
        }
      });
      const data = await res.json();
      if (data.success && data.redirectUrl) {
        window.location.href = window.kbRoutes.normalizeLegacyRoute(data.redirectUrl);
        return;
      }
      showToast(data.message || "Tag Number Not Found!");
    } catch (err) {
      showToast("Could not search inventory");
    }
  }
  async function applyServerFilters() {
    const form = document.getElementById("filterForm");
    if (!form) return;
    const fd = new FormData(form);
    const tag = (fd.get("tag") || "").toString().trim();
    const item = (fd.get("item") || "").toString().trim();
    if (tag || item) {
      await searchByTagOrSku();
      return;
    }
    const hasEmptyGroup = ["prefix", "ornament", "stockType"].some((key) => {
      const selected = getSelectedServerFilters(key);
      return Array.isArray(selected) && !selected.length;
    });
    if (hasEmptyGroup) {
      filterTable();
      return;
    }
    const params = getFilterParams();
    const nextUrl = "/inventorySelection?" + params.toString();
    window.history.replaceState(null, "", nextUrl);
    await fetchInventory();
  }
  async function fetchInventory() {
    const summary = document.getElementById("resultSummary");
    const grid = document.getElementById("stockTable");
    if (!grid) return;
    const params = getFilterParams();
    if (summary) summary.textContent = "Loading products...";
    try {
      const res = await fetch("/inventory-query?" + params.toString(), {
        headers: {
          "X-Requested-With": "XMLHttpRequest"
        }
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        throw new Error(data.message || "Could not load inventory");
      }
      if (data.redirectUrl) {
        window.location.href = window.kbRoutes.normalizeLegacyRoute(data.redirectUrl);
        return;
      }
      const items = data.stockTable || [];
      grid.innerHTML = (data.cardHtml || []).join("");
      updateDynamicFilters(items);
      pager.resetPage();
      LoadTable();
    } catch (err) {
      grid.innerHTML = "";
      if (summary) summary.textContent = err.message || "Could not load inventory";
      showToast(err.message || "Could not load inventory");
    }
  }

  const cardSlideshow = {
    observer: null,
    timers: new Map()
  };

  function parseCardImages(el) {
    try {
      const urls = JSON.parse(el.getAttribute("data-images") || "[]");
      return Array.isArray(urls) ? urls.filter(Boolean) : [];
    } catch (err) {
      return [];
    }
  }

  function updateCardSlideshowDots(slideshowEl, index) {
    slideshowEl.querySelectorAll(".card-slideshow-dot").forEach((dot, i) => {
      dot.classList.toggle("bg-white", i === index);
      dot.classList.toggle("bg-white/50", i !== index);
    });
  }

  function resetCardSlideshow(slideshowEl) {
    const urls = slideshowEl._slideshowUrls;
    if (!urls || !urls.length) return;
    slideshowEl._slideshowIndex = 0;
    const img = slideshowEl.querySelector(".card-slideshow-img");
    if (img) {
      img.src = urls[0];
      img.style.opacity = "1";
    }
    updateCardSlideshowDots(slideshowEl, 0);
  }

  function advanceCardSlideshow(slideshowEl) {
    const urls = slideshowEl._slideshowUrls;
    if (!urls || urls.length <= 1) return;
    const nextIndex = ((slideshowEl._slideshowIndex || 0) + 1) % urls.length;
    slideshowEl._slideshowIndex = nextIndex;
    const img = slideshowEl.querySelector(".card-slideshow-img");
    if (!img) return;
    img.style.opacity = "0";
    window.setTimeout(() => {
      img.onload = () => {
        img.style.opacity = "1";
      };
      img.src = urls[nextIndex];
      if (img.complete) img.style.opacity = "1";
    }, 180);
    updateCardSlideshowDots(slideshowEl, nextIndex);
  }

  function startCardSlideshow(slideshowEl) {
    if (cardSlideshow.timers.has(slideshowEl)) return;
    const timer = window.setInterval(() => advanceCardSlideshow(slideshowEl), 3000);
    cardSlideshow.timers.set(slideshowEl, timer);
  }

  function stopCardSlideshow(slideshowEl) {
    const timer = cardSlideshow.timers.get(slideshowEl);
    if (!timer) return;
    window.clearInterval(timer);
    cardSlideshow.timers.delete(slideshowEl);
    resetCardSlideshow(slideshowEl);
  }

  function stopAllCardSlideshows() {
    cardSlideshow.timers.forEach((timer, slideshowEl) => {
      window.clearInterval(timer);
      resetCardSlideshow(slideshowEl);
    });
    cardSlideshow.timers.clear();
    if (cardSlideshow.observer) {
      cardSlideshow.observer.disconnect();
      cardSlideshow.observer = null;
    }
  }

  function isCardFullyVisible(cardEl) {
    const rect = cardEl.getBoundingClientRect();
    return (
      rect.top >= 0 &&
      rect.left >= 0 &&
      rect.bottom <= window.innerHeight &&
      rect.right <= window.innerWidth &&
      rect.width > 0 &&
      rect.height > 0
    );
  }

  function syncCardSlideshowVisibility(cardEl) {
    const slideshowEl = cardEl._slideshowEl;
    if (!slideshowEl || cardEl.classList.contains("hidden")) {
      if (slideshowEl) stopCardSlideshow(slideshowEl);
      return;
    }
    if (isCardFullyVisible(cardEl)) startCardSlideshow(slideshowEl);
    else stopCardSlideshow(slideshowEl);
  }

  function syncAllCardSlideshows() {
    document.querySelectorAll("[data-stock-card]").forEach((cardEl) => {
      if (cardEl._slideshowEl) syncCardSlideshowVisibility(cardEl);
    });
  }

  function initCardSlideshows() {
    stopAllCardSlideshows();

    const watchedCards = [];
    document.querySelectorAll("[data-stock-card]").forEach((cardEl) => {
      const slideshowEl = cardEl.querySelector("[data-card-slideshow]");
      if (!slideshowEl) return;
      const urls = parseCardImages(slideshowEl);
      if (urls.length <= 1) return;
      slideshowEl._slideshowUrls = urls;
      slideshowEl._slideshowIndex = 0;
      cardEl._slideshowEl = slideshowEl;
      resetCardSlideshow(slideshowEl);
      watchedCards.push(cardEl);
    });

    if (!watchedCards.length) return;

    cardSlideshow.observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          syncCardSlideshowVisibility(entry.target);
        });
      },
      { threshold: [0, 0.25, 0.5, 0.75, 1] }
    );

    watchedCards.forEach((cardEl) => {
      cardSlideshow.observer.observe(cardEl);
      syncCardSlideshowVisibility(cardEl);
    });

    if (!cardSlideshow._scrollBound) {
      cardSlideshow._scrollBound = true;
      window.addEventListener("scroll", syncAllCardSlideshows, { passive: true });
      window.addEventListener("resize", syncAllCardSlideshows);
    }
  }

  function SlideShow() {
    initCardSlideshows();
  }

  function goPage(page) {
    pager.goPage(page);
    document.getElementById("stockTable")?.scrollIntoView({
      behavior: "smooth",
      block: "start"
    });
  }

  function AddToCart(id) {
    fetch("/addToCart?index=" + id, {
        headers: {
          "X-Requested-With": "XMLHttpRequest"
        }
      })
      .then((res) => res.json())
      .then((data) => showToast(data.message || "Added to cart"))
      .catch(() => {});
  }

  function setFilterAction(url) {
    document.getElementById("filterForm").action = url;
    document.getElementById("filterForm").submit();
  }
  let filterTimer = null;

  function bindMobileFilter() {
    const btn = document.getElementById("mobileFilterToggle");
    const wrap = document.getElementById("filterPanelWrap");
    const chevron = document.getElementById("mobileFilterChevron");
    if (!btn || !wrap) return;
    btn.addEventListener("click", () => {
      wrap.classList.toggle("hidden");
      chevron?.classList.toggle("rotate-180");
    });
  }

  function bindServerFilterCheckboxes(formId, autoApply) {
    const form = document.getElementById(formId);
    if (!form) return;
    form.querySelectorAll("[data-filter-group]").forEach((cb) => {
      cb.addEventListener("change", function () {
        const group = this.dataset.filterGroup;
        const hidden = form.querySelector('[name="' + group + '"]');
        if (this.checked) {
          form.querySelectorAll('[data-filter-group="' + group + '"]').forEach((el) => {
            if (el !== this) el.checked = false;
          });
          if (hidden) hidden.value = this.dataset.filterValue || "";
        } else if (hidden && hidden.value === (this.dataset.filterValue || "")) {
          hidden.value = group === "prefix" ? (this.dataset.filterValue || "") : "";
          this.checked = true;
        }
        if (autoApply) {
          const tagInput = form.querySelector('[name="tag"]');
          const itemInput = form.querySelector('[name="item"]');
          if (tagInput) tagInput.value = "";
          if (itemInput) itemInput.value = "";
          applyServerFilters();
        }
        if (typeof updateMobileFilterUI === "function") updateMobileFilterUI();
      });
    });
  }

  function bindFilterForm() {
    const form = document.getElementById("filterForm");
    if (!form) return;
    form.addEventListener("submit", (e) => {
      if (form.action && form.action.includes("/addToCart")) return;
      e.preventDefault();
    });
    ["prefix", "ornament", "stockType"].forEach((group) => {
      const inputName = getDesktopFilterInputName(group);
      form.querySelectorAll('input[name="' + inputName + '"]').forEach((el) => {
        el.addEventListener("change", () => {
          if (typeof syncDesktopToMobileFilters === "function") syncDesktopToMobileFilters();
          const tagInput = form.querySelector('[name="tag"]');
          const itemInput = form.querySelector('[name="item"]');
          if (tagInput) tagInput.value = "";
          if (itemInput) itemInput.value = "";
          filterTable();
          applyServerFilters();
        });
      });
    });
    const tagInput = form.querySelector('[name="tag"]');
    const itemInput = form.querySelector('[name="item"]');
    const scheduleTagSkuSearch = () => {
      clearTimeout(filterTimer);
      filterTimer = setTimeout(applyServerFilters, 400);
    };
    tagInput?.addEventListener("input", scheduleTagSkuSearch);
    itemInput?.addEventListener("input", scheduleTagSkuSearch);
  }
  document.addEventListener("DOMContentLoaded", () => {
    bindMobileFilter();
    bindFilterForm();
    fetchInventory();
  });
  window.addEventListener("resize", syncPerPage);
</script>