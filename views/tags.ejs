<% activeNav = 'inventory' %>
<% const fmtPrice = n => new Intl.NumberFormat('en-IN').format(Math.round((n || 0) * 1)); %>
<% const label = "text-[10px] font-semibold uppercase tracking-widest text-secondary"; %>
<% const val = "text-sm font-semibold text-on-surface dark:text-dark-text"; %>
<% const backLink = typeof backHref !== 'undefined' ? backHref : '/cart'; %>
<div class="pb-10 space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <h2 class="text-display-lg-mobile md:text-headline-xl font-bold text-on-surface dark:text-dark-text tracking-tight mb-1"><%= title || 'Print Tags' %></h2>
      <p class="text-sm text-secondary"><%= stockTable.length %> tag<%= stockTable.length !== 1 ? 's' : '' %> ready to print</p>
    </div>
    <div class="flex flex-wrap items-center gap-2 shrink-0">
      <a href="<%= backLink %>" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg border border-outline bg-surface-container-lowest dark:bg-dark-container text-sm font-semibold text-on-surface dark:text-dark-text hover:bg-surface-container transition-colors">
        <i class="fas fa-arrow-left text-xs"></i> Back
      </a>
      <button type="button" onclick="printTags()" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all">
        <i class="fas fa-print text-xs"></i> Print Tags
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
    <% for (let item of stockTable) { %>
    <div class="bg-surface-container-lowest dark:bg-dark-container rounded-xl border border-surface-container dark:border-white/10 shadow-whisper overflow-hidden">
      <div class="px-5 py-3 border-b border-surface-container dark:border-white/10 bg-surface-container-low/50 flex items-center justify-between gap-2">
        <span class="text-sm font-bold text-on-surface dark:text-dark-text truncate">
          <%= item.prefix.name %> <%= item.ornament.name %> #<%= item.tag %>
        </span>
        <% if (item.stockType) { %>
        <span class="shrink-0 text-[10px] font-semibold uppercase tracking-wide bg-primary-fixed/40 text-primary px-2 py-0.5 rounded"><%= item.stockType.name %></span>
        <% } %>
      </div>
      <div class="p-5 grid grid-cols-2 gap-4">
        <div class="space-y-3">
          <div>
            <p class="<%= label %>">Gross Weight</p>
            <p class="<%= val %>"><%= (item.grossWt * 1).toFixed(3) %> gm</p>
          </div>
          <div>
            <p class="<%= label %>">Net Weight</p>
            <p class="<%= val %>"><%= (item.netWt * 1).toFixed(3) %> gm</p>
          </div>
          <div>
            <p class="<%= label %>">Purity</p>
            <p class="<%= val %>"><%= item.purity ? item.purity.name : '—' %><% if (item.kaarigar) { %> | <%= item.kaarigar.name %><% } %></p>
          </div>
        </div>
        <div class="space-y-3">
          <div>
            <p class="<%= label %>"><%= tag_name %></p>
            <p class="<%= val %>">#<%= item.index %></p>
          </div>
          <% if (item.stoneTable && item.stoneTable.length) { %>
          <div>
            <p class="<%= label %>">Stones</p>
            <% for (let j of item.stoneTable) { %>
            <p class="text-xs font-medium text-on-surface dark:text-dark-text"><%= j.type.name %> — <%= (j.ctWeight * 1).toFixed(3) %> ct</p>
            <% } %>
          </div>
          <% } %>
          <div>
            <p class="<%= label %>">Price</p>
            <p class="text-base font-bold text-primary">&#8377;<%= fmtPrice(item.sellingPrice) %> /-</p>
          </div>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <div id="printTagsArea" class="hidden">
    <% for (let i of stockTable) { %>
    <div class="tag-print-row">
      <div class="tag-left">
        <span><%= i.prefix.name %> <%= i.ornament.name %> # <%= i.tag %> (<%= i.stockType.name %>)</span>
        <span>G. Wt. <%= (i.grossWt * 1).toFixed(3) %> gm</span>
        <span>N. Wt. <%= (i.netWt * 1).toFixed(3) %> gm</span>
        <span><%= i.purity.name %><% if (i.kaarigar) { %> | <%= i.kaarigar.name %><% } %></span>
      </div>
      <div class="tag-right">
        <span><%= tag_name %> | <%= i.index %></span>
        <% for (let j of i.stoneTable) { %>
        <span><%= j.type.name %> - <%= (j.ctWeight * 1).toFixed(3) %> ct</span>
        <% } %>
        <span>&#8377;&nbsp;<%= i.sellingPrice.toFixed(0) %>&nbsp;/-</span>
      </div>
      <div class="tag-extra"></div>
    </div>
    <% } %>
  </div>
</div>
<script>
  function printTags() {
    const area = document.getElementById('printTagsArea');
    if (!area) return;
    const win = window.open('', '_blank');
    if (!win) return;
    let html = '<html><head><title>Print Tags</title><style>';
    html += 'body{margin:0;font-family:sans-serif;font-size:10px}';
    html += '.tag-print-row{display:flex;flex-direction:row;font-weight:bold;width:100%;height:100vh;page-break-after:always}';
    html += '.tag-left,.tag-right{display:flex;flex-direction:column;width:27%;height:100%;padding-left:25px}';
    html += '.tag-right{padding-left:10px}';
    html += '.tag-extra{width:46%}';
    html += 'span{white-space:nowrap}';
    html += '</style></head><body>';
    html += area.innerHTML;
    html += '</body></html>';
    win.document.write(html);
    win.document.close();
    win.focus();
    win.print();
    win.close();
  }
</script>
