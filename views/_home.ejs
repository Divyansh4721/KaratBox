<% activeNav = 'home' %>
<div class="space-y-5 w-full">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-5">
    <div class="rounded-xl bg-gradient-to-b from-primary-fixed/25 via-surface-container-lowest to-surface-container-lowest dark:from-dark-brand/15 dark:via-dark-container dark:to-dark-container p-5 lg:p-6 flex flex-col justify-between border border-primary-container/50 dark:border-dark-brand/40 shadow-sm min-w-0 w-full">
      <div>
        <div class="flex items-center gap-2 text-primary dark:text-dark-brand mb-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
          <h3 class="text-base lg:text-body-lg font-bold tracking-tight">Gold Rate Manager</h3>
        </div>
        <p class="text-sm text-secondary font-light leading-relaxed max-w-md">
          Update the current rate for calculations across all inventory valuations and billing systems.
        </p>
      </div>
      <div class="text-center my-4">
        <span class="block text-[10px] uppercase tracking-widest text-secondary mb-1">Current 24K Rate</span>
        <div class="flex items-baseline justify-center gap-1">
          <span class="text-3xl lg:text-4xl font-bold text-on-surface dark:text-dark-text tracking-tight">
            <span class="text-primary-container dark:text-dark-brand font-semibold">₹</span>
            <%= goldPrice ? (goldPrice.value * 1).toLocaleString('en-IN') : '0' %>
          </span>
          <span class="text-xs text-secondary font-light">/ gm</span>
        </div>
      </div>
      <form id="gold-rate-form" action="/goldPriceForm" method="POST" class="space-y-3">
        <input type="number" name="amount" id="gold-rate-input" min="0" step="1" value="<%= goldPrice ? goldPrice.value : 0 %>" class="w-full px-4 py-2.5 bg-surface-container-low dark:bg-dark-container border border-outline-variant/40 dark:border-white/10 rounded-DEFAULT text-body-md text-on-surface dark:text-dark-text focus:outline-none focus:border-primary-container dark:focus:border-dark-brand transition-colors" placeholder="Enter gold rate per gm" />
        <div class="flex gap-2">
          <button type="button" id="sync-live-gold-rate" disabled class="flex-1 py-2.5 bg-emerald-600/10 hover:bg-emerald-600/20 dark:bg-emerald-500/10 dark:hover:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 border border-emerald-300/60 dark:border-emerald-700/60 text-[11px] uppercase font-semibold tracking-wider rounded-DEFAULT transition-all duration-card active:scale-[0.98] focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed">
            Sync Live
          </button>
          <button type="submit" class="flex-1 py-2.5 bg-primary-container hover:brightness-105 dark:bg-dark-brand dark:hover:bg-dark-brand-hover text-on-primary dark:text-dark-on-brand text-[11px] uppercase font-semibold tracking-wider rounded-DEFAULT shadow-sm hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-card active:scale-[0.98] focus:outline-none">
            Update
          </button>
        </div>
      </form>
    </div>
    <div id="live-gold-tracker" class="rounded-xl bg-gradient-to-b from-emerald-50/80 via-surface-container-lowest to-surface-container-lowest dark:from-emerald-950/20 dark:via-dark-container dark:to-dark-container p-5 lg:p-6 flex flex-col justify-between border border-emerald-200/60 dark:border-emerald-800/40 shadow-sm min-w-0 w-full min-h-[220px] lg:min-h-[320px]">
      <div>
        <div class="flex items-center justify-between gap-2 mb-2">
          <div class="flex items-center gap-2 text-emerald-700 dark:text-emerald-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <h3 class="text-base lg:text-body-lg font-bold tracking-tight">Live Gold Rate</h3>
          </div>
          <span id="live-gold-status" class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-wider font-semibold text-emerald-600 dark:text-emerald-400">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            Live
          </span>
        </div>
        <p class="text-sm text-secondary font-light leading-relaxed max-w-md">
          Real-time 995 gold sell rate.
        </p>
      </div>
      <div class="text-center my-4">
        <span class="block text-[10px] uppercase tracking-widest text-secondary mb-1">Market Sell Rate</span>
        <div class="flex items-baseline justify-center gap-1">
          <span id="live-gold-rate" class="text-3xl lg:text-4xl font-bold text-on-surface dark:text-dark-text tracking-tight">
            <span class="text-emerald-600 dark:text-emerald-400 font-semibold">₹</span>—
          </span>
          <span class="text-xs text-secondary font-light">/ gm</span>
        </div>
      </div>
      <p id="live-gold-updated" class="text-[10px] text-secondary text-center mt-3 uppercase tracking-wider"></p>
    </div>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5 w-full">
    <a href="/stock/add" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-plus-square"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">Stock Add</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">Add new jewelry items to inventory with tags, purity, and weight details.</p>
    </a>
    <a href="/inventory" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-gem"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">Inventory</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">Browse, search, and manage your complete luxury stock portfolio.</p>
    </a>
    <a href="/approvalViewPage" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-shield-halved"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">Approval</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">Review customer approvals, verify items, and process returns.</p>
    </a>
    <a href="/list_master" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-list-check"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">List Master</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">Configure master lists for purity, ornaments, dealers, and more.</p>
    </a>
    <a href="/customerTable" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-users"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">Customer</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">Manage client profiles, balances, payments, and transaction history.</p>
    </a>
    <a href="/billPage" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-file-invoice"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">Bills</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">View and manage customer sale bills across your portfolio.</p>
    </a>
    <a href="/dataPage" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-database"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">Reports</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">Access daily sheets, stock reports, and historical data exports.</p>
    </a>
    <a href="/analytics" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-chart-line"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1.5 group-hover:text-primary dark:group-hover:text-dark-brand transition-colors">Analytics</h3>
      <p class="text-sm text-secondary font-light leading-relaxed">Track performance insights and business trends across operations.</p>
    </a>
  </div>
</div>
<script>
  (function() {
    const rateEl = document.getElementById('live-gold-rate');
    const updatedEl = document.getElementById('live-gold-updated');
    const statusEl = document.getElementById('live-gold-status');
    const syncBtn = document.getElementById('sync-live-gold-rate');
    const goldInput = document.getElementById('gold-rate-input');
    const goldForm = document.getElementById('gold-rate-form');
    const fmt = (n) => n != null ? Number(n).toLocaleString('en-IN') : '—';
    const perGm = (n) => n != null ? Math.round(Number(n) / 10) : null;
    let lastLiveRate = null;
    async function fetchLiveGoldRate() {
      try {
        const res = await fetch('/api/liveGoldRate');
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json();
        if (data.rate == null) throw new Error('no rate');
        lastLiveRate = perGm(data.rate);
        rateEl.innerHTML = '<span class="text-emerald-600 dark:text-emerald-400 font-semibold">₹</span>' + fmt(lastLiveRate);
        updatedEl.textContent = 'Updated ' + new Date().toLocaleTimeString('en-IN');
        statusEl.classList.remove('text-red-500', 'dark:text-red-400');
        statusEl.classList.add('text-emerald-600', 'dark:text-emerald-400');
        syncBtn.disabled = false;
      } catch (e) {
        lastLiveRate = null;
        syncBtn.disabled = true;
        statusEl.innerHTML = '<span class="text-red-500 dark:text-red-400">Offline</span>';
      }
    }
    syncBtn.addEventListener('click', function() {
      if (lastLiveRate == null) return;
      goldInput.value = lastLiveRate;
      goldForm.submit();
    });
    fetchLiveGoldRate();
    setInterval(fetchLiveGoldRate, 3000);
  })();
</script>