<% const tp = typeof tablePage !== 'undefined' ? tablePage : {}; %>
<% const colCount = tp.colCount || (tp.columns ? tp.columns.length : 1); %>
<% const minWidth = tp.minWidth || '720px'; %>
<% const emptyColspan = tp.emptyColspan || colCount; %>
<div class="pb-10">
  <% if (typeof tableFilters !== 'undefined' && tableFilters && tableFilters.length) { %>
  <%- include('_filters', { filters: tableFilters, label: typeof label !== 'undefined' ? label : undefined, field: typeof field !== 'undefined' ? field : undefined, filterGridClass: typeof filterGridClass !== 'undefined' ? filterGridClass : undefined }) %>
  <% } %>
  <div class="bg-surface-container-lowest rounded-[22px] border border-surface-container shadow-whisper overflow-hidden <%= tp.tableClass || '' %>">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-5 py-4 border-b border-surface-container">
      <h3 class="text-sm font-bold text-on-surface shrink-0"><%= tp.tableTitle %></h3>
      <% if (tp.headerActions) { %>
      <div class="flex items-center gap-2 sm:ml-auto"><%- tp.headerActions %></div>
      <% } %>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[<%= minWidth %>]">
        <thead>
          <tr class="bg-surface-container-low text-[10px] font-semibold uppercase tracking-widest text-secondary">
            <% (tp.columns || []).forEach(function(col) { %>
            <th class="text-<%= col.align || 'left' %> py-3 <%= col.thClass || 'px-4' %>"><%= col.label %></th>
            <% }); %>
          </tr>
        </thead>
        <tbody id="<%= tp.tableId %>"></tbody>
      </table>
    </div>
    <%- include('../partials/_pagination_footer', tp.pagination || {}) %>
  </div>
  <% if (typeof tablePageAfter !== 'undefined' && tablePageAfter) { %>
  <%- tablePageAfter %>
  <% } %>
</div>