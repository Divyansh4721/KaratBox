<script src="https://cdn.tailwindcss.com"></script>
<%- include('layoutStockTable',{stockTable:stockTable}); %>
    <div class="bg-gray-900 text-gray-200 antialiased min-h-screen">
        <div class="grid grid-cols-2 max-w-6xl mx-auto gap-6 p-4 justify-center">
            <button onclick="printTable('printTable', 0)"
                class="px-6 py-3 theme-color theme-color-hover:hover text-white font-semibold rounded-lg shadow-md transition">
                Print Table
            </button>
            <a href="/printMultipleTags" class="w-full sm:w-auto">
                <button
                    class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition">
                    Print Tags
                </button>
            </a>
            <a href="/estimateRetail">
                <button
                    class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition">Estimate
                    Retail</button>
            </a>
            <a href="/estimateWholesale">
                <button
                    class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition">Estimate
                    Wholesale</button>
            </a>
            <a href="/soldRetailPage">
                <button
                    class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition">Sold
                    Retail</button>
            </a>
            <a href="/soldWholesalePage">
                <button
                    class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition">Sold
                    Wholesale</button>
            </a>
            <a href="/editMultipleStock">
                <button
                    class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition">Edit
                    Multiple</button>
            </a>
            <a href="/approvalPage">
                <button
                    class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-md transition">Approval
                    Page</button>
            </a>
            <a href="/clearCart">
                <button
                    class="w-full px-6 py-3 bg-red-600 text-white font-semibold rounded-lg shadow-md hover:bg-red-700 transition">Clear
                    Cart</button>
            </a>
        </div>

        <!-- Cart Items Grid -->
        <main class="p-4 sm:p-6 lg:p-8">
            <div id="stockTable"
                class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-6 w-full max-w-screen-2xl mx-auto">
            </div>
        </main>
    </div>
    <script>
        let stockTable = JSON.parse((`<%= JSON.stringify(stockTable,null,2) %>`).replaceAll('&#34;', '"'));
    </script>
    <script src="<%= assetPath('js/cart.js') %>"></script>
    <script src="<%= assetPath('js/printTable.js') %>"></script>