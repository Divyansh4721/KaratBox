<% activeNav = 'list_master' %>
<% const masterCard = "group bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-3 sm:p-5 flex flex-col h-full hover:-translate-y-1 hover:shadow-card-hover transition-all duration-card"; %>
<% const iconWrap = "w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-primary-fixed/35 flex items-center justify-center text-primary mb-2 sm:mb-4 group-hover:bg-primary-fixed/50 transition-colors"; %>
<div class="pb-10">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-5 mb-8">
    <a href="/list_master/kaarigar" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-user-tie"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">Kaarigar</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Manage artisans, craftsmen and manufacturing contacts.</p>
    </a>
    <a href="/list_master/ornament" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-ring"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">Ornament</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Define jewelry pieces, designs, and product categories.</p>
    </a>
    <a href="/list_master/prefix" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-list-ol"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">Prefix</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Set up naming conventions and stock code prefixes.</p>
    </a>
    <a href="/list_master/purity" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-percent"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">Purity</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Gold carats, multipliers, and wastage calculations.</p>
    </a>
    <a href="/list_master/stocktype" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-box"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">StockType</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Categorize physical inventory and storage types.</p>
    </a>
    <a href="/list_master/stonedealer" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-store"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">StoneDealer</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Database of gem suppliers and diamond vendors.</p>
    </a>
    <a href="/list_master/stonetype" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-gem"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">StoneType</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Classify diamonds, rubies, emeralds and other gems.</p>
    </a>
  </div>
  <div id="settings-row" class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-5 mb-8 scroll-mt-6">
    <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6">
      <span class="<%= iconWrap %>"><i class="fas fa-tag"></i></span>
      <h3 class="text-base font-bold text-on-surface mb-4">Tag Name</h3>
      <div class="text-center my-4">
        <span class="block text-[10px] uppercase tracking-widest text-secondary mb-1">Current Tag Name</span>
        <p id="currentTagName" class="text-3xl font-bold text-on-surface tracking-tight"><%= TagName.value || '—' %></p>
      </div>
      <form id="tagNameForm" action="/list_master/update-tag-name" method="post" class="flex flex-col sm:flex-row gap-3">
        <input type="text" name="TagName" value="<%= TagName.value %>" placeholder="Tag Name..." required class="flex-1 px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-body-md text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors">
        <button type="submit" class="px-6 py-3 bg-primary-container hover:brightness-105 text-on-primary text-sm font-semibold rounded-lg shadow-sm transition-all shrink-0">Update</button>
      </form>
    </div>
    <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6">
      <span class="<%= iconWrap %>"><i class="fas fa-chart-line"></i></span>
      <h3 class="text-base font-bold text-on-surface mb-4">Gold Rate</h3>
      <div class="text-center my-4">
        <span class="block text-[10px] uppercase tracking-widest text-secondary mb-1">Current 24K Rate</span>
        <div class="flex items-baseline justify-center gap-1">
          <span id="currentGoldRate" class="text-3xl font-bold text-on-surface tracking-tight">
            <span class="text-primary-container font-semibold">₹</span>
            <%= goldPrice ? (goldPrice.value * 1).toLocaleString('en-IN') : '0' %>
          </span>
          <span class="text-xs text-secondary font-light">/ gm</span>
        </div>
      </div>
      <form id="goldPriceForm" action="/goldPriceForm" method="post" class="flex flex-col sm:flex-row gap-3">
        <input type="number" name="amount" min="0" step="1" value="<%= goldPrice ? goldPrice.value : 0 %>" class="flex-1 px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-body-md text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors" placeholder="Enter gold rate per gm" />
        <button type="submit" class="px-6 py-3 bg-primary-container hover:brightness-105 text-on-primary text-sm font-semibold rounded-lg shadow-sm transition-all shrink-0">Update Gold Rate</button>
      </form>
    </div>
  </div>
</div>
<script>
  function notify(text, type) {
    if (typeof Noty !== 'undefined') {
      new Noty({ theme: 'nest', text, type, layout: 'topCenter', timeout: 2000 }).show();
    } else {
      alert(text);
    }
  }

  async function postForm(url, form) {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(form))
    });
    const json = await res.json();
    if (!json.success) throw new Error(json.message || 'Request failed');
    return json;
  }

  document.getElementById('tagNameForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = e.target.querySelector('[name="TagName"]');
    try {
      const json = await postForm('/list_master/update-tag-name', e.target);
      const value = input.value.trim() || '—';
      document.getElementById('currentTagName').textContent = value;
      notify('Tag name updated successfully!', 'success');
    } catch (err) {
      notify(err.message, 'error');
    }
  });

  document.getElementById('goldPriceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = e.target.querySelector('[name="amount"]');
    const amount = Math.round(Number(input.value) || 0);
    try {
      const res = await fetch('/goldPriceForm', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ amount: String(amount) }),
        redirect: 'manual'
      });
      if (res.type === 'opaqueredirect' || res.status === 302 || res.status === 303 || res.ok) {
        input.value = amount;
        document.getElementById('currentGoldRate').innerHTML =
          '<span class="text-primary-container font-semibold">₹</span>' + amount.toLocaleString('en-IN');
        notify('Gold rate updated successfully!', 'success');
        return;
      }
      throw new Error('Could not update gold rate');
    } catch (err) {
      notify(err.message || 'Could not update gold rate', 'error');
    }
  });
</script>