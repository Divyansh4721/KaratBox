<% activeNav = 'khata' %>
<% const fmt = n => new Intl.NumberFormat('en-IN').format(Math.abs(n * 1)); %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const initials = (client.name || 'C').trim().charAt(0).toUpperCase(); %>
<% const bookName = client.book ? client.book.name : '—'; %>
<% const bookId = client.book ? client.book._id : ''; %>
<% const balanceTone = netBalance > 0 ? 'receivable' : netBalance < 0 ? 'payable' : 'settled'; %>
<div class="pb-10">
  <div class="flex flex-wrap items-center gap-3 mb-4">
    <a href="/khataBook/clients<%= bookId ? '?book=' + bookId : '' %>" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
      <i class="fas fa-arrow-left text-xs"></i> Back to clients
    </a>
    <span class="text-[10px] font-bold uppercase tracking-wide text-primary bg-primary-fixed/40 px-2.5 py-1 rounded-full"><%= bookName %></span>
  </div>
  <div class="rounded-xl bg-primary text-on-primary overflow-hidden shadow-whisper mb-6">
    <div class="p-6 sm:p-8 flex flex-wrap items-center gap-5">
      <div class="w-16 h-16 rounded-xl bg-surface-container-lowest/20 border border-on-primary/20 flex items-center justify-center shrink-0">
        <span class="text-2xl font-bold text-on-primary/70"><%= initials %></span>
      </div>
      <div class="flex-1 min-w-0">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight truncate"><%= client.name %></h2>
        <p class="text-sm text-on-primary/75 mt-0.5">
          +91 <%= client.phNum %><% if (client.address) { %> &middot; <%= client.address %><% } %>
        </p>
      </div>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6">
      <p class="<%= label %>">Net Balance</p>
      <% if (balanceTone === 'settled') { %>
      <p class="text-2xl font-bold text-on-surface mt-1">&#8377; 0</p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-wide text-secondary bg-surface-container px-2.5 py-1 rounded-full">Settled</span>
      <% } else if (balanceTone === 'receivable') { %>
      <p class="text-2xl font-bold text-emerald-600 dark:text-emerald-400 mt-1">&#8377; <%= fmt(netBalance) %></p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-wide text-emerald-700 bg-emerald-100 dark:text-emerald-300 dark:bg-emerald-900/40 px-2.5 py-1 rounded-full">You'll Get</span>
      <% } else { %>
      <p class="text-2xl font-bold text-rose-600 dark:text-rose-400 mt-1">&#8377; <%= fmt(netBalance) %></p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-wide text-rose-700 bg-rose-100 dark:text-rose-300 dark:bg-rose-900/40 px-2.5 py-1 rounded-full">You'll Give</span>
      <% } %>
      <p class="text-xs text-secondary mt-4 leading-relaxed"><strong>Credit</strong> = Jama (received). <strong>Debit</strong> = Udhar (given on credit).</p>
    </div>
    <div class="lg:col-span-2 bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden">
      <div class="px-6 pt-6 pb-0">
        <h3 class="text-sm font-bold text-primary mb-4 flex items-center gap-2"><i class="fas fa-plus text-xs"></i> Add Entry</h3>
      </div>
      <div class="flex items-end gap-0 px-6 border-b border-surface-container">
        <button type="button" id="tabDebit" class="txn-tab txn-tab-active min-w-[8rem] h-10 inline-flex items-center justify-center gap-2 rounded-t-lg border border-b-0 border-surface-container bg-surface-container-lowest px-4 text-sm font-semibold text-on-surface -mb-px relative z-[1]">
          <i class="fas fa-arrow-up text-xs text-rose-500"></i> Debit
        </button>
        <button type="button" id="tabCredit" class="txn-tab min-w-[8rem] h-10 inline-flex items-center justify-center gap-2 rounded-t-lg border border-transparent px-4 text-sm font-semibold text-secondary -mb-px">
          <i class="fas fa-arrow-down text-xs text-emerald-500"></i> Credit
        </button>
        <button type="button" id="tabImage" class="txn-tab min-w-[8rem] h-10 inline-flex items-center justify-center gap-2 rounded-t-lg border border-transparent px-4 text-sm font-semibold text-secondary -mb-px">
          <i class="fas fa-file-image text-xs text-primary"></i> Invoice
        </button>
      </div>
      <div class="p-6">
        <form id="entryForm" class="space-y-4">
          <input type="hidden" name="client" value="<%= client._id %>">
          <input type="hidden" name="type" id="entryType" value="debit">
          <div id="amountFields" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="<%= label %>">Amount (&#8377;)</label>
              <input type="number" name="amount" id="entryAmount" step="0.01" min="0.01" placeholder="Enter amount..." class="<%= field %>">
            </div>
          </div>
          <div id="imageField" class="hidden">
            <label class="<%= label %>">Invoice / Bill Image</label>
            <label class="flex flex-col items-center justify-center gap-2 w-full px-4 py-6 border-2 border-dashed border-outline-variant/50 rounded-xl bg-surface-container-low cursor-pointer hover:border-primary-container transition-colors">
              <i class="fas fa-cloud-upload-alt text-xl text-secondary"></i>
              <span class="text-xs text-secondary">PNG or JPG only</span>
              <input type="file" name="image" id="entryImage" accept="image/png,image/jpeg,image/jpg" class="hidden">
            </label>
            <img id="imagePreview" src="" alt="" class="hidden mt-3 max-h-36 rounded-lg border border-surface-container object-contain">
          </div>
          <div>
            <label class="<%= label %>">Remarks</label>
            <textarea name="remark" rows="2" placeholder="Optional note..." class="<%= field %> resize-none"></textarea>
          </div>
          <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg">
            <i class="fas fa-check text-xs"></i> <span id="submitLabel">Add Debit Entry</span>
          </button>
        </form>
      </div>
    </div>
  </div>
  <div class="bg-surface-container-low/60 rounded-xl border border-dashed border-outline-variant/50 p-5 mb-6 flex items-start gap-4 opacity-80">
    <span class="w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center shrink-0 text-secondary"><i class="fas fa-bell"></i></span>
    <div>
      <p class="text-sm font-bold text-on-surface">Payment Reminders &amp; Collections</p>
      <p class="text-xs text-secondary mt-1">Planned for a future release.</p>
      <span class="inline-block mt-2 text-[10px] font-bold uppercase tracking-widest text-secondary bg-surface-container px-2.5 py-1 rounded-full">Coming Soon</span>
    </div>
  </div>
  <div class="bg-primary-fixed/25 rounded-xl border border-primary-container/20 p-5 mb-6 flex flex-wrap items-center justify-between gap-4">
    <div>
      <p class="text-sm font-bold text-on-surface">Settle Ledger</p>
      <p class="text-xs text-secondary mt-1">Clear all transactions for <%= client.name %> in book <strong><%= bookName %></strong>.</p>
    </div>
    <button type="button" onclick="settleClient()" class="px-5 py-2.5 border-2 border-primary text-primary font-bold text-sm rounded-lg hover:bg-primary-fixed/40 transition-colors">Settle Now</button>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden">
    <div class="px-5 py-4 border-b border-surface-container flex items-center justify-between">
      <h3 class="text-sm font-bold text-on-surface">Transaction History</h3>
      <span class="text-xs text-secondary"><%= entries.length %> entr<%= entries.length === 1 ? 'y' : 'ies' %></span>
    </div>
    <% if (entries.length) { %>
    <div class="divide-y divide-surface-container" id="entriesList">
      <% for (let e of entries) { %>
      <div class="flex items-start justify-between gap-4 px-5 py-4 hover:bg-surface-container-low/30">
        <div class="flex items-start gap-4 min-w-0">
          <% if (e.image) { %>
          <span class="w-10 h-10 rounded-full bg-primary-fixed/40 text-primary flex items-center justify-center shrink-0"><i class="fas fa-file-image text-sm"></i></span>
          <% } else if (e.type === 'debit') { %>
          <span class="w-10 h-10 rounded-full bg-rose-100 text-rose-600 dark:bg-rose-900/40 dark:text-rose-300 flex items-center justify-center shrink-0"><i class="fas fa-arrow-up text-sm"></i></span>
          <% } else { %>
          <span class="w-10 h-10 rounded-full bg-emerald-100 text-emerald-600 dark:bg-emerald-900/40 dark:text-emerald-300 flex items-center justify-center shrink-0"><i class="fas fa-arrow-down text-sm"></i></span>
          <% } %>
          <div class="min-w-0">
            <% if (e.amount) { %><p class="font-bold text-on-surface">&#8377; <%= fmt(e.amount) %> /-</p><% } %>
            <% if (e.type === 'debit') { %><p class="text-xs font-semibold text-rose-600">Debit (Udhar)</p><% } %>
            <% if (e.type === 'credit') { %><p class="text-xs font-semibold text-emerald-600">Credit (Jama)</p><% } %>
            <% if (e.image && !e.amount) { %><p class="text-xs font-semibold text-primary">Invoice / Image Entry</p><% } %>
            <p class="text-xs text-secondary mt-1"><%= convertDate(e.date) %><% if (e.remark) { %> &middot; <%= e.remark %><% } %></p>
            <% if (e.image) { %>
            <button type="button" data-image="<%= e.image %>" onclick="openImageModal(this.dataset.image)" class="mt-2 text-xs font-semibold text-primary hover:underline">View attachment</button>
            <% } %>
          </div>
        </div>
        <button type="button" onclick="deleteEntry('<%= e.id %>')" class="p-2 text-secondary hover:text-error rounded-lg shrink-0" title="Delete"><i class="fas fa-trash"></i></button>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div class="py-12 text-center text-secondary text-sm">
      <i class="fas fa-book-open text-2xl mb-3 opacity-40"></i>
      <p>No transactions yet.</p>
    </div>
    <% } %>
  </div>
</div>
<div id="imageModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm" onclick="closeImageModal()">
  <div class="relative max-w-4xl w-full" onclick="event.stopPropagation()">
    <button type="button" onclick="closeImageModal()" class="absolute -top-10 right-0 text-white"><i class="fas fa-times text-xl"></i></button>
    <img id="imageModalImg" src="" alt="Attachment" class="w-full max-h-[85vh] object-contain rounded-xl bg-white">
  </div>
</div>
<script>
  const clientId = <%- JSON.stringify(String(client._id)) %>;

  function notify(text, type) {
    if (typeof Noty !== 'undefined') new Noty({ theme: 'nest', text, type, layout: 'topCenter', timeout: 2000 }).show();
    else alert(text);
  }

  function imageSrc(path) {
    if (!path) return '';
    if (path.startsWith('http') || path.startsWith('/')) return path;
    const name = path.split(/[/\\]/).pop();
    return '/assets/uploads/khatabook/' + name;
  }

  function setTabActive(btn, on) {
    btn.classList.toggle('txn-tab-active', on);
    btn.classList.toggle('border-surface-container', on);
    btn.classList.toggle('border-b-0', on);
    btn.classList.toggle('bg-surface-container-lowest', on);
    btn.classList.toggle('text-on-surface', on);
    btn.classList.toggle('z-[1]', on);
    btn.classList.toggle('border-transparent', !on);
    btn.classList.toggle('text-secondary', !on);
  }

  function selectTab(mode) {
    const amountFields = document.getElementById('amountFields');
    const imageField = document.getElementById('imageField');
    const entryType = document.getElementById('entryType');
    const entryAmount = document.getElementById('entryAmount');
    const submitLabel = document.getElementById('submitLabel');
    const tabDebit = document.getElementById('tabDebit');
    const tabCredit = document.getElementById('tabCredit');
    const tabImage = document.getElementById('tabImage');
    setTabActive(tabDebit, mode === 'debit');
    setTabActive(tabCredit, mode === 'credit');
    setTabActive(tabImage, mode === 'image');
    if (mode === 'image') {
      amountFields.classList.add('hidden');
      imageField.classList.remove('hidden');
      entryAmount.removeAttribute('required');
      entryType.value = '';
      submitLabel.textContent = 'Upload Invoice';
    } else {
      amountFields.classList.remove('hidden');
      imageField.classList.add('hidden');
      entryAmount.setAttribute('required', 'required');
      entryType.value = mode;
      submitLabel.textContent = mode === 'debit' ? 'Add Debit Entry' : 'Add Credit Entry';
    }
  }

  document.getElementById('tabDebit').addEventListener('click', () => selectTab('debit'));
  document.getElementById('tabCredit').addEventListener('click', () => selectTab('credit'));
  document.getElementById('tabImage').addEventListener('click', () => selectTab('image'));

  document.getElementById('entryImage')?.addEventListener('change', function() {
    const img = document.getElementById('imagePreview');
    if (!this.files || !this.files[0]) {
      img.classList.add('hidden');
      img.removeAttribute('src');
      return;
    }
    img.src = URL.createObjectURL(this.files[0]);
    img.classList.remove('hidden');
  });

  document.getElementById('entryForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const mode = document.getElementById('entryType').value;
    if (mode === 'image' || document.getElementById('tabImage').classList.contains('txn-tab-active')) {
      fd.delete('type');
      fd.delete('amount');
      if (!fd.get('image') || !fd.get('image').name) {
        notify('Choose an invoice image to upload.', 'error');
        return;
      }
    } else {
      fd.delete('image');
    }
    try {
      const res = await fetch('/khataBook/add-entry', { method: 'POST', body: fd });
      const json = await res.json();
      if (!json.success) throw new Error(json.message);
      notify(json.message, 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message || 'Could not add entry', 'error');
    }
  });

  async function deleteEntry(id) {
    if (!confirm('Delete this transaction?')) return;
    try {
      const res = await fetch('/khataBook/delete-entry?id=' + encodeURIComponent(id), { method: 'POST' });
      const json = await res.json();
      if (!json.success) throw new Error(json.message);
      notify(json.message, 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message, 'error');
    }
  }

  async function settleClient() {
    if (!confirm('Settle and clear all entries for this client?')) return;
    try {
      const res = await fetch('/khataBook/settle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: clientId })
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.message);
      notify(json.message, 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message, 'error');
    }
  }

  function openImageModal(path) {
    document.getElementById('imageModalImg').src = imageSrc(path);
    document.getElementById('imageModal').classList.replace('hidden', 'flex');
  }

  function closeImageModal() {
    document.getElementById('imageModal').classList.replace('flex', 'hidden');
    document.getElementById('imageModalImg').removeAttribute('src');
  }
</script>
