<% activeNav = 'khata' %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const bookOptions = []; %>
<% const bookMap = {}; %>
<% (clients || []).forEach(function(c) { if (c.book && c.book._id && !bookMap[c.book._id]) { bookMap[c.book._id] = c.book.name; bookOptions.push({ id: c.book._id, name: c.book.name }); } }); %>
<div class="pb-10">
  <%- include('../partials/_table_page', {
    label,
    field,
    tableFilters: [
        { type: 'search', id: 'searchInput', label: 'Search Client', placeholder: 'Search...', span: 4, flexEnd: false },
        { type: 'select', id: 'sortByInput', label: 'Sort By', options: [{value: 'name', label: 'Name'}, {value: 'netBalance', label: 'Balance'}, {value: 'netWeight', label: 'Weight'}], span: 2, onChange: 'renderTable()' },
        { type: 'select', id: 'orderByInput', label: 'Order By', options: [{value: 'asc', label: 'Asc'}, {value: 'desc', label: 'Desc'}], span: 2, onChange: 'renderTable()' },
        // Hidden on mobile via standard CSS layout scripts inside optimizeMobileFilterLayout
        { type: 'stat', id: 'clientCount', label: 'Clients', span: 4, icon: 'fas fa-users' }
    ],
    tablePage: {
        tableTitle: 'Client Ledger Accounts',
        tableId: 'clientBody',
        minWidth: '100%', 
        colCount: 6,
        // Inserted a mobile-only text counter inside the actions panel wrapper
        headerActions: `
          <div class="flex items-center gap-3 w-full justify-between md:justify-end">
            <span class="md:hidden text-xs font-semibold text-secondary bg-surface-container-low px-3 py-2 rounded-lg">
              Total: <span id="mobileClientCount">0</span>
            </span>
            <button type="button" onclick="openAddModal()" title="Add Client" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-primary-container hover:brightness-105 text-on-primary text-sm font-semibold rounded-lg shadow-sm transition-all shrink-0">
              <i class="fas fa-user-plus text-xs"></i> Add Client
            </button>
          </div>
        `,
        columns: [
            { label: 'S.No', align: 'left', thClass: 'px-5 hidden md:table-cell' },
            { label: 'Client Name / Phone', align: 'left', thClass: 'px-4' },
            { label: 'Phone', align: 'left', thClass: 'px-4 hidden md:table-cell' },
            { label: 'Net Balance / Weight', align: 'left', thClass: 'px-4' },
            { label: 'Net Weight', align: 'left', thClass: 'px-4 hidden md:table-cell' },
            { label: 'Actions', align: 'right', thClass: 'px-5 hidden md:table-cell' }
        ]
    }
}) %>
</div>
<div id="addModal" class="fixed inset-0 z-50 hidden items-start justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-lg my-8">
    <div class="flex items-start justify-between px-6 py-4 border-b border-surface-container">
      <div>
        <h3 class="text-lg font-bold text-on-surface">Add Client</h3>
        <p class="text-[10px] font-semibold uppercase tracking-widest text-primary">Khata Party</p>
      </div>
      <button type="button" onclick="closeAddModal()" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form id="addClientForm" class="p-6 space-y-4">
      <div>
        <label class="<%= label %>">Book</label>
        <p id="addBookDisplay" class="px-4 py-3 bg-surface-container-low rounded-lg text-sm font-semibold text-on-surface">—</p>
        <input type="hidden" name="book" id="addBookHidden" value="">
      </div>
      <div><label class="<%= label %>">Client Name <span class="text-error">*</span></label><input type="text" name="name" required placeholder="Enter name..." class="<%= field %>"></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div><label class="<%= label %>">Phone <span class="text-error">*</span></label><input type="tel" name="phNum" required inputmode="numeric" maxlength="10" placeholder="10-digit mobile" class="<%= field %>"></div>
        <div><label class="<%= label %>">Address</label><input type="text" name="address" placeholder="Optional" class="<%= field %>"></div>
      </div>
      <div class="flex gap-3 pt-2 border-t border-surface-container">
        <button type="submit" class="flex-1 py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg">Add Client</button>
        <button type="button" onclick="closeAddModal()" class="px-5 py-3 bg-surface-container-low text-on-surface text-sm font-semibold rounded-lg">Cancel</button>
      </div>
    </form>
  </div>
</div>
<div id="editModal" class="fixed inset-0 z-50 hidden items-start justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-lg my-8">
    <div class="flex items-start justify-between px-6 py-4 border-b border-surface-container">
      <h3 class="text-lg font-bold text-on-surface">Edit Client</h3>
      <button type="button" onclick="closeEditModal()" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form id="editClientForm" class="p-6 space-y-4">
      <input type="hidden" name="id" id="editId">
      <div>
        <label class="<%= label %>">Book <span class="text-error">*</span></label>
        <select name="book" id="editBookSelect" required class="<%= field %> cursor-pointer"></select>
      </div>
      <div><label class="<%= label %>">Client Name</label><input type="text" name="name" id="editName" required class="<%= field %>"></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div><label class="<%= label %>">Phone</label><input type="tel" name="phNum" id="editPhone" required inputmode="numeric" maxlength="10" class="<%= field %>"></div>
        <div><label class="<%= label %>">Address</label><input type="text" name="address" id="editAddress" class="<%= field %>"></div>
      </div>
      <div class="flex gap-3 pt-2 border-t border-surface-container">
        <button type="submit" class="flex-1 py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg">Save</button>
        <button type="button" onclick="closeEditModal()" class="px-5 py-3 bg-surface-container-low text-on-surface text-sm font-semibold rounded-lg">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
  const allRows = <%- JSON.stringify((clients || []).map(c => ({
    id: c._id || c.id,
    name: c.name || '',
    phNum: c.phNum,
    address: c.address || '',
    bookId: c.book ? (c.book._id || c.book) : '',
    bookName: c.book ? c.book.name : '—',
    netBalance: c.netBalance || 0,
    netWeight: c.netWeight || 0,
    searchStr: ((c.name || '') + ' ' + (c.phNum || '') + ' ' + (c.address || '') + ' ' + (c.book ? c.book.name : '')).toLowerCase()
  }))) %>;
  const bookOptions = <%- JSON.stringify(bookOptions) %>;
  const urlBook = new URLSearchParams(window.location.search).get('book');
  const urlBookName = new URLSearchParams(window.location.search).get('bookName');

  function ensureActiveBookOption() {
    if (urlBook && !bookOptions.some(b => b.id === urlBook)) {
      bookOptions.push({
        id: urlBook,
        name: urlBookName || 'Selected Book'
      });
    }
  }

  function notify(text, type) {
    if (typeof Noty !== 'undefined') new Noty({
      theme: 'nest',
      text,
      type,
      layout: 'topCenter',
      timeout: 2000
    }).show();
    else alert(text);
  }
  async function postJson(url, data) {
    const res = await fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    });
    const json = await res.json();
    if (!json.success) throw new Error(json.message || 'Request failed');
    return json;
  }

  function fillBookSelects() {
    const opts = bookOptions.map(b => `<option value="${b.id}">${b.name}</option>`).join('');
    document.getElementById('editBookSelect').innerHTML = opts || '<option value="">No books</option>';
  }

  function currentBookName() {
    return urlBookName || bookOptions.find(b => b.id === urlBook)?.name || 'Selected Book';
  }

  function optimizeMobileFilterLayout() {
    const searchInput = document.getElementById('searchInput');
    if (!searchInput) return;
    const filterContainer = searchInput.closest('.grid') || searchInput.parentElement?.parentElement;
    if (filterContainer) {
      filterContainer.className = "grid grid-cols-2 md:grid-cols-12 gap-3 mb-6 items-end w-full";
      const items = filterContainer.children;
      if (items.length >= 4) {
        items[0].className = "col-span-2 md:col-span-4";
        items[1].className = "col-span-1 md:col-span-2";
        items[2].className = "col-span-1 md:col-span-2";
        items[3].className = "hidden md:block md:col-span-4";
      }
    }
  }

  function filteredRows() {
    const q = (document.getElementById('searchInput').value || '').toLowerCase().trim();
    const sortBy = document.getElementById('sortByInput').value || 'name';
    const orderBy = document.getElementById('orderByInput').value || 'asc';
    let rows = [...allRows];
    if (urlBook) {
      rows = rows.filter(r => r.bookId === urlBook);
    }
    if (q) {
      rows = rows.filter(r => r.searchStr.includes(q));
    }
    rows.sort((a, b) => {
      let valA = a[sortBy];
      let valB = b[sortBy];
      if (typeof valA === 'string') {
        valA = valA.toLowerCase();
        valB = valB.toLowerCase();
      }
      if (valA < valB) return orderBy === 'asc' ? -1 : 1;
      if (valA > valB) return orderBy === 'asc' ? 1 : -1;
      return 0;
    });
    return rows;
  }
  const pager = new KbPagination({
    onPageChange: renderTable,
    formatSummary(page, rows) {
      return rows.length ? `Showing ${page.length} of ${rows.length} client${rows.length > 1 ? 's' : ''}` : 'No clients';
    }
  });

  function renderTable() {
    const rows = filteredRows();
    const {
      page,
      start
    } = pager.apply(rows);
    const tbody = document.getElementById('clientBody');
    const tableEl = tbody.closest('table');
    if (tableEl) {
      tableEl.classList.add('w-full', 'block', 'md:table');
      const thead = tableEl.querySelector('thead');
      if (thead) thead.classList.add('hidden', 'md:table-header-group');
    }
    tbody.classList.add('block', 'w-full', 'md:table-row-group');
    if (!page.length) {
      tbody.innerHTML = '<div class="block md:table-row py-12 text-center text-secondary">No clients in this book yet.</div>';
    } else {
      tbody.innerHTML = page.map((r, i) => {
        const balanceColorClass = r.netBalance > 0 ? 'text-emerald-600 font-bold' : r.netBalance < 0 ? 'text-rose-600 font-bold' : 'text-secondary font-medium';
        const weightColorClass = r.netWeight > 0 ? 'text-emerald-600 font-bold' : r.netWeight < 0 ? 'text-rose-600 font-bold' : 'text-secondary font-medium';
        const cleanBalance = Math.abs(r.netBalance).toLocaleString('en-IN');
        const cleanWeight = Math.abs(r.netWeight).toLocaleString('en-IN');
        return `
        <tr class="border-t border-surface-container hover:bg-surface-container-low/40 transition-colors flex flex-row justify-between items-center md:table-row w-full px-4 py-3 md:p-0">
          <td class="py-4 px-5 text-secondary font-medium hidden md:table-cell">${start + i + 1}</td>
          
          <td class="py-0 md:py-4 px-0 md:px-4 block md:table-cell">
            <div class="flex flex-col">
              <a href="/khataBook/entries?id=${r.id}" class="font-semibold text-primary hover:text-primary/80 text-base md:text-sm">${r.name}</a>
              <span class="text-xs text-secondary md:hidden mt-0.5 font-medium">${r.phNum}</span>
            </div>
          </td>
          
          <td class="py-4 px-4 font-semibold text-primary hidden md:table-cell">${r.phNum}</td>
          
          <td class="py-0 md:py-4 px-0 md:px-4 block md:table-cell text-right md:text-left">
            <div class="flex flex-col items-end md:items-start">
              <span class="${balanceColorClass} text-base md:text-sm">${cleanBalance}</span>
              <span class="${weightColorClass} text-xs md:hidden mt-0.5">${cleanWeight} g</span>
            </div>
          </td>
          
          <td class="py-4 px-4 ${weightColorClass} hidden md:table-cell">${cleanWeight} g</td>
          
          <td class="py-4 px-5 text-right whitespace-nowrap hidden md:table-cell">
            <a href="/khataBook/entries?id=${r.id}" class="p-2 text-secondary hover:text-primary inline-block" title="Open ledger"><i class="fas fa-book-open"></i></a>
            <button type="button" onclick="openEditModal('${r.id}')" class="p-2 text-secondary hover:text-primary inline-block" title="Edit"><i class="fas fa-pen"></i></button>
            <button type="button" onclick="deleteClient('${r.id}')" class="p-2 text-secondary hover:text-error inline-block" title="Delete"><i class="fas fa-trash"></i></button>
          </td>
        </tr>`;
      }).join('');
    }
    const formattedCount = rows.length.toLocaleString('en-IN');
    const pcCounter = document.getElementById('clientCount');
    const mobileCounter = document.getElementById('mobileClientCount');
    if (pcCounter) pcCounter.textContent = formattedCount;
    if (mobileCounter) mobileCounter.textContent = formattedCount;
  }

  function openAddModal() {
    if (!urlBook) {
      notify('Open a khata book first.', 'error');
      return;
    }
    document.getElementById('addBookHidden').value = urlBook;
    document.getElementById('addBookDisplay').textContent = currentBookName();
    document.getElementById('addModal').classList.replace('hidden', 'flex');
  }

  function closeAddModal() {
    document.getElementById('addModal').classList.replace('flex', 'hidden');
  }

  function openEditModal(id) {
    const row = allRows.find(r => r.id === id);
    if (!row) return;
    document.getElementById('editId').value = row.id;
    document.getElementById('editName').value = row.name;
    document.getElementById('editPhone').value = row.phNum;
    document.getElementById('editAddress').value = row.address;
    document.getElementById('editBookSelect').value = row.bookId;
    document.getElementById('editModal').classList.replace('hidden', 'flex');
  }

  function closeEditModal() {
    document.getElementById('editModal').classList.replace('flex', 'hidden');
  }
  async function deleteClient(id) {
    const row = allRows.find(r => r.id === id);
    if (!row) return;
    const confirmed = await KbConfirm.ask({
      title: 'Delete Client',
      message: 'This will permanently remove the client from your registry.',
      detail: row.name,
      confirmLabel: 'Delete Client'
    });
    if (!confirmed) return;
    try {
      const res = await fetch('/khataBook/delete-client?id=' + encodeURIComponent(id), {
        method: 'POST'
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.message);
      notify(json.message, 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message, 'error');
    }
  }
  document.getElementById('addClientForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    try {
      await postJson('/khataBook/add-client', {
        book: fd.get('book'),
        name: fd.get('name'),
        phNum: fd.get('phNum'),
        address: fd.get('address')
      });
      notify('Client added!', 'success');
      window.location.href = '/khataBook/clients?book=' + encodeURIComponent(urlBook) + (currentBookName() ? '&bookName=' + encodeURIComponent(currentBookName()) : '');
    } catch (err) {
      notify(err.message, 'error');
    }
  });
  document.getElementById('editClientForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    try {
      await postJson('/khataBook/edit-client', {
        id: fd.get('id'),
        book: fd.get('book'),
        name: fd.get('name'),
        phNum: fd.get('phNum'),
        address: fd.get('address')
      });
      notify('Client updated!', 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message, 'error');
    }
  });
  document.addEventListener('DOMContentLoaded', () => {
    ensureActiveBookOption();
    fillBookSelects();
    optimizeMobileFilterLayout();
    document.getElementById('searchInput').addEventListener('input', renderTable);
    renderTable();
    if (new URLSearchParams(window.location.search).get('openAdd') === '1') openAddModal();
  });
</script>