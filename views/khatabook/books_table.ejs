<% activeNav = 'khata' %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<div class="pb-10">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
    <div>
      <p class="<%= label %> text-primary mb-1">Multi-Company Ledger</p>
      <h2 class="text-xl sm:text-2xl font-bold text-on-surface">Your Khata Books</h2>
      <p class="text-sm text-secondary mt-1 max-w-xl">Open a separate book for each company or shop. Parties and transactions stay inside that book only.</p>
    </div>
    <button type="button" onclick="openAddModal()" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-primary-container hover:brightness-105 text-on-primary text-sm font-semibold rounded-lg shadow-sm transition-all shrink-0">
      <i class="fas fa-plus text-xs"></i> New Book
    </button>
  </div>
  <div id="booksGrid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 mb-6"></div>
  <div id="booksEmpty" class="hidden bg-surface-container-lowest rounded-xl border border-dashed border-outline-variant/50 p-10 text-center">
    <i class="fas fa-book text-3xl text-secondary/40 mb-3"></i>
    <p class="text-sm font-semibold text-on-surface mb-1">No books yet</p>
    <p class="text-xs text-secondary mb-4">Create your first book for a company, then add clients inside it.</p>
    <button type="button" onclick="openAddModal()" class="inline-flex items-center gap-2 px-4 py-2.5 bg-primary text-on-primary text-sm font-semibold rounded-lg">Create Book</button>
  </div>
</div>
<div id="addModal" class="fixed inset-0 z-50 hidden items-start justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-md my-8">
    <div class="flex items-start justify-between px-6 py-4 border-b border-surface-container">
      <div>
        <h3 class="text-lg font-bold text-on-surface">New Khata Book</h3>
        <p class="text-[10px] font-semibold uppercase tracking-widest text-primary">Company / Shop Account</p>
      </div>
      <button type="button" onclick="closeAddModal()" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form id="addBookForm" class="p-6 space-y-4">
      <div>
        <label class="<%= label %>">Book Name <span class="text-error">*</span></label>
        <input type="text" name="name" required placeholder="e.g. KaratBox Retail, Second Company..." class="<%= field %>">
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg">Create Book</button>
        <button type="button" onclick="closeAddModal()" class="px-5 py-3 bg-surface-container-low text-on-surface text-sm font-semibold rounded-lg">Cancel</button>
      </div>
    </form>
  </div>
</div>
<div id="editModal" class="fixed inset-0 z-50 hidden items-start justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-md my-8">
    <div class="flex items-start justify-between px-6 py-4 border-b border-surface-container">
      <h3 class="text-lg font-bold text-on-surface">Rename Book</h3>
      <button type="button" onclick="closeEditModal()" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form id="editBookForm" class="p-6 space-y-4">
      <input type="hidden" name="id" id="editId">
      <div>
        <label class="<%= label %>">Book Name <span class="text-error">*</span></label>
        <input type="text" name="name" id="editName" required class="<%= field %>">
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg">Save</button>
        <button type="button" onclick="closeEditModal()" class="px-5 py-3 bg-surface-container-low text-on-surface text-sm font-semibold rounded-lg">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
  const allBooks = <%- JSON.stringify((books || []).map(b => ({
    id: b._id,
    name: b.name,
    createdAt: b.createdAt
  }))) %>;

  function fmtDate(iso) {
    const d = new Date(iso);
    return d.toLocaleDateString('en-IN', {
      day: 'numeric',
      month: 'short',
      year: 'numeric'
    });
  }

  function initials(name) {
    return (name || 'B').trim().charAt(0).toUpperCase();
  }

  function notify(text, type) {
    if (typeof Noty !== 'undefined') {
      new Noty({
        theme: 'nest',
        text,
        type,
        layout: 'topCenter',
        timeout: 2000
      }).show();
    } else {
      alert(text);
    }
  }

  async function postJson(url, data) {
    const res = await fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    });
    const json = await res.json();
    if (!json.success) throw new Error(json.message || 'Request failed');
    return json;
  }

  function renderBooks() {
    const grid = document.getElementById('booksGrid');
    const empty = document.getElementById('booksEmpty');
    if (!allBooks.length) {
      grid.innerHTML = '';
      empty.classList.remove('hidden');
      return;
    }
    empty.classList.add('hidden');
    grid.innerHTML = allBooks.map((b, i) => `
      <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-5 flex flex-col gap-4 hover:border-primary-container/40 transition-colors">
        <div class="flex items-start gap-4">
          <span class="w-12 h-12 rounded-xl ${i % 2 ? 'bg-primary-fixed/50 text-primary' : 'bg-surface-container text-on-surface'} text-lg font-bold flex items-center justify-center shrink-0">${initials(b.name)}</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-base font-bold text-on-surface truncate">${b.name}</h3>
            <p class="text-xs text-secondary mt-0.5">Created ${fmtDate(b.createdAt)}</p>
          </div>
        </div>
        <a href="/khataBook/clients?book=${b.id}&bookName=${encodeURIComponent(b.name)}" class="w-full text-center py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all">
          <i class="fas fa-book-open text-xs mr-1.5"></i>Open Book
        </a>
        <div class="flex items-center justify-end gap-1 border-t border-surface-container pt-3">
          <button type="button" onclick="openEditModal('${b.id}')" class="p-2 text-secondary hover:text-primary rounded-lg" title="Rename"><i class="fas fa-pen"></i></button>
          <button type="button" onclick="deleteBook('${b.id}')" class="p-2 text-secondary hover:text-error rounded-lg" title="Delete book"><i class="fas fa-trash"></i></button>
        </div>
      </div>`).join('');
  }

  function openAddModal() {
    document.getElementById('addModal').classList.replace('hidden', 'flex');
    document.getElementById('addBookForm').reset();
  }

  function closeAddModal() {
    document.getElementById('addModal').classList.replace('flex', 'hidden');
  }

  function openEditModal(id) {
    const book = allBooks.find(b => b.id === id);
    if (!book) return;
    document.getElementById('editId').value = book.id;
    document.getElementById('editName').value = book.name;
    document.getElementById('editModal').classList.replace('hidden', 'flex');
  }

  function closeEditModal() {
    document.getElementById('editModal').classList.replace('flex', 'hidden');
  }

  async function deleteBook(id) {
    const book = allBooks.find(b => b.id === id);
    if (!book || !confirm(`Delete book "${book.name}"? Only empty books can be removed.`)) return;
    try {
      const res = await fetch('/khataBook/delete-book?id=' + encodeURIComponent(id), {
        method: 'POST'
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.message);
      notify(json.message, 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message || 'Could not delete book', 'error');
    }
  }

  document.getElementById('addBookForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    try {
      await postJson('/khataBook/add-book', {
        name: fd.get('name')
      });
      notify('Book created successfully!', 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message, 'error');
    }
  });

  document.getElementById('editBookForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    try {
      await postJson('/khataBook/edit-book', {
        id: fd.get('id'),
        name: fd.get('name')
      });
      notify('Book updated successfully!', 'success');
      window.location.reload();
    } catch (err) {
      notify(err.message, 'error');
    }
  });

  document.addEventListener('DOMContentLoaded', renderBooks);
</script>