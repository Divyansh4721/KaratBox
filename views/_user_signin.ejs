<!DOCTYPE html>
<html lang="en">

<head>
    <title>KaratBox — Authenticate</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="/assets/favicon.ico" type="image/x-icon" />
    <script src="https://kit.fontawesome.com/9f9e58ef8b.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/noty/3.1.4/noty.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/noty/3.1.4/noty.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <%- include('_tailwind') %>
</head>

<body
    class="bg-brand-blush dark:bg-dark-surface text-on-surface dark:text-dark-text font-sans antialiased flex min-h-screen items-center justify-center p-4 sm:p-6 transition-colors duration-300">

    <!-- Gallery-esque Centralized Login Card -->
    <div
        class="w-full max-w-md bg-brand-light dark:bg-dark-container rounded-lg shadow-whisper p-8 lg:p-10 border border-brand-almond/40 dark:border-white/5 transition-all duration-300">

        <!-- Header / Identity Area -->
        <div class="text-center mb-8">
            <h1 class="text-[32px] font-bold text-brand-accent tracking-tight leading-none mb-2">KaratBox</h1>
            <p class="text-[12px] font-medium text-secondary tracking-wider uppercase">Luxury Management Workspace</p>
        </div>

        <div class="space-y-6">
            <!-- Informational Intro Text -->
            <div class="text-center">
                <h2 class="text-[18px] font-semibold text-on-surface dark:text-dark-text mb-1">Verify Your Identity</h2>
                <p class="text-[14px] text-secondary font-light">Access is restricted to authorized collectors and
                    administrators.</p>
            </div>

            <!-- Divider Line with Text Accent -->
            <div class="relative flex py-2 items-center">
                <div class="flex-grow border-t border-brand-almond dark:border-white/10"></div>
                <span class="flex-shrink mx-4 text-[11px] uppercase tracking-widest text-on-surface-variant/50">Secure
                    Portal</span>
                <div class="flex-grow border-t border-brand-almond dark:border-white/10"></div>
            </div>

            <!-- Provided Authentication Form -->
            <form action="/users/auth/google" method="GET">
                <button type="submit"
                    class="w-full flex items-center justify-center gap-3 px-4 py-3.5 bg-brand-accent hover:bg-brand-accent/90 text-white dark:text-on-surface font-semibold text-[14px] uppercase tracking-wider rounded-DEFAULT shadow-sm active:scale-[0.99] transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-brand-accent/40">
                    <!-- Google White Icon (Vector Clean) -->
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                            fill="#ffffff" />
                        <path
                            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            fill="#ffffff" />
                        <path
                            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z"
                            fill="#ffffff" />
                        <path
                            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z"
                            fill="#ffffff" />
                    </svg>
                    <span>Continue with Google</span>
                </button>
            </form>

            <!-- Institutional Guard Notice -->
            <div class="mt-8 pt-6 border-t border-brand-almond dark:border-white/5 text-center">
                <p class="text-[12px] text-secondary font-light">
                    By accessing this terminal, you agree to the institution's terms of privacy and strict encryption
                    storage protocols.
                </p>
                <div
                    class="mt-4 flex justify-center gap-4 text-[11px] uppercase tracking-wider font-semibold text-brand-accent">
                    <a href="#" class="hover:underline">Helpdesk</a>
                    <span class="text-brand-almond">•</span>
                    <a href="#" class="hover:underline">Legal</a>
                </div>
            </div>
        </div>

    </div>

</body>
<script>
    '<% if (flash.success && flash.success.length > 0) { %>'
    new Noty({
        theme: 'nest',
        text: '<%= flash.success %>',
        type: 'success',
        layout: 'topCenter',
        timeout: 1500
    }).show();
    '<% } %>'
    '<% if (flash.error && flash.error.length > 0) { %>'
    new Noty({
        theme: 'nest',
        text: '<%= flash.error %>',
        type: 'error',
        layout: 'topCenter',
        timeout: 1500
    }).show();
    '<% } %>'
</script>

</html>