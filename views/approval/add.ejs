<% activeNav = 'inventory' %>
<%- include('../partials/_tokens') %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low dark:bg-dark-container border border-outline-variant/40 dark:border-white/10 rounded-lg text-sm text-on-surface dark:text-dark-text placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const select = field + " appearance-none cursor-pointer"; %>
<% const btn = "inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all"; %>
<% const fmt = n => new Intl.NumberFormat('en-IN').format(Math.round((n || 0) * 1)); %>
<% const pageSubtitle = stockTable.length + ' item' + (stockTable.length !== 1 ? 's' : '') + ' for customer approval'; %>
<div class="pb-10 space-y-6">
  <% const backLink = typeof backHref !== 'undefined' ? backHref : '/cart'; %>
  <% const subtitle = typeof pageSubtitle !== 'undefined' ? pageSubtitle : ''; %>
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <h2 class="text-display-lg-mobile md:text-headline-xl font-bold text-on-surface dark:text-dark-text tracking-tight mb-1"><%= title %></h2>
      <% if (subtitle) { %><p class="text-sm text-secondary"><%= subtitle %></p><% } %>
    </div>
  </div>
  <form action="/approvalForm" method="post" class="space-y-6">
    <div class="<%= formCard %>">
      <h3 class="text-sm font-bold text-on-surface dark:text-dark-text mb-5">Approval Details</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="space-y-2">
          <label class="<%= label %>">Search Customer</label>
          <input type="text" id="customerinput" placeholder="Search by name, phone, or address..." autocomplete="off" class="<%= field %>">
          <label class="<%= label %>">Customer <span class="text-error">*</span></label>
          <select id="customeroptions" name="customer" class="<%= select %>" required>
            <option value="">Select customer...</option>
            <% for (let i of customerTable) { %>
            <option value="<%= i._id %>"><%= i.name %><% if (i.phNum && i.phNum.length) { %> — <%= i.phNum.join(', ') %><% } %></option>
            <% } %>
          </select>
        </div>
        <script>
          (function() {
            const customers = <%- JSON.stringify(customerTable.map(function(c) { return { _id: c._id, searchStr: c.searchStr }; })) %>;
            const input = document.getElementById('customerinput');
            const select = document.getElementById('customeroptions');
            if (!input || !select) return;
            const defaultLabel = 'Select customer...';

            function fillOptions(list) {
              select.innerHTML = '<option value="">' + defaultLabel + '</option>';
              list.forEach(function(c) {
                const opt = document.createElement('option');
                opt.value = c._id;
                opt.textContent = c.searchStr;
                select.appendChild(opt);
              });
            }
            fillOptions(customers);
            input.addEventListener('input', function() {
              const q = input.value.toLowerCase().trim();
              if (!q) {
                fillOptions(customers);
                return;
              }
              const matches = customers.filter(function(c) {
                return c.searchStr.toLowerCase().includes(q);
              });
              select.innerHTML = '<option value="">' + (matches.length ? defaultLabel : 'No customer found') + '</option>';
              matches.forEach(function(c) {
                const opt = document.createElement('option');
                opt.value = c._id;
                opt.textContent = c.searchStr;
                select.appendChild(opt);
              });
            });
          })();
        </script>
        <div class="space-y-2">
          <label class="<%= label %>">Total Cash</label>
          <input type="number" name="totalCash" value="<%= totalCash %>" readonly class="<%= field %> opacity-80">
        </div>
        <div class="md:col-span-2 space-y-2">
          <label class="<%= label %>">Remark</label>
          <input type="text" id="remark" name="remark" placeholder="Add a remark..." autocomplete="off" class="<%= field %>">
        </div>
        <div class="md:col-span-2 rounded-lg bg-primary-fixed/20 border border-primary-container/30 px-5 py-4 flex items-center justify-between gap-4">
          <span class="text-[10px] font-semibold uppercase tracking-widest text-secondary">Approval Value</span>
          <span class="text-xl font-bold text-primary">₹<%= fmt(totalCash) %> /-</span>
        </div>
      </div>
      <div class="mt-6 pt-5 border-t border-surface-container dark:border-white/10">
        <button type="submit" class="<%= btn %>">
          <i class="fas fa-shield-halved text-xs"></i> Submit Approval
        </button>
      </div>
    </div>
    <%- include('../partials/_stock_detail_table', { stockTable, title: 'Cart Items' }) %>
  </form>
</div>