<% activeNav = 'approval' %>
<% const isPending = !approval.receivedDate; %>
<% const fmt = n => new Intl.NumberFormat('en-IN').format(n); %>
<% const convertDate = (date) => {
    if (!date) return '—';
    const b = new Date(date);
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const time = String(b.getHours()).padStart(2, '0') + ':' + String(b.getMinutes()).padStart(2, '0');
    return b.getDate() + ' ' + months[b.getMonth()] + ' ' + b.getFullYear() + ' at ' + time;
}; %>
<% const tagLabel = s => (s.prefix ? s.prefix.name : '') + (s.tag ? '-' + s.tag : ''); %>
<% const initials = (approval.customer.name || 'C').trim().charAt(0).toUpperCase(); %>
<% const txnId = 'TXN-' + String(approval._id).slice(-6).toUpperCase(); %>
<div class="pb-10">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">
    <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6">
      <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary mb-4">Customer Details</p>
      <div class="flex items-start gap-4 mb-4">
        <span class="w-14 h-14 rounded-full bg-primary-fixed/50 text-primary text-xl font-bold flex items-center justify-center shrink-0"><%= initials %></span>
        <div>
          <h3 class="text-lg font-bold text-on-surface"><%= approval.customer.name %></h3>
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="text-[10px] font-semibold uppercase tracking-wider bg-surface-container text-secondary px-2.5 py-1 rounded-full">Approver: <%= approval.userGave.name %></span>
          </div>
        </div>
      </div>
      <div class="pt-4 border-t border-surface-container">
        <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1">Estimate</p>
        <p class="text-2xl font-bold text-on-surface">₹ <%= fmt(approval.totalCash) %> <span class="text-sm font-normal text-secondary">/-</span></p>
        <p class="text-sm text-secondary italic mt-3"><%= approval.remark ? approval.remark : 'No remarks provided' %></p>
      </div>
      <a href="/customer?id=<%= approval.customer._id %>" class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold text-primary hover:underline">
        <i class="fas fa-arrow-up-right-from-square text-xs"></i> View Customer Profile
      </a>
    </div>
    <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6">
      <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary mb-4">Transaction Summary</p>
      <div class="space-y-5">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1">Given By</p>
          <p class="font-bold text-on-surface"><%= approval.userGave.name %></p>
          <p class="text-sm text-secondary"><%= convertDate(approval.approvedDate) %></p>
        </div>
        <% if (approval.receivedDate) { %>
        <div class="pt-4 border-t border-surface-container">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1">Taken By</p>
          <p class="font-bold text-on-surface"><%= approval.userTake.name %></p>
          <p class="text-sm text-secondary"><%= convertDate(approval.receivedDate) %></p>
        </div>
        <% } else { %>
        <div class="pt-4 border-t border-surface-container">
          <p class="text-sm text-secondary italic">Awaiting return & credit confirmation</p>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <form id="approvalForm" action="/approvalRecvForm" method="post">
    <input type="hidden" name="approval" value="<%= approval._id %>">
    <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden mb-6">
      <div class="flex items-center justify-between px-5 py-4 border-b border-surface-container">
        <h3 class="text-sm font-bold text-on-surface">Items for Approval</h3>
        <span class="text-xs font-semibold bg-primary-fixed/40 text-primary px-3 py-1 rounded-full"><%= stockTable.length %> Item<%= stockTable.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[900px]">
          <thead>
            <tr class="bg-surface-container-low text-[10px] font-semibold uppercase tracking-widest text-secondary">
              <th class="py-3 px-4 text-left">S. No</th>
              <th class="py-3 px-3 text-left">Photo</th>
              <th class="py-3 px-3 text-left">SKU</th>
              <th class="py-3 px-3 text-left">Tag No</th>
              <th class="py-3 px-3 text-left">Purity</th>
              <th class="py-3 px-3 text-left">Gross Wt</th>
              <th class="py-3 px-3 text-left">Net Wt</th>
              <th class="py-3 px-3 text-left">Stone Wt (gms)</th>
              <th class="py-3 px-3 text-left">Stone Wt (ct)</th>
              <th class="py-3 px-3 text-left">Stock Type</th>
              <th class="py-3 px-4 text-center">Cart</th>
              <th class="py-3 px-4 text-center">Link</th>
            </tr>
          </thead>
          <tbody id="approvalItemsBody"></tbody>
        </table>
      </div>
      <%- include('../partials/_pagination_footer', { summaryId: 'approvalItemsSummary', paginationId: 'approvalItemsPagination', perPageSelectId: 'approvalItemsPerPage' }) %>
    </div>
    <% if (isPending) { %>
    <div class="rounded-xl bg-primary text-on-primary p-6 mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h3 class="text-lg font-bold mb-1">Final Settlement</h3>
        <p class="text-sm text-on-primary/85 max-w-lg">Verify all item statuses to finalize the credit reconciliation for <%= approval.customer.name %>.</p>
        <p class="text-xs text-on-primary/70 mt-2 font-mono">Transaction ID: <%= txnId %></p>
      </div>
      <button type="submit" onclick="return confirm('Confirm return and credit for this approval?')" class="shrink-0 px-6 py-3 bg-surface-container-lowest text-on-surface text-sm font-bold rounded-lg hover:brightness-105 shadow-sm transition-all">
        Confirm Return &amp; Credit
      </button>
    </div>
    <% } %>
    <div class="flex flex-wrap items-center justify-end gap-3">
      <button type="button" onclick="printTable('printTable',0)" class="px-5 py-2.5 border-2 border-primary-container text-primary text-sm font-semibold rounded-lg hover:bg-primary-fixed/20 transition-colors">
        Print Memo
      </button>
      <% if (isPending) { %>
      <button type="submit" onclick="return confirm('Submit this approval?')" class="px-6 py-2.5 bg-primary-container hover:brightness-105 text-on-primary text-sm font-semibold rounded-lg shadow-sm transition-all">
        Submit Approval
      </button>
      <% } %>
    </div>
  </form>
  <div id="cartToast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden px-5 py-3 rounded-lg shadow-lg text-sm font-medium text-on-primary bg-primary"></div>
</div>
<%- include('../layoutStockTable', { stockTable }) %>
<%- include('../reports/_print_script') %>
<script>
  const approvalItems = <%- JSON.stringify(stockTable) %>.map((s) => ({
    id: s._id,
    image: s.stockImage && s.stockImage.length ? s.stockImage[0].fileName : '',
    sku: s.index,
    tag: (s.prefix ? s.prefix.name : '') + (s.tag ? '-' + s.tag : ''),
    purity: s.purity ? s.purity.name : '—',
    grossWt: s.grossWt || 0,
    netWt: s.netWt || 0,
    stoneWt: s.stoneWt || 0,
    stockType: s.stockType ? s.stockType.name : '—'
  }));
  const itemsPager = new KbPagination({
    perPage: 10,
    paginationId: 'approvalItemsPagination',
    summaryId: 'approvalItemsSummary',
    perPageSelectId: 'approvalItemsPerPage',
    onPageChange: renderApprovalItems,
    formatSummary(page, rows, start) {
      if (!rows.length) return 'No items';
      const end = start + page.length;
      return `Showing ${start + 1}-${end} of ${rows.length} item${rows.length > 1 ? 's' : ''}`;
    }
  });

  function renderApprovalItems() {
    const {
      page,
      start
    } = itemsPager.apply(approvalItems);
    const tbody = document.getElementById('approvalItemsBody');
    if (!page.length) {
      tbody.innerHTML = '<tr><td colspan="12" class="py-10 text-center text-secondary">No items found.</td></tr>';
      return;
    }
    tbody.innerHTML = page.map((s, i) => `
            <tr class="border-t border-surface-container hover:bg-surface-container-low/30">
                <td class="py-3 px-4 text-secondary">${start + i + 1}</td>
                <td class="py-3 px-3">
                    ${s.image
                        ? `<img src="/uploads/stock/${s.image}" alt="" class="w-12 h-12 rounded-lg object-cover border border-surface-container">`
                        : '<span class="w-12 h-12 rounded-lg bg-surface-container flex items-center justify-center text-secondary/40"><i class="fas fa-image"></i></span>'}
                </td>
                <td class="py-3 px-3 font-medium text-on-surface">${s.sku}</td>
                <td class="py-3 px-3 text-primary font-semibold">${s.tag}</td>
                <td class="py-3 px-3 text-secondary">${s.purity}</td>
                <td class="py-3 px-3 text-secondary">${s.grossWt.toFixed(3)}g</td>
                <td class="py-3 px-3 text-secondary">${s.netWt.toFixed(3)}g</td>
                <td class="py-3 px-3 text-secondary">${s.stoneWt.toFixed(3)}g</td>
                <td class="py-3 px-3 text-secondary">${(s.stoneWt * 5).toFixed(3)}ct</td>
                <td class="py-3 px-3 text-secondary">${s.stockType}</td>
                <td class="py-3 px-4 text-center">
                    <button type="button" onclick="AddToCart('${s.id}')" class="p-2 text-primary hover:bg-primary-fixed/25 rounded-lg transition-colors"><i class="fas fa-cart-plus"></i></button>
                </td>
                <td class="py-3 px-4 text-center">
                    <a href="${window.kbRoutes.stockView(s.id)}" class="p-2 text-secondary hover:text-primary inline-block"><i class="fas fa-arrow-up-right-from-square"></i></a>
                </td>
            </tr>`).join('');
  }
  let printArrHeader = [];
  printArrHeader.push('Approval - <%= approval.customer.name %>');
  printArrHeader.push('<%= convertDate(approval.approvedDate) %>');
  <% if (approval.receivedDate) { %>printArrHeader.push('<%= convertDate(approval.receivedDate) %>');
  <% } %>

  function showToast(msg, err) {
    const t = document.getElementById('cartToast');
    t.textContent = msg;
    t.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-lg shadow-lg text-sm font-medium text-on-primary ' + (err ? 'bg-error' : 'bg-primary');
    t.classList.remove('hidden');
    setTimeout(() => t.classList.add('hidden'), 2000);
  }

  function AddToCart(id) {
    fetch('/addToCart?index=' + id, {
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      .then(r => r.json())
      .then(d => showToast(d.message, d.status !== 'success'))
      .catch(() => showToast('Could not add to cart', true));
  }
  document.addEventListener('DOMContentLoaded', renderApprovalItems);
</script>