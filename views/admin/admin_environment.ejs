<% activeNav = 'settings' %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-brand-almond border border-transparent rounded-md text-body-md text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors disabled:opacity-70 disabled:cursor-not-allowed"; %>
<% const fieldPw = "w-full pl-4 pr-11 py-3 bg-brand-almond border border-transparent rounded-md text-body-md text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors disabled:opacity-70 disabled:cursor-not-allowed"; %>
<% const days = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]; %>
<% const displayLabels = {
    AppName: "App Name",
    TagName: "Tag Name",
    goldPrice: "Gold Price (USD/OZ)",
    XDaysToDelete: "Days Before Delete",
    startHour: "Start Hour",
    endHour: "End Hour",
    mailUser: "Mail ID (Internal)",
    mailPassword: "Mail Password",
    mailFrom: "Mail From",
    backUpMail: "Mail To",
    google_clientID: "Google ClientID",
    google_clientSecret: "Google ClientSecret",
    google_callbackURL: "Google CallbackURL"
}; %>
<% const fullWidthFields = ["google_clientID", "google_clientSecret", "google_callbackURL"]; %>
<div class="w-full pb-10">
  <form id="environmentForm" action="/admin/settings/update" method="post">
    <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6 sm:p-8">
      <div class="mb-10">
        <h2 class="text-xl font-bold text-on-surface mb-1">General Settings</h2>
        <p class="text-sm text-secondary mb-6">Manage core application identifiers and communication protocols.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% variables.forEach(function(v) { %>
          <% if (!fullWidthFields.includes(v.name)) { %>
          <div>
            <label class="<%= label %>" for="<%= v.name %>"><%= displayLabels[v.name] || v.nickname %></label>
            <% if (v.disabled) { %>
            <input type="hidden" name="<%= v.name %>" value="<%= v.value %>">
            <% } %>
            <% if (v.name === "mailPassword") { %>
            <div class="relative">
              <input type="password" id="<%= v.name %>" name="<%= v.name %>" value="<%= v.value %>" <%= v.disabled ? "disabled" : "" %> class="<%= fieldPw %>" autocomplete="off">
              <button type="button" onclick="togglePassword('<%= v.name %>', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-secondary hover:text-primary p-1" aria-label="Toggle password visibility">
                <i class="fas fa-eye text-sm"></i>
              </button>
            </div>
            <% } else if (v.name === "goldPrice") { %>
            <input type="number" step="0.01" id="<%= v.name %>" name="<%= v.name %>" value="<%= v.value %>" <%= v.disabled ? "disabled" : "" %> class="<%= field %>">
            <% } else { %>
            <input type="text" id="<%= v.name %>" name="<%= v.name %>" value="<%= v.value %>" <%= v.disabled ? "disabled" : "" %> class="<%= field %>">
            <% } %>
          </div>
          <% } %>
          <% }); %>
        </div>
        <div class="mt-5 space-y-5">
          <% variables.forEach(function(v) { %>
          <% if (fullWidthFields.includes(v.name)) { %>
          <div>
            <label class="<%= label %>" for="<%= v.name %>"><%= displayLabels[v.name] || v.nickname %></label>
            <% if (v.disabled) { %>
            <input type="hidden" name="<%= v.name %>" value="<%= v.value %>">
            <% } %>
            <% if (v.name === "google_clientSecret") { %>
            <div class="relative">
              <input type="password" id="<%= v.name %>" name="<%= v.name %>" value="<%= v.value %>" <%= v.disabled ? "disabled" : "" %> class="<%= fieldPw %>" autocomplete="off">
              <button type="button" onclick="togglePassword('<%= v.name %>', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-secondary hover:text-primary p-1" aria-label="Toggle password visibility">
                <i class="fas fa-eye text-sm"></i>
              </button>
            </div>
            <% } else { %>
            <input type="text" id="<%= v.name %>" name="<%= v.name %>" value="<%= v.value %>" <%= v.disabled ? "disabled" : "" %> class="<%= field %>">
            <% } %>
          </div>
          <% } %>
          <% }); %>
        </div>
      </div>
      <div class="mb-8">
        <h2 class="text-xl font-bold text-on-surface mb-1">Operating Schedule</h2>
        <p class="text-sm text-secondary mb-4">Define days of active system monitoring and availability.</p>
        <div class="rounded-lg overflow-hidden border border-surface-container">
          <div class="grid grid-cols-2 bg-brand-almond px-5 py-3 text-[10px] font-semibold uppercase tracking-widest">
            <span class="text-on-surface">Days</span>
            <span class="text-right text-primary">Status</span>
          </div>
          <% days.forEach(function(day, i) { %>
          <div class="grid grid-cols-2 items-center px-5 py-3.5 border-t border-surface-container bg-surface-container-lowest">
            <span class="text-sm text-on-surface"><%= day %></span>
            <div class="flex justify-end">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="hidden" name="daysAllowed" value="<%= daysAllowed[i] ? 'on' : 'off' %>" id="day-<%= i %>">
                <input type="checkbox" class="sr-only peer" <%= daysAllowed[i] ? "checked" : "" %> onchange="document.getElementById('day-<%= i %>').value = this.checked ? 'on' : 'off'">
                <div class="w-11 h-6 bg-secondary/30 rounded-full peer peer-checked:bg-primary transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-5"></div>
              </label>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <div class="flex justify-end">
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:brightness-110 text-on-primary text-xs font-bold uppercase tracking-wider rounded-lg transition-all">
          <i class="fas fa-save text-sm"></i>
          Submit Configuration
        </button>
      </div>
    </div>
  </form>
</div>
<%- include('_ajax_helpers') %>
<script>
  function togglePassword(id, btn) {
    const input = document.getElementById(id);
    if (!input) return;
    const icon = btn.querySelector('i');
    const hidden = input.type === 'password';
    input.type = hidden ? 'text' : 'password';
    icon.classList.toggle('fa-eye', !hidden);
    icon.classList.toggle('fa-eye-slash', hidden);
  }

  document.getElementById('environmentForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const json = await postForm('/admin/settings/update', e.target);
      notify(json.message || 'Settings updated successfully!', 'success');
    } catch (err) {
      notify(err.message, 'error');
    }
  });
</script>