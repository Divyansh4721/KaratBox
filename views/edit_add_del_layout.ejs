<link rel="stylesheet" href="<%= assetPath('css/home.css') %>">
<div id="home-container">
    <br>
    <form action="/add<%= name %>" method="post">
        <input type="text" name="name" placeholder="Enter <%= name %> Name ...." required>
        <br>
        <button type="submit">Add <%= name %></button>
    </form>
    <br>
    <br>
    <br>
    <form action="/edit<%= name %>" method="post">
        <select name="oldname" required>
            <option value="">Select <%= name %></option>
            <% for(let i of options){ %>
            <option value="<%= i.id %>"><%= i.name %></option>
            <% } %>
        </select>
        <br>
        <input type="text" name="newname" placeholder="Enter <%= name %> Name ...." required>
        <br>
        <button type="submit" onclick="return (alert(event))">Edit <%= name %></button>
    </form>
    <br>
    <br>
    <br>
    <form action="/del<%= name %>" method="post">
        <select name="name" required>
            <option value="">Select <%= name %></option>
            <% for(let i of options){ %>
            <option value="<%= i.id %>"><%= i.name %></option>
            <% } %>
        </select>
        <br>
        <button type="submit" onclick="return (alert(event) && alert(event) && alert(event))">
            Delete <%= name %>
        </button>
    </form>
    <br>
    <br>
</div>