<script src="https://cdn.tailwindcss.com"></script>
<div class="bg-gray-900 text-gray-200 antialiased">
    <div id="buttonList"
        class="flex flex-col sm:flex-row justify-center items-center gap-4 p-4 bg-gray-800/70 backdrop-blur-sm sticky top-0 z-20 border-b border-gray-700">
        <button onclick="printTable('printTable', 0)"
            class="w-full sm:w-auto px-6 py-2.5 bg-indigo-600 text-white font-semibold rounded-lg shadow-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-opacity-75 transition duration-300">
            <i class="fa-solid fa-print mr-2"></i> Print List
        </button>
        <select id="sortOrder" onchange="LoadTable(); SlideShow();"
            class="w-full sm:w-auto px-4 py-2.5 bg-gray-700 text-gray-200 border border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 appearance-none">
            <option value="stockType1" selected>Sort by Stock Type</option>
            <option value="tag">Sort by Tag Number</option>
            <option value="grossWt">Sort by Gross Weight</option>
            <option value="netWt">Sort by Net Weight</option>
            <option value="sellingPrice">Sort by Price</option>
        </select>
        <div class="flex items-center gap-3 bg-gray-700 px-4 py-2.5 rounded-lg border border-gray-600">
            <label for="checkbox" class="font-medium cursor-pointer">In Stock Only</label>
            <input id="checkbox" type="checkbox" onchange="LoadTable(); SlideShow();" checked
                class="h-5 w-5 rounded bg-gray-600 border-gray-500 text-indigo-600 focus:ring-indigo-500 cursor-pointer">
        </div>
    </div>
    <div id="printTable" class="hidden"></div>
    <main id="home-container" class="p-4 sm:p-6 lg:p-8">
        <div id="stockTable"
            class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-6 w-full max-w-screen-2xl mx-auto">
        </div>
    </main>
</div>
<script>
    let stockTable = JSON.parse((`<%= JSON.stringify(stockTable,null,2) %>`).replaceAll('&#34;', '"'));
</script>
<script src="<%= assetPath('js/categoryView.js') %>"></script>
<script src="<%= assetPath('js/printTable.js') %>"></script>