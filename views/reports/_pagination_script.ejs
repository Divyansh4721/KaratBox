<%- include('../partials/_pagination_lib') %>
<script>
  function paginateDomTable(opts) {
    const tbody = document.getElementById(opts.bodyId);
    if (!tbody) return null;

    function getRows() {
      return Array.from(tbody.querySelectorAll('tr')).filter(function(tr) {
        return !tr.classList.contains('pager-skip');
      });
    }
    const pager = new KbPagination({
      perPage: opts.perPage || 10,
      paginationId: opts.paginationId,
      summaryId: opts.summaryId,
      perPageSelectId: opts.perPageSelectId,
      onPageChange: render,
      formatSummary: function(page, rows) {
        return rows.length ?
          'Showing ' + page.length + ' of ' + rows.length + ' rows' :
          'No rows';
      }
    });

    function render() {
      const allRows = getRows();
      allRows.forEach(function(tr) {
        tr.classList.add('hidden');
      });
      const result = pager.apply(allRows);
      result.page.forEach(function(tr) {
        tr.classList.remove('hidden');
      });
      tbody.querySelectorAll('tr.pager-skip').forEach(function(tr) {
        tr.classList.remove('hidden');
      });
    }
    render();
    pager.refresh = render;
    return pager;
  }
</script>