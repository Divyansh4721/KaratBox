<% const chips = typeof checkList !== 'undefined' ? checkList : []; %>
<% const filterId = typeof filterContainerId !== 'undefined' ? filterContainerId : 'categoryFilter'; %>
<div class="<%= sectionCard %> p-5 mb-6">
  <div class="flex items-center gap-2 mb-4">
    <i class="fas fa-filter text-primary text-sm"></i>
    <h3 class="text-sm font-bold text-on-surface dark:text-dark-text">Filter by Category</h3>
  </div>
  <div id="<%= filterId %>" class="flex flex-wrap gap-2">
    <% chips.forEach(function(name, i) { %>
    <label class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-outline-variant/40 dark:border-white/10 bg-surface-container-low/60 dark:bg-dark-container/60 cursor-pointer hover:border-primary-container/60 transition-colors has-[:checked]:border-primary-container has-[:checked]:bg-primary-fixed/25">
      <input type="checkbox" id="checkbox<%= i %>" value="<%= name %>" <%= typeof defaultChecked === 'undefined' || defaultChecked ? 'checked' : '' %> class="rounded border-outline-variant text-primary focus:ring-primary-container category-filter-cb">
      <span class="text-xs font-medium text-on-surface dark:text-dark-text whitespace-nowrap"><%= name %></span>
    </label>
    <% }); %>
  </div>
</div>