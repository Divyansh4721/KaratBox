<% activeNav = 'reports' %>
<%- include('../partials/_tokens') %>
<% const yesterday = new Date(new Date().getTime() + 19800000 - 86400000).toISOString().substring(0, 10); %>
<% const today = new Date(new Date().getTime() + 19800000).toISOString().substring(0, 10); %>
<div class="space-y-5 w-full pb-10">
  <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:gap-5">
    <a href="/dailySheet" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-calendar-day"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">Daily Sheet</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">View today's stock arrivals, edits, sales, and approvals.</p>
    </a>
    <a href="/allStock" class="<%= masterCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-boxes-stacked"></i></span>
      <h3 class="text-sm sm:text-base font-bold text-on-surface mb-1 sm:mb-1.5 group-hover:text-primary transition-colors">View Stock</h3>
      <p class="hidden sm:block text-sm text-secondary font-light leading-relaxed">Complete inventory report across all stock items.</p>
    </a>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 sm:gap-4 lg:gap-5">
    <div class="<%= formCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-clock-rotate-left"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1">Back Date Lists</h3>
      <p class="text-sm text-secondary font-light leading-relaxed mb-6">Load historical daily update lists for a past date.</p>
      <form action="/backDateSheet" method="post" class="mt-auto space-y-4">
        <div>
          <label class="<%= label %>">Select Date</label>
          <input type="date" name="date" value="<%= yesterday %>" max="<%= yesterday %>" class="<%= field %>" required>
        </div>
        <button type="submit" class="<%= btnPrimary %>">View Back Date Lists</button>
      </form>
    </div>
    <div class="<%= formCard %>">
      <span class="<%= iconWrap %>"><i class="fas fa-list-check"></i></span>
      <h3 class="text-base font-bold text-on-surface dark:text-dark-text mb-1">Custom Lists</h3>
      <p class="text-sm text-secondary font-light leading-relaxed mb-6">Generate a custom stock change list for any date up to today.</p>
      <form action="/customSheetPage" method="post" class="mt-auto space-y-4">
        <div>
          <label class="<%= label %>">Select Date</label>
          <input type="date" name="date" value="<%= today %>" max="<%= today %>" class="<%= field %>" required>
        </div>
        <button type="submit" class="<%= btnPrimary %>">View Custom Lists</button>
      </form>
    </div>
  </div>
</div>