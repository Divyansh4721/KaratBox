<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-2">
  <div class="min-w-0">
    <% if (typeof date !== 'undefined' && date) { %>
    <h2 class="text-lg font-bold text-on-surface dark:text-dark-text truncate"><%= pageTitle %></h2>
    <h2 class="text-display-lg-mobile md:text-headline-xl font-bold text-primary tracking-tight truncate PageDate"><%= date %></h2>
    <% } else { %>
    <h2 class="text-lg font-bold text-on-surface dark:text-dark-text truncate"><%= pageTitle %></h2>
    <% } %>
  </div>
  <% if (typeof actions !== 'undefined' && actions && actions.length) { %>
  <div class="flex flex-wrap items-center gap-2 sm:shrink-0">
    <% actions.forEach(function(action) { %>
    <button type="button" onclick="<%= action.onclick %>" class="<%= btnOutline %>">
      <% if (action.icon) { %><i class="fas <%= action.icon %> text-xs"></i><% } %>
      <%= action.label %>
    </button>
    <% }); %>
  </div>
  <% } %>
</div>