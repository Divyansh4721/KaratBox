<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rough Estimate / Quotation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <style>
    body {
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    @media print {
      body {
        background: #ffffff !important;
        color: #000000 !important;
        padding: 0 !important;
        margin: 0 !important;
      }

      .no-print {
        display: none !important;
      }

      #maindata {
        width: 100% !important;
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
        border: none !important;
      }

      .table-container {
        overflow: visible !important;
        width: 100% !important;
      }

      table {
        width: 100% !important;
      }
    }

    @page {
      size: A4 portrait;
      margin: 10mm;
    }
  </style>
</head>

<body class="bg-stone-50 text-black p-4 md:p-8 flex flex-col items-center">
  <div class="no-print w-full max-w-4xl bg-white border border-stone-300 rounded-lg p-4 mb-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div>
      <h1 class="text-xs font-bold uppercase tracking-wider text-stone-800">Estimate Print Control</h1>
      <p class="text-[12px] text-stone-500">Pure black and white rendering engine preview dashboard.</p>
    </div>
    <div class="flex items-center gap-2 w-full sm:w-auto">
      <button onclick="window.close()" class="flex-1 sm:flex-none px-3 py-1.5 text-xs font-medium text-stone-700 bg-white border border-stone-300 rounded hover:bg-stone-100 transition">
        Cancel
      </button>
      <button onclick="window.print()" class="flex-1 sm:flex-none px-3 py-1.5 text-xs font-semibold text-white bg-black rounded hover:bg-stone-900 transition shadow-sm">
        Print Document
      </button>
      <button id="downloadBtn" onclick="generateMonochromePDF()" class="flex-1 sm:flex-none px-3 py-1.5 text-xs font-semibold text-white bg-stone-800 rounded hover:bg-stone-700 transition shadow-sm">
        Save PDF
      </button>
    </div>
  </div>
  <div id="loadingIndicator" class="hidden no-print fixed inset-0 bg-black/20 backdrop-blur-xs z-50 flex items-center justify-center">
    <div class="bg-white p-4 rounded border border-stone-400 shadow-lg flex items-center gap-3">
      <div class="animate-spin rounded-full h-4 w-4 border-2 border-black border-t-transparent"></div>
      <p class="text-xs font-bold uppercase tracking-wide">Compiling PDF Data Grid...</p>
    </div>
  </div>
  <% 
    let activeGoldPrice = parseFloat(goldrate) || 0;
    
    
    let sumWstg = 0;
    let sumGross = 0;
    let sumNet = 0;
    let sumStone = 0;
    let sumChgWt = 0;
    let sumAmt = 0;
  %>
  <div id="maindata" class="w-full max-w-4xl bg-white border border-stone-300 rounded-sm p-6 print:p-0 print:border-none">
    <div class="invoice-header border-b border-black pb-4 mb-5 flex flex-col sm:flex-row print:flex-row sm:items-end print:items-end sm:justify-between print:justify-between gap-2">
      <div>
        <div class="date text-[12px] font-mono tracking-tight text-stone-600 uppercase" id="livePrintTime"></div>
        <h2 class="title text-lg font-bold tracking-tight uppercase text-black mt-0.5">Rough Estimate / Quotation</h2>
        <div class="note text-[10px] text-stone-600 italic mt-1">GST 3% Applicable on Bill / Goods are not Delivered</div>
      </div>
      <div class="text-left sm:print:font-mono text-xs">
        <p class="text-black">Base Gold Rate: ₹<%= new Intl.NumberFormat('en-IN').format(activeGoldPrice) %>/10g</p>
      </div>
    </div>
    <div class="table-container w-full overflow-x-auto print:overflow-visible">
      <div class="inline-block min-w-full align-middle">
        <table id="table" class="min-w-full text-left text-xs leading-tight border border-black border-collapse table-auto text-center">
          <thead>
            <tr class="bold backgroundDark border-b border-black bg-stone-100 text-black font-bold uppercase tracking-wide text-[10px] whitespace-nowrap">
              <th class="py-2.5 px-1 border-r border-black">S. No</th>
              <th class="py-2.5 px-1 border-r border-black">SKU</th>
              <th class="py-2.5 px-2 border-r border-black text-left">Ornament</th>
              <th class="py-2.5 px-1.5 border-r border-black">Stone<br>Wt (ct)</th>
              <th class="py-2.5 px-1.5 border-r border-black">Carat</th>
              <th class="py-2.5 px-1.5 border-r border-black">Gross<br>Wt (g)</th>
              <th class="py-2.5 px-1.5 border-r border-black">Net<br>Wt (g)</th>
              <th class="py-2.5 px-1.5 border-r border-black">Wastage<br>(g)</th>
              <th class="py-2.5 px-1.5 border-r border-black">Charged<br>Wt (g)</th>
              <th class="py-2.5 px-1.5 border-r border-black">Gold<br>Rate</th>
              <th class="py-2.5 px-1 border-r border-black">KDM<br>Rate</th>
              <th class="py-2.5 px-1.5 border-r border-black">Rate</th>
              <th class="py-2.5 px-2 border-r border-black">Amount</th>
              <th class="py-2.5 px-3 min-w-[70px]">Remark</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-black font-normal text-black text-[12px]">
            <% if (billdata.length === 0) { %>
            <tr>
              <td colspan="14" class="py-6 text-stone-500 italic font-mono text-xs">
                No active rows present inside the transaction dataset stack.
              </td>
            </tr>
            <% } else { %>
            <% billdata.forEach((item, index) => { %>
            <tr id="<%= item.type %>" class="break-inside-avoid">
              <td class="py-2 px-1 border-r border-black font-mono whitespace-nowrap"><%= index + 1 %></td>
              <% if (item.type === "type1") { %>
              <% 
                    let chunks = (item.purity || "").split("$");
                    let caratString = chunks[0] || "";
                    let wholesaleMult = parseFloat(chunks[1]) || 100;
                    let retailMult = parseFloat(chunks[2]) || 100;
                    let wtPct = parseFloat(item.wastage) || 0;
                    
                    let standardRate = (activeGoldPrice * retailMult) / 100;
                    let finalRate = item.isKDM ? (standardRate * 1.10) : standardRate;
                    let kdmRate = item.isKDM ? (standardRate / 10) : 0;
                    
                    let nWt = parseFloat(item.netweight) || 0;
                    let gWt = parseFloat(item.grossweight) || 0;
                    let calculatedWstg = (nWt * wtPct) / 100;
                    let chargedWt = nWt + calculatedWstg;
                    let finalRowAmount = chargedWt * finalRate;
                    
                    
                    sumWstg += calculatedWstg;
                    sumGross += gWt;
                    sumNet += nWt;
                    sumChgWt += chargedWt;
                    sumAmt += finalRowAmount;
                  %>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= item.index || '-' %></td>
              <td class="py-2 px-2 border-r border-black font-medium text-[12px] leading-tight whitespace-nowrap">
                <%= item.prefix || "" %> <%= item.ornament || "" %><%= item.tag? " - " + item.tag : "" %>
              </td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1 border-r border-black whitespace-nowrap"><%= caratString %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= gWt.toFixed(3) %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= nWt.toFixed(3) %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= calculatedWstg.toFixed(3) %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= chargedWt.toFixed(3) %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= Math.round(standardRate) %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= Math.round(kdmRate) %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= Math.round(finalRate) %></td>
              <td class="py-2 px-2 border-r border-black font-mono font-bold whitespace-nowrap"><%= new Intl.NumberFormat('en-IN').format(Math.round(finalRowAmount)) %></td>
              <td class="py-2 px-2 border-black"></td>
              <% } else { %>
              <%
                let sWt = parseFloat(item.stoneweight) || 0;
                let sRate = parseFloat(item.stonerate) || 0;
                let multiplierFactor = sWt ? sWt : 1;
                let finalRowAmount = multiplierFactor * sRate;
                sumStone += sWt;
                sumAmt += finalRowAmount;
                %>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-2 border-r border-black italic text-black text-[12px] leading-tight whitespace-nowrap"><%= item.stonetype || "Stone" %></td>
              <td class="py-2 px-1.5 border-r border-black font-mono whitespace-nowrap"><%= sWt.toFixed(3) %></td>
              <td class="py-2 px-1 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black">-</td>
              <td class="py-2 px-1.5 border-r border-black font-mono text-black whitespace-nowrap"><%= Math.round(sRate) %></td>
              <td class="py-2 px-2 border-r border-black font-mono font-bold whitespace-nowrap"><%= new Intl.NumberFormat('en-IN').format(Math.round(finalRowAmount)) %></td>
              <td class="py-2 px-2 border-black"></td>
              <% } %>
            </tr>
            <% }) %>
            <% } %>
            <tr class="bold backgroundDark border-t border-black bg-stone-100 font-bold text-black text-[12px] whitespace-nowrap">
              <td colspan="3" class="py-2.5 px-2 border-r border-black text-left uppercase tracking-wider">Total</td>
              <td class="py-2.5 px-1.5 border-r border-black font-mono"><%= sumStone.toFixed(3) %></td>
              <td class="py-2.5 px-0.5 border-r border-black"></td>
              <td class="py-2.5 px-1.5 border-r border-black font-mono"><%= sumGross.toFixed(3) %></td>
              <td class="py-2.5 px-1.5 border-r border-black font-mono"><%= sumNet.toFixed(3) %></td>
              <td class="py-2.5 px-1.5 border-r border-black font-mono"><%= sumWstg.toFixed(3) %></td>
              <td class="py-2.5 px-1.5 border-r border-black font-mono"><%= sumChgWt.toFixed(3) %></td>
              <td colspan="3" class="border-r border-black"></td>
              <td class="py-2.5 px-2 border-r border-black font-mono text-black"><%= new Intl.NumberFormat('en-IN').format(Math.round(sumAmt)) %></td>
              <td class="py-2.5 px-2 border-black"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
    <div class="mt-4 flex justify-end w-full">
      <div class="w-72 print:w-72 border border-black p-3 space-y-1 font-mono text-xs text-black bg-white">
        <div class="flex justify-between">
          <span>Sub-Total Amt:</span>
          <span>₹<%= new Intl.NumberFormat('en-IN').format(Math.round(sumAmt)) %></span>
        </div>
        <div class="flex justify-between pb-1 border-b border-black">
          <span>GST (3%):</span>
          <span>₹<%= new Intl.NumberFormat('en-IN').format(Math.round(sumAmt * 0.03)) %></span>
        </div>
        <div class="flex justify-between font-sans font-black text-sm uppercase pt-1 tracking-tight">
          <span>Total Estimate:</span>
          <span class="font-mono text-base">₹<%= new Intl.NumberFormat('en-IN').format(Math.round(sumAmt * 1.03)) %></span>
        </div>
      </div>
    </div>
  </div>
  <script>
    function getFormattedTimeString() {
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      const now = new Date();
      const dayName = days[now.getDay()];
      const dayNum = now.getDate();
      const monthStr = months[now.getMonth()];
      const yearNum = now.getFullYear();
      const hoursStr = now.getHours().toString().padStart(2, '0');
      const minutesStr = now.getMinutes().toString().padStart(2, '0');
      return `${dayName} ${dayNum}-${monthStr}-${yearNum} at ${hoursStr}:${minutesStr}`;
    }
    document.getElementById('livePrintTime').innerText = getFormattedTimeString();

    function generateMonochromePDF() {
      const targetOverlay = document.getElementById('loadingIndicator');
      const actionButton = document.getElementById('downloadBtn');
      targetOverlay.classList.remove('hidden');
      actionButton.disabled = true;
      const captureNode = document.getElementById('maindata');
      html2canvas(captureNode, {
        scale: 2.5,
        useCORS: true,
        logging: false,
        allowTaint: true
      }).then(canvas => {
        const {
          jsPDF
        } = window.jspdf;
        const pdf = new jsPDF({
          orientation: 'portrait',
          unit: 'mm',
          format: 'a4',
          compress: true
        });
        const pdfW = 210;
        const targetMargin = 10;
        const contentW = pdfW - (targetMargin * 2);
        const imgH = contentW / (canvas.width / canvas.height);
        pdf.addImage(
          canvas.toDataURL('image/jpeg', 0.98),
          'JPEG',
          targetMargin,
          10,
          contentW,
          imgH
        );
        const dateStamp = new Date().toISOString().slice(0, 10);
        pdf.save(`Rough_Estimate_${dateStamp}.pdf`);
        targetOverlay.classList.add('hidden');
        actionButton.disabled = false;
      }).catch(err => {
        console.error('PDF Thread Failure Exception Context Log:', err);
        alert('Exception encountered during dynamic canvas output transformation.');
        targetOverlay.classList.add('hidden');
        actionButton.disabled = false;
      });
    }
  </script>
</body>

</html>