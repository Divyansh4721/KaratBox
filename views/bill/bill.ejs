<% activeNav = 'bills' %>
<% const fmt = n => new Intl.NumberFormat('en-IN').format(Math.round(n * 1 || 0)); %>
<% const fmtWt = n => (n * 1 || 0).toFixed(3); %>
<% const purityLabel = s => s.purity ? s.purity.name + ' | ' + s.purity.wholesaleMultiplier : '—'; %>
<% const isWholesale = bill.totalCash != null || (bill.stoneTable && bill.stoneTable.length); %>
<% const totalCash = isWholesale ? (bill.totalCash || 0) : (bill.amount || 0); %>
<% const goldRate = bill.goldRate || 0; %>
<%
let fineWt = bill.totalWt || 0;
let sumNetWt = 0, sumStoneGm = 0, sumStoneCt = 0;
for (let i = 0; i < stockTable.length; i++) {
    sumNetWt += stockTable[i].netWt * 1;
    if (stockTable[i].stoneTable) {
        for (let j = 0; j < stockTable[i].stoneTable.length; j++) {
            sumStoneGm += stockTable[i].stoneTable[j].gmWeight * 1;
            sumStoneCt += stockTable[i].stoneTable[j].ctWeight * 1;
        }
    }
}
if (!fineWt && isWholesale) {
    for (let i = 0; bill.stoneTable && i < bill.stoneTable.length; i++) {
        fineWt += (bill.stoneTable[i].tounch || 0) * 1;
    }
}
const row = "flex items-center justify-between gap-4 px-5 py-3.5 border-b border-surface-container last:border-0";
const label = "text-[10px] font-semibold uppercase tracking-widest text-secondary";
const val = "text-sm font-semibold text-on-surface text-right";
%>
<div class="pb-10">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6">
    <div>
      <h2 class="text-display-lg-mobile md:text-headline-xl font-bold text-on-surface tracking-tight mb-1">Bill Details</h2>
      <p class="text-sm text-secondary">Invoice for <%= bill.customer ? bill.customer.name : 'Walk-in Customer' %>.</p>
    </div>
    <% if (bill.customer) { %>
    <a href="/customer?id=<%= bill.customer.id %>" class="inline-flex items-center gap-2 px-4 py-2.5 border border-surface-container text-secondary text-sm font-semibold rounded-lg hover:bg-surface-container-low transition-colors shrink-0">
      <i class="fas fa-user text-xs"></i> View Customer
    </a>
    <% } %>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-surface-container bg-surface-container-low/50">
      <h3 class="text-sm font-bold text-on-surface">Bill Summary</h3>
    </div>
    <div>
      <div class="<%= row %>">
        <span class="<%= label %>">Customer</span>
        <span class="<%= val %>"><%= bill.customer ? bill.customer.name : '—' %></span>
      </div>
      <% if (isWholesale) { %>
      <div class="<%= row %>">
        <span class="<%= label %>">Fine Wt</span>
        <span class="<%= val %>"><%= fmtWt(fineWt) %> gm</span>
      </div>
      <div class="<%= row %>">
        <span class="<%= label %>">Total Cash - Gold</span>
        <span class="<%= val %>">&#8377; <%= fmt(totalCash) %> /-</span>
      </div>
      <div class="<%= row %>">
        <span class="<%= label %>">Gold Rate</span>
        <span class="<%= val %>">&#8377; <%= fmt(goldRate) %> /-</span>
      </div>
      <% } %>
      <div class="<%= row %>">
        <span class="<%= label %>">Total Cash</span>
        <span class="<%= val %> text-primary">&#8377; <%= fmt(totalCash) %> /-</span>
      </div>
      <div class="<%= row %>">
        <span class="<%= label %>">Billed By</span>
        <span class="<%= val %>"><%= bill.user ? bill.user.name : '—' %></span>
      </div>
      <div class="<%= row %>">
        <span class="<%= label %>">Bill Date</span>
        <span class="<%= val %>"><%= convertDate(bill.createdAt) %></span>
      </div>
    </div>
  </div>
  <div class="flex flex-wrap items-center justify-center gap-3 mb-6">
    <% if (isWholesale) { %>
    <a href="/estimateWholesale/<%= bill.id %>" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all">
      <i class="fas fa-calculator text-xs"></i> Estimate
    </a>
    <% } %>
    <button type="button" onclick="printTable('printTable')" class="inline-flex items-center gap-2 px-6 py-2.5 border-2 border-primary-container text-primary text-sm font-semibold rounded-lg hover:bg-primary-fixed/20 transition-colors">
      <i class="fas fa-print text-xs"></i> Print Table
    </button>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-surface-container">
      <h3 class="text-sm font-bold text-on-surface">Itemized Details</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[900px]">
        <thead>
          <tr class="bg-primary text-on-primary text-[10px] font-semibold uppercase tracking-widest">
            <th class="py-3 px-4 text-left">S. No</th>
            <th class="py-3 px-3 text-left">Tag No</th>
            <th class="py-3 px-3 text-left">Purity</th>
            <th class="py-3 px-3 text-left">Net Wt</th>
            <th class="py-3 px-3 text-left">Total Fine Wt</th>
            <th class="py-3 px-3 text-left">Wastage</th>
            <th class="py-3 px-3 text-left">Labour</th>
            <th class="py-3 px-4 text-right">Total</th>
          </tr>
        </thead>
        <tbody>
          <% if (isWholesale && bill.stoneTable && bill.stoneTable.length) { %>
          <% for (let i = 0; i < stockTable.length; i++) { const s = stockTable[i]; const bRow = bill.stoneTable[i] || {}; %>
          <tr class="border-t border-surface-container bg-surface-container-low/30">
            <td class="py-3 px-4 font-semibold text-on-surface"><%= i + 1 %></td>
            <td class="py-3 px-3 font-semibold text-on-surface"><%= generateTagName(s) %></td>
            <td class="py-3 px-3 text-secondary"><%= purityLabel(s) %></td>
            <td class="py-3 px-3 text-secondary"><%= fmtWt(s.netWt) %> gm</td>
            <td class="py-3 px-3 text-secondary"><%= fmtWt(bRow.tounch || 0) %> gm</td>
            <td class="py-3 px-3 text-secondary"><%= s.purity ? s.purity.wastage : '—' %></td>
            <td class="py-3 px-3 text-secondary"><%= fmt(bRow.labour || 0) %></td>
            <td class="py-3 px-4 text-right font-semibold text-on-surface">&#8377; <%= fmt((bRow.rate && bRow.rate[0]) || 0) %> /-</td>
          </tr>
          <% for (let j = 0; s.stoneTable && j < s.stoneTable.length; j++) { const st = s.stoneTable[j]; const stoneTotal = (bRow.rate && bRow.rate[j + 1]) || Math.round((st.ctWeight || 0) * (st.sellRate || 0)); %>
          <tr class="border-t border-surface-container/60">
            <td class="py-2.5 px-4"></td>
            <td class="py-2.5 px-3 text-secondary pl-6"><%= st.type ? st.type.name : '—' %></td>
            <td class="py-2.5 px-3"></td>
            <td class="py-2.5 px-3 text-secondary"><%= fmtWt(st.gmWeight) %> gm</td>
            <td class="py-2.5 px-3"></td>
            <td class="py-2.5 px-3 text-secondary"><%= fmtWt(st.ctWeight) %> ct</td>
            <td class="py-2.5 px-3 text-secondary"><%= fmt(st.sellRate || 0) %></td>
            <td class="py-2.5 px-4 text-right font-medium text-on-surface">&#8377; <%= fmt(stoneTotal) %> /-</td>
          </tr>
          <% } %>
          <% } %>
          <tr class="border-t-2 border-primary-container/40 bg-surface-container-low font-bold text-on-surface">
            <td class="py-3 px-4" colspan="2"></td>
            <td class="py-3 px-3"><%= fmtWt(sumStoneGm) %> gm</td>
            <td class="py-3 px-3"><%= fmtWt(sumNetWt) %> gm</td>
            <td class="py-3 px-3"><%= fmtWt(fineWt) %> gm</td>
            <td class="py-3 px-3"><%= fmtWt(sumStoneCt) %> ct</td>
            <td class="py-3 px-3"></td>
            <td class="py-3 px-4 text-right text-primary">&#8377; <%= fmt(totalCash) %> /-</td>
          </tr>
          <% } else { %>
          <% for (let i = 0; i < stockTable.length; i++) { const s = stockTable[i]; %>
          <tr class="border-t border-surface-container hover:bg-surface-container-low/30">
            <td class="py-3 px-4 font-medium text-secondary"><%= i + 1 %></td>
            <td class="py-3 px-3 font-semibold text-on-surface"><%= generateTagName(s) %><% if (s.tag) { %> <span class="text-secondary font-normal">#<%= s.tag %></span><% } %></td>
            <td class="py-3 px-3 text-secondary"><%= s.purity ? s.purity.name : '—' %></td>
            <td class="py-3 px-3 text-secondary"><%= fmtWt(s.netWt) %> gm</td>
            <td class="py-3 px-3 text-secondary">—</td>
            <td class="py-3 px-3 text-secondary"><%= s.purity ? s.purity.wastage : '—' %></td>
            <td class="py-3 px-3 text-secondary">—</td>
            <td class="py-3 px-4 text-right font-semibold text-on-surface"><%= s.sellingPrice ? '&#8377; ' + fmt(s.sellingPrice) + ' /-' : '—' %></td>
          </tr>
          <% } %>
          <% if (stockTable.length) { %>
          <tr class="border-t-2 border-primary-container/40 bg-surface-container-low font-bold text-on-surface">
            <td class="py-3 px-4 text-right" colspan="7">Total</td>
            <td class="py-3 px-4 text-right text-primary">&#8377; <%= fmt(totalCash) %> /-</td>
          </tr>
          <% } %>
          <% } %>
          <% if (!stockTable.length) { %>
          <tr>
            <td colspan="8" class="py-10 text-center text-secondary">No items in this bill.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<div id="printTable" class="hidden">
  <table>
    <thead>
      <tr>
        <th>S. No</th>
        <th>Tag No</th>
        <th>Purity</th>
        <th>Net Wt</th>
        <th>Total Fine Wt</th>
        <th>Wastage</th>
        <th>Labour</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% if (isWholesale && bill.stoneTable && bill.stoneTable.length) { %>
      <% for (let i = 0; i < stockTable.length; i++) { const s = stockTable[i]; const bRow = bill.stoneTable[i] || {}; %>
      <tr>
        <td><%= i + 1 %></td>
        <td><%= generateTagName(s) %></td>
        <td><%= purityLabel(s) %></td>
        <td><%= fmtWt(s.netWt) %> gm</td>
        <td><%= fmtWt(bRow.tounch || 0) %> gm</td>
        <td><%= s.purity ? s.purity.wastage : '' %></td>
        <td><%= fmt(bRow.labour || 0) %></td>
        <td>&#8377; <%= fmt((bRow.rate && bRow.rate[0]) || 0) %> /-</td>
      </tr>
      <% for (let j = 0; s.stoneTable && j < s.stoneTable.length; j++) { const st = s.stoneTable[j]; const stoneTotal = (bRow.rate && bRow.rate[j + 1]) || Math.round((st.ctWeight || 0) * (st.sellRate || 0)); %>
      <tr>
        <td></td>
        <td><%= st.type ? st.type.name : '' %></td>
        <td></td>
        <td><%= fmtWt(st.gmWeight) %> gm</td>
        <td></td>
        <td><%= fmtWt(st.ctWeight) %> ct</td>
        <td><%= fmt(st.sellRate || 0) %></td>
        <td>&#8377; <%= fmt(stoneTotal) %> /-</td>
      </tr>
      <% } %>
      <% } %>
      <tr>
        <td colspan="2"></td>
        <td><%= fmtWt(sumStoneGm) %> gm</td>
        <td><%= fmtWt(sumNetWt) %> gm</td>
        <td><%= fmtWt(fineWt) %> gm</td>
        <td><%= fmtWt(sumStoneCt) %> ct</td>
        <td></td>
        <td>&#8377; <%= fmt(totalCash) %> /-</td>
      </tr>
      <% } else { %>
      <% for (let i = 0; i < stockTable.length; i++) { const s = stockTable[i]; %>
      <tr>
        <td><%= i + 1 %></td>
        <td><%= generateTagName(s) %></td>
        <td><%= s.purity ? s.purity.name : '' %></td>
        <td><%= fmtWt(s.netWt) %> gm</td>
        <td></td>
        <td><%= s.purity ? s.purity.wastage : '' %></td>
        <td></td>
        <td><%= s.sellingPrice ? '&#8377; ' + fmt(s.sellingPrice) + ' /-' : '' %></td>
      </tr>
      <% } %>
      <% } %>
    </tbody>
  </table>
</div>
<%- include('../reports/_print_script') %>
<script>
  let printArrHeader = [];
  printArrHeader.push('Customer: <%= bill.customer ? bill.customer.name.replace(/'/g, "\\'") : "Walk-in" %>');
  <% if (isWholesale) { %>
  printArrHeader.push('Fine Wt: <%= fmtWt(fineWt) %> gm');
  printArrHeader.push('Total Cash: &#8377; <%= fmt(totalCash) %> /-');
  <% } else { %>
  printArrHeader.push('Total Cash: &#8377; <%= fmt(totalCash) %> /-');
  <% } %>
  printArrHeader.push('Billed By: <%= bill.user ? bill.user.name.replace(/'/g, "\\'") : "" %>');
  printArrHeader.push('<%= convertDate(bill.createdAt).replace(/'/g, "\\'") %>');
</script>