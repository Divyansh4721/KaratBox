<% activeNav = 'bills' %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<%- include('../table_page/_page', {
    label,
    field,
    filterGridClass: 'grid-cols-1 md:grid-cols-12',
    tableFilters: [
        { type: 'search', id: 'searchInput', label: 'Search Customer Name', placeholder: 'Enter customer name...', span: 10, flexEnd: true },
        { type: 'stat', id: 'billCount', label: 'Total Bills', span: 2, icon: 'fas fa-file-invoice' }
    ],
    tablePage: {
        tableTitle: 'Bill Records',
        tableId: 'billBody',
        minWidth: '960px',
        colCount: 8,
        columns: [
            { label: 'S.No', align: 'left', thClass: 'px-5' },
            { label: 'Customer', align: 'left', thClass: 'px-4' },
            { label: 'Items', align: 'left', thClass: 'px-4' },
            { label: 'Gold Wt', align: 'left', thClass: 'px-4' },
            { label: 'Sold By', align: 'left', thClass: 'px-4' },
            { label: 'Date', align: 'left', thClass: 'px-4' },
            { label: 'Actions', align: 'right', thClass: 'px-5' }
        ]
    }
}) %>
<script>
  const rawRows = <%- JSON.stringify(billTable) %>;
  const allRows = rawRows.map((b) => {
    const cash = b.totalCash != null ? b.totalCash : (b.amount || 0);
    const gold = b.goldRate ? 0 : (b.totalWt || 0);
    return {
      id: b._id,
      customerId: b.customer ? b.customer._id : '',
      name: b.customer ? b.customer.name : '—',
      itemCount: b.cart ? b.cart.length : 0,
      cash,
      gold,
      soldBy: b.user ? b.user.name : '—',
      createdAt: b.createdAt,
      searchStr: b.customer ?
        (
          (b.customer.name || '') + ' ' +
          (b.customer.phNum || []).join(' ') + ' ' +
          (b.customer.address || '')
        ).toLowerCase() : ''
    };
  });
  const pager = new KbPagination({
    onPageChange: renderTable,
    formatSummary(page, rows) {
      return rows.length ?
        `Showing ${page.length} of ${rows.length} bill${rows.length > 1 ? 's' : ''}` :
        'No bills';
    }
  });

  function initials(name) {
    return (name || 'C').trim().charAt(0).toUpperCase();
  }

  function fmtCash(n) {
    return '₹ ' + new Intl.NumberFormat('en-IN').format(n || 0);
  }

  function fmtDate(iso) {
    const d = new Date(iso);
    const m = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return `${d.getDate()} ${m[d.getMonth()]} ${d.getFullYear()}, ${d.toTimeString().slice(0, 5)}`;
  }

  function filteredRows() {
    const q = (document.getElementById('searchInput').value || '').toLowerCase().trim();
    let rows = [...allRows];
    if (q) rows = rows.filter(r => r.searchStr.includes(q));
    return rows;
  }

  function renderTable() {
    const rows = filteredRows();
    const {
      page,
      start
    } = pager.apply(rows);
    const tbody = document.getElementById('billBody');
    if (!page.length) {
      tbody.innerHTML = '<tr><td colspan="8" class="py-12 text-center text-secondary">No bills found.</td></tr>';
    } else {
      tbody.innerHTML = page.map((r, i) => `
                <tr class="border-t border-surface-container hover:bg-surface-container-low/40 transition-colors">
                    <td class="py-4 px-5 text-secondary font-medium">${start + i + 1}</td>
                    <td class="py-4 px-4">
                        <div class="flex items-center gap-3">
                            <span class="w-9 h-9 rounded-full ${i % 2 ? 'bg-primary-fixed/50 text-primary' : 'bg-surface-container text-on-surface'} text-xs font-bold flex items-center justify-center shrink-0">${initials(r.name)}</span>
                            <span class="font-semibold text-on-surface">${r.name ? `<a href="/customer?id=${r.customerId}" class="text-primary hover:underline">${r.name}</a>` : '—'}</span>
                        </div>
                    </td>
                    <td class="py-4 px-4 text-secondary">${r.itemCount}</td>
                    <td class="py-4 px-4 text-secondary">${r.gold ? r.gold.toFixed(3) + ' gm' : '—'}</td>
                    <td class="py-4 px-4"><span class="text-xs font-medium bg-surface-container px-2.5 py-1 rounded-full text-secondary">${r.soldBy}</span></td>
                    <td class="py-4 px-4 text-secondary text-xs whitespace-nowrap">${fmtDate(r.createdAt)}</td>
                    <td class="py-4 px-5 text-right whitespace-nowrap">
                        <a href="/bill?id=${r.id}" class="p-2 text-secondary hover:text-primary inline-block" title="View Bill"><i class="fas fa-arrow-up-right-from-square"></i></a>
                    </td>
                </tr>`).join('');
    }
    document.getElementById('billCount').textContent = rows.length.toLocaleString('en-IN');
  }
  document.addEventListener('DOMContentLoaded', renderTable);
</script>