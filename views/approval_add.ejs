<% activeNav = 'inventory' %>
<%- include('reports/_tokens') %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low dark:bg-dark-container border border-outline-variant/40 dark:border-white/10 rounded-lg text-sm text-on-surface dark:text-dark-text placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const select = field + " appearance-none cursor-pointer"; %>
<% const btn = "inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all"; %>
<% const fmt = n => new Intl.NumberFormat('en-IN').format(Math.round((n || 0) * 1)); %>
<% const pageSubtitle = stockTable.length + ' item' + (stockTable.length !== 1 ? 's' : '') + ' for customer approval'; %>
<div class="pb-10 space-y-6">
  <%- include('cart/_workflow_header', { title, pageSubtitle }) %>

  <form action="/approvalForm" method="post" class="space-y-6">
    <div class="<%= formCard %>">
      <h3 class="text-sm font-bold text-on-surface dark:text-dark-text mb-5">Approval Details</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <%- include('cart/_customer_field', { customerTable, label, field, select, customerRequired: true }) %>
        <div class="space-y-2">
          <label class="<%= label %>">Total Cash</label>
          <input type="number" name="totalCash" value="<%= totalCash %>" readonly class="<%= field %> opacity-80">
        </div>
        <div class="md:col-span-2 space-y-2">
          <label class="<%= label %>">Remark</label>
          <input type="text" id="remark" name="remark" placeholder="Add a remark..." autocomplete="off" class="<%= field %>">
        </div>
        <div class="md:col-span-2 rounded-lg bg-primary-fixed/20 border border-primary-container/30 px-5 py-4 flex items-center justify-between gap-4">
          <span class="text-[10px] font-semibold uppercase tracking-widest text-secondary">Approval Value</span>
          <span class="text-xl font-bold text-primary">&#8377;<%= fmt(totalCash) %> /-</span>
        </div>
      </div>
      <div class="mt-6 pt-5 border-t border-surface-container dark:border-white/10">
        <button type="submit" class="<%= btn %>">
          <i class="fas fa-shield-halved text-xs"></i> Submit Approval
        </button>
      </div>
    </div>

    <%- include('layoutStockTableCartLink', { stockTable, title: 'Cart Items' }) %>
  </form>
</div>
