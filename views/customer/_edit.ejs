<% activeNav = 'customer' %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const fmtDateInput = d => { const x = new Date(d); return x.toISOString().substring(0, 10); }; %>
<div class="fixed inset-0 z-50 flex items-start justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden w-full max-w-lg my-8 max-h-[calc(100vh-4rem)] overflow-y-auto">
    <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-surface-container">
      <div class="flex items-center gap-3">
        <span class="w-10 h-10 rounded-lg bg-primary-fixed/40 flex items-center justify-center text-primary"><i class="fas fa-pen"></i></span>
        <div>
          <h3 class="text-lg font-bold text-on-surface">Edit Profile</h3>
          <p class="text-[10px] font-semibold uppercase tracking-widest text-primary">Registry Update</p>
        </div>
      </div>
      <a href="/customer?id=<%= customer.id %>" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></a>
    </div>
    <form id="editCustomerForm" action="/customer/edit-customer" method="post" class="p-6 space-y-5">
      <input type="hidden" name="id" value="<%= customer.id %>">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="<%= label %>">Customer Name</label>
          <input type="text" name="name" required value="<%= customer.name %>" placeholder="Enter Customer Name ...." class="<%= field %>">
        </div>
        <div>
          <label class="<%= label %>">Address <span class="text-error">*</span></label>
          <input type="text" name="address" required value="<%= customer.address %>" placeholder="Enter Customer Address ...." class="<%= field %>">
        </div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="<%= label %> mb-0">Phone Number <span class="text-error">*</span></label>
          <button type="button" onclick="addPhoneRow()" class="text-xs font-semibold text-primary hover:underline"><i class="fas fa-plus mr-1"></i>Add Row</button>
        </div>
        <div id="phoneRows" class="space-y-2">
          <% for (let i = 0; customer.phNum && i < customer.phNum.length; i++) { %>
          <div class="flex gap-2" id="ph<%= i %>">
            <input type="number" name="phNum[]" min="1111111111" max="9999999999" required value="<%= customer.phNum[i] %>" placeholder="Enter Phone Number ...." class="<%= field %> flex-1">
            <button type="button" onclick="removeRow('ph<%= i %>')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>
          </div>
          <% } %>
        </div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="<%= label %> mb-0">Care Of</label>
          <button type="button" onclick="addCORow()" class="text-xs font-semibold text-primary hover:underline"><i class="fas fa-plus mr-1"></i>Add Row</button>
        </div>
        <div id="coRows" class="space-y-2">
          <% for (let i = 0; customer.CO && i < customer.CO.length; i++) { %>
          <div class="flex gap-2" id="co<%= i %>">
            <input type="text" name="CO[]" value="<%= customer.CO[i] %>" placeholder="Enter Care Of ...." class="<%= field %> flex-1">
            <button type="button" onclick="removeRow('co<%= i %>', 'co')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>
          </div>
          <% } %>
        </div>
        <div id="coEmpty" class="mt-2 border border-dashed border-outline-variant/50 rounded-lg p-4 text-center text-xs text-secondary <%= customer.CO && customer.CO.length ? 'hidden' : '' %>">
          <i class="fas fa-user-friends mb-2 text-secondary/50"></i>
          <p>No 'Care Of' details added. Click 'Add Row' to include.</p>
        </div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="<%= label %> mb-0">Important Dates</label>
          <button type="button" onclick="addDateRow()" class="text-xs font-semibold text-primary hover:underline"><i class="fas fa-calendar-plus mr-1"></i>Add Row</button>
        </div>
        <div id="dateRows" class="space-y-2">
          <% for (let i = 0; customer.impDates && i < customer.impDates.length; i++) { %>
          <div class="flex gap-2 flex-wrap sm:flex-nowrap" id="dt<%= i %>">
            <input type="date" name="impDates[]" required value="<%= fmtDateInput(customer.impDates[i].date) %>" class="<%= field %> flex-1 min-w-[140px]">
            <input type="text" name="remark[]" required value="<%= customer.impDates[i].remark %>" placeholder="Remark ...." class="<%= field %> flex-1">
            <button type="button" onclick="removeRow('dt<%= i %>', 'date')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>
          </div>
          <% } %>
        </div>
        <div id="dateEmpty" class="mt-2 border border-dashed border-outline-variant/50 rounded-lg p-4 text-center text-xs text-secondary <%= customer.impDates && customer.impDates.length ? 'hidden' : '' %>">
          <i class="fas fa-calendar mb-2 text-secondary/50"></i>
          <p>Add significant anniversaries or birthdays.</p>
        </div>
      </div>
      <div class="flex gap-3 pt-2 border-t border-surface-container">
        <button type="submit" class="flex-1 py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg transition-all">Save Changes</button>
        <a href="/customer?id=<%= customer.id %>" class="px-6 py-3 bg-surface-container-low text-on-surface text-sm font-semibold rounded-lg hover:bg-surface-container transition-colors inline-flex items-center">Cancel</a>
      </div>
    </form>
  </div>
</div>
<script>
  function notify(text, type) {
    if (typeof Noty !== 'undefined') {
      new Noty({ theme: 'nest', text, type, layout: 'topCenter', timeout: 2000 }).show();
    } else {
      alert(text);
    }
  }

  async function postForm(url, form) {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(form))
    });
    const json = await res.json();
    if (!json.success) throw new Error(json.message || 'Request failed');
    return json;
  }

  async function postData(url, data) {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(data)
    });
    const json = await res.json();
    if (!json.success) throw new Error(json.message || 'Request failed');
    return json;
  }
</script>
<script>
  const inputClass = 'flex-1 px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors';
  let phoneIdx = <%= customer.phNum ? customer.phNum.length : 0 %>;
  let coIdx = <%= customer.CO ? customer.CO.length : 0 %>;
  let dateIdx = <%= customer.impDates ? customer.impDates.length : 0 %>;

  function addPhoneRow() {
    const id = phoneIdx++;
    const row = document.createElement('div');
    row.className = 'flex gap-2';
    row.id = 'ph' + id;
    row.innerHTML = `<input type="number" name="phNum[]" min="1111111111" max="9999999999" required placeholder="Enter Phone Number ...." class="${inputClass}"><button type="button" onclick="removeRow('ph${id}')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>`;
    document.getElementById('phoneRows').appendChild(row);
  }

  function addCORow() {
    document.getElementById('coEmpty').classList.add('hidden');
    const id = coIdx++;
    const row = document.createElement('div');
    row.className = 'flex gap-2';
    row.id = 'co' + id;
    row.innerHTML = `<input type="text" name="CO[]" placeholder="Enter Care Of ...." class="${inputClass}"><button type="button" onclick="removeRow('co${id}', 'co')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>`;
    document.getElementById('coRows').appendChild(row);
  }

  function addDateRow() {
    document.getElementById('dateEmpty').classList.add('hidden');
    const id = dateIdx++;
    const row = document.createElement('div');
    row.className = 'flex gap-2 flex-wrap sm:flex-nowrap';
    row.id = 'dt' + id;
    row.innerHTML = `<input type="date" name="impDates[]" required class="${inputClass} min-w-[140px]"><input type="text" name="remark[]" required placeholder="Remark ...." class="${inputClass}"><button type="button" onclick="removeRow('dt${id}', 'date')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>`;
    document.getElementById('dateRows').appendChild(row);
  }

  function removeRow(id, type) {
    document.getElementById(id)?.remove();
    if (type === 'co' && !document.getElementById('coRows').children.length) document.getElementById('coEmpty').classList.remove('hidden');
    if (type === 'date' && !document.getElementById('dateRows').children.length) document.getElementById('dateEmpty').classList.remove('hidden');
  }
  document.addEventListener('DOMContentLoaded', () => {
    if (!document.getElementById('phoneRows').children.length) addPhoneRow();
  });
  document.getElementById('editCustomerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const json = await postForm('/customer/edit-customer', e.target);
      notify(json.message, 'success');
    } catch (err) {
      notify(err.message, 'error');
    }
  });
</script>