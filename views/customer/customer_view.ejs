<% activeNav = 'customer' %>
<% const fmt = n => new Intl.NumberFormat('en-IN').format(Math.abs(n * 1)); %>
<% const label = "block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field = "w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const months = ['January','February','March','April','May','June','July','August','September','October','November','December']; %>
<% const since = new Date(customer.createdAt); %>
<% const sinceStr = months[since.getMonth()] + ' ' + since.getFullYear(); %>
<% const primaryPhone = customer.phNum && customer.phNum.length ? String(customer.phNum[0]) : '—'; %>
<% const dtLocal = new Date(new Date().getTime() + 19800000).toISOString().substring(0, 16); %>
<% const fmtReview = d => { if (!d) return '—'; const x = new Date(d); return months[x.getMonth()].slice(0,3) + ' ' + x.getDate() + ', ' + x.getFullYear(); }; %>
<% const initials = (customer.name || 'C').trim().charAt(0).toUpperCase(); %>
<%
let paymentDate = null;
if (customer.impDates && customer.impDates.length) {
    const now = new Date();
    const upcoming = customer.impDates.filter(d => new Date(d.date) >= now).sort((a, b) => new Date(a.date) - new Date(b.date));
}
if (customer.payments && customer.payments.length) {
    const dates = customer.payments.map(p => p.date).filter(Boolean);
    if (dates.length) paymentDate = dates.sort((a, b) => new Date(b) - new Date(a))[0];
}
%>
<div class="pb-10">
  <div class="rounded-xl bg-primary text-on-primary overflow-hidden shadow-whisper mb-4">
    <div class="p-6 sm:p-8">
      <div class="flex items-center gap-5">
        <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl bg-surface-container-lowest/20 border border-on-primary/20 flex items-center justify-center shrink-0 overflow-hidden">
          <span class="text-2xl sm:text-3xl font-bold text-on-primary/70"><%= initials %></span>
        </div>
        <div class="flex-1 min-w-0">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight truncate"><%= customer.name %></h2>
          <p class="text-sm text-on-primary/75 mt-0.5"> Since <%= sinceStr %></p>
        </div>
        <button type="button" onclick="openEditModal()" class="inline-flex items-center gap-2 px-4 py-2.5 border border-on-primary/40 hover:bg-on-primary/10 text-on-primary text-sm font-semibold rounded-lg transition-colors shrink-0">
          <i class="fas fa-pen text-xs"></i>
          <span class="hidden sm:inline">Edit Profile</span>
        </button>
      </div>
    </div>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6 sm:p-8 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-5">
        <div class="flex items-start gap-3">
          <span class="w-9 h-9 rounded-lg bg-surface-container-low flex items-center justify-center shrink-0 text-secondary"><i class="fas fa-location-dot text-sm"></i></span>
          <div>
            <p class="<%= label %>">Customer Address</p>
            <p class="text-sm font-medium text-on-surface"><%= customer.address %></p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-9 h-9 rounded-lg bg-surface-container-low flex items-center justify-center shrink-0 text-secondary"><i class="fas fa-shield-halved text-sm"></i></span>
          <div>
            <p class="<%= label %>">Onboarded By</p>
            <p class="text-sm font-medium text-on-surface"><%= customer.user.name %></p>
          </div>
        </div>
      </div>
      <div class="space-y-5">
        <div class="bg-surface-container-low rounded-xl p-5 space-y-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <span class="w-8 h-8 rounded-lg bg-surface-container-lowest flex items-center justify-center text-secondary"><i class="fas fa-money-bill-wave text-xs"></i></span>
              <div>
                <p class="<%= label %> mb-0">Cash Balance</p>
                <p class="text-lg font-bold text-on-surface">&#8377; <%= fmt(cashBalance) %> <span class="text-sm font-normal text-secondary">/-</span></p>
              </div>
            </div>
            <% if (cashBalance === 0) { %><span class="text-[10px] font-bold uppercase tracking-wide text-on-surface bg-surface-container-highest px-2.5 py-1 rounded-full">Settled</span><% } %>
          </div>
          <div class="border-t border-surface-container"></div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <span class="w-8 h-8 rounded-lg bg-surface-container-lowest flex items-center justify-center text-secondary"><i class="fas fa-gem text-xs"></i></span>
              <div>
                <p class="<%= label %> mb-0">Gold Balance</p>
                <p class="text-lg font-bold text-on-surface"><%= fmt(goldBalance) %> <span class="text-sm font-normal text-secondary">gm</span></p>
              </div>
            </div>
            <% if (goldBalance === 0) { %><span class="text-[10px] font-bold uppercase tracking-wide text-on-surface bg-surface-container-highest px-2.5 py-1 rounded-full">Settled</span><% } %>
          </div>
        </div>
        <div class="flex flex-wrap gap-x-8 gap-y-2 text-sm">
        </div>
      </div>
    </div>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6 sm:p-8 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="flex items-start gap-3">
        <span class="w-9 h-9 rounded-lg bg-surface-container-low flex items-center justify-center shrink-0 text-secondary"><i class="fas fa-phone text-sm"></i></span>
        <div>
          <p class="<%= label %>">Phone Numbers</p>
          <% if (customer.phNum && customer.phNum.length) { %>
          <div class="space-y-1">
            <% customer.phNum.forEach(function(num) { %>
            <p class="text-sm font-medium text-on-surface">+91 <%= String(num) %></p>
            <% }); %>
          </div>
          <% } else { %>
          <p class="text-sm font-medium text-on-surface">+91 —</p>
          <% } %>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="w-9 h-9 rounded-lg bg-surface-container-low flex items-center justify-center shrink-0 text-secondary"><i class="fas fa-user-friends text-sm"></i></span>
        <div>
          <p class="<%= label %>">Care Of</p>
          <% if (customer.CO && customer.CO.length) { %>
          <ul class="text-sm font-medium text-on-surface space-y-1 list-disc list-inside">
            <% customer.CO.forEach(function(co) { %>
            <li><%= co %></li>
            <% }); %>
          </ul>
          <% } else { %>
          <p class="text-sm font-medium text-on-surface">Not Specified</p>
          <% } %>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="w-9 h-9 rounded-lg bg-surface-container-low flex items-center justify-center shrink-0 text-secondary"><i class="fas fa-calendar-days text-sm"></i></span>
        <div class="min-w-0 flex-1">
          <p class="<%= label %>">Important Dates</p>
          <% if (customer.impDates && customer.impDates.length) { %>
          <div class="space-y-2">
            <% customer.impDates
              .slice()
              .sort(function(a, b) { return new Date(a.date) - new Date(b.date); })
              .forEach(function(d) { %>
            <div>
              <p class="text-sm font-semibold text-on-surface"><%= convertDate(d.date) %></p>
              <% if (d.remark) { %>
              <p class="text-xs text-secondary mt-0.5"><%= d.remark %></p>
              <% } %>
            </div>
            <% }); %>
          </div>
          <% } else { %>
          <p class="text-sm font-medium text-on-surface">Not Specified</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-8 lg:items-start">
    <div class="lg:col-span-3 bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden">
      <div class="px-6 sm:px-8 pt-6 pb-0">
        <h3 class="text-sm font-bold text-primary mb-4 flex items-center gap-2">
          <i class="fas fa-plus text-xs"></i> Post New Transaction
        </h3>
      </div>
      <div class="flex items-end gap-0 px-6 sm:px-8 border-b border-surface-container shrink-0">
        <button type="button" id="txnTabPayment" data-txn-tab="payment" class="txn-tab txn-tab-active min-w-[9.5rem] h-10 inline-flex items-center justify-center gap-2 rounded-t-lg border border-b-0 border-surface-container bg-surface-container-lowest px-4 text-sm font-semibold text-on-surface -mb-px relative z-[1]">
          <i class="fas fa-money-bill-wave text-xs"></i> Add Payment
        </button>
        <button type="button" id="txnTabGold" data-txn-tab="gold" class="txn-tab min-w-[9.5rem] h-10 inline-flex items-center justify-center gap-2 rounded-t-lg border border-transparent px-4 text-sm font-semibold text-secondary hover:text-on-surface hover:bg-surface-container-low/60 -mb-px">
          <i class="fas fa-gem text-xs"></i> Add Gold Entry
        </button>
      </div>
      <div class="p-6 sm:p-8 pt-6">
        <div class="relative h-[28rem]">
          <form action="/addPaymentCustomer" method="post" id="paymentForm" class="txn-panel absolute inset-0 space-y-4 overflow-y-auto">
            <input type="hidden" name="id" value="<%= customer.id %>">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="<%= label %>">Amount (&#8377;)</label>
                <input type="number" name="amount" placeholder="Enter amount..." required class="<%= field %>">
              </div>
              <div>
                <label class="<%= label %>">Transaction Date</label>
                <input type="datetime-local" name="date" value="<%= dtLocal %>" required class="<%= field %>">
              </div>
            </div>
            <div>
              <label class="<%= label %>">Remarks / Notes</label>
              <textarea name="remark" rows="3" placeholder="Describe the transaction..." required autocomplete="off" class="<%= field %> resize-none"></textarea>
            </div>
            <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all">
              <i class="fas fa-money-bill-wave text-xs"></i> Add Payment
            </button>
          </form>
          <form action="/addPaymentCustomer" method="post" id="goldForm" class="txn-panel hidden absolute inset-0 space-y-4 overflow-y-auto">
            <input type="hidden" name="id" value="<%= customer.id %>">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div><label class="<%= label %>">Gold Wt (gm)</label><input type="number" id="payemntGold" step="0.001" placeholder="Gold Wt..." onchange="calcFine()" required class="<%= field %>"></div>
              <div><label class="<%= label %>">Purity %</label><input type="number" id="payemntPer" step="0.01" value="100" onchange="calcFine()" required class="<%= field %>"></div>
              <div><label class="<%= label %>">Fine Wt (gm)</label><input type="number" name="gold" id="payemntFine" readonly required class="<%= field %> opacity-80"></div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div><label class="<%= label %>">Transaction Date</label><input type="datetime-local" name="date" value="<%= dtLocal %>" required class="<%= field %>"></div>
            </div>
            <div>
              <label class="<%= label %>">Remarks / Notes</label>
              <textarea name="remark" rows="3" placeholder="Describe the transaction..." autocomplete="off" class="<%= field %> resize-none"></textarea>
            </div>
            <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:brightness-110 text-on-primary text-sm font-semibold rounded-lg transition-all">
              <i class="fas fa-gem text-xs"></i> Add Gold Entry
            </button>
          </form>
        </div>
      </div>
    </div>
    <div class="lg:col-span-2 flex flex-col gap-4">
      <div class="bg-primary-fixed/25 rounded-xl border border-primary-container/20 p-6 flex flex-col">
        <div class="flex items-start gap-4 mb-5">
          <span class="w-12 h-12 rounded-full bg-primary-container/30 flex items-center justify-center shrink-0 text-primary">
            <i class="fas fa-wallet text-lg"></i>
          </span>
          <div>
            <h3 class="text-sm font-bold text-on-surface mb-1">Final Settlement</h3>
            <p class="text-sm text-secondary leading-relaxed">Process all pending balances and close current ledger for <%= customer.name %>.</p>
          </div>
        </div>
        <div class="space-y-2 text-sm mb-6">
          <p><span class="text-secondary">Total Cash Due:</span> <span class="font-bold text-on-surface">&#8377; <%= fmt(cashBalance) %>.00</span></p>
          <p><span class="text-secondary">Total Gold Due:</span> <span class="font-bold text-on-surface"><%= (goldBalance * 1).toFixed(3) %> gm</span></p>
        </div>
        <a href="/settleCustomer/<%= customer.id %>" onclick="return confirm('Settle all balances for this customer?')" class="block w-full text-center py-3 border-2 border-primary text-primary font-bold text-sm rounded-lg hover:bg-primary-fixed/40 transition-colors">
          Settle Now
        </a>
      </div>
      <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper p-6">
        <h3 class="text-sm font-bold text-on-surface mb-4">Lifecycle &amp; History</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="bg-surface-container-low rounded-xl border border-surface-container p-4">
            <div class="flex items-center gap-2 mb-2 text-secondary">
              <i class="fas fa-calendar-days text-sm"></i>
            </div>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1">Joined Date</p>
            <p class="font-bold text-on-surface text-sm"><%= months[since.getMonth()] %> <%= since.getDate() %>, <%= since.getFullYear() %></p>
          </div>
          <div class="bg-surface-container-low rounded-xl border border-surface-container p-4">
            <div class="flex items-center gap-2 mb-2 text-secondary">
              <i class="fas fa-clock-rotate-left text-sm"></i>
            </div>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1">Last Payment</p>
            <p class="font-bold text-on-surface text-sm"><%= paymentDate ? convertDate(paymentDate) : 'Not Recorded' %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden mb-8">
    <div class="px-5 py-4 border-b border-surface-container flex items-center justify-between gap-3">
      <h3 class="text-sm font-bold text-on-surface">Transaction Ledger</h3>
      <span class="text-xs text-secondary"><%= entries.length %> entr<%= entries.length === 1 ? 'y' : 'ies' %></span>
    </div>
    <div class="hidden md:grid md:grid-cols-[1fr_1fr_auto] border-b border-surface-container bg-surface-container-low/40 text-[10px] font-semibold uppercase tracking-widest">
      <div class="px-5 py-3 text-rose-700 dark:text-rose-400">
        <i class="fas fa-arrow-up text-[9px] mr-1"></i> Bills &amp; Dues
      </div>
      <div class="px-5 py-3 text-emerald-700 dark:text-emerald-400 text-center">
        Cash Received <i class="fas fa-arrow-down text-[9px] ml-1"></i>
      </div>
      <div class="w-20"></div>
    </div>
    <div id="ledgerList"></div>
    <%- include('../partials/_pagination_footer', { summaryId: 'ledgerSummary', paginationId: 'ledgerPagination', perPageSelectId: 'ledgerPerPage' }) %>
  </div>
</div>
<div id="editModal" class="fixed inset-0 z-50 hidden items-start justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-lg my-8 max-h-[calc(100vh-4rem)] overflow-y-auto">
    <div class="flex items-start justify-between px-6 py-4 border-b border-surface-container">
      <div class="flex items-center gap-3">
        <span class="w-10 h-10 rounded-lg bg-primary-fixed/40 flex items-center justify-center text-primary"><i class="fas fa-pen"></i></span>
        <div>
          <h3 class="text-lg font-bold text-on-surface">Edit Profile</h3>
          <p class="text-[10px] font-semibold uppercase tracking-widest text-primary">Registry Update</p>
        </div>
      </div>
      <button type="button" onclick="closeEditModal()" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form id="editForm" action="/editCustomerForm" method="post" class="p-6 space-y-5">
      <input type="hidden" name="id" id="editId">
      <input type="hidden" name="returnTo" value="/customer?id=<%= customer.id %>">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div><label class="<%= label %>">Customer Name</label><input type="text" name="name" id="editName" required placeholder="Enter Customer Name ...." class="<%= field %>"></div>
        <div><label class="<%= label %>">Address <span class="text-error">*</span></label><input type="text" name="address" id="editAddress" required placeholder="Enter Customer Address ...." class="<%= field %>"></div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="<%= label %> mb-0">Phone Number <span class="text-error">*</span></label>
          <button type="button" onclick="addEditPhoneRow()" class="text-xs font-semibold text-primary hover:underline"><i class="fas fa-plus mr-1"></i>Add Row</button>
        </div>
        <div id="editPhoneRows" class="space-y-2"></div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="<%= label %> mb-0">Care Of</label>
          <button type="button" onclick="addEditCORow()" class="text-xs font-semibold text-primary hover:underline"><i class="fas fa-plus mr-1"></i>Add Row</button>
        </div>
        <div id="editCoRows" class="space-y-2"></div>
        <div id="editCoEmpty" class="mt-2 border border-dashed border-outline-variant/50 rounded-lg p-4 text-center text-xs text-secondary">
          <i class="fas fa-user-friends mb-2 text-secondary/50"></i>
          <p>No 'Care Of' details added. Click 'Add Row' to include.</p>
        </div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="<%= label %> mb-0">Important Dates</label>
          <button type="button" onclick="addEditDateRow()" class="text-xs font-semibold text-primary hover:underline"><i class="fas fa-calendar-plus mr-1"></i>Add Row</button>
        </div>
        <div id="editDateRows" class="space-y-2"></div>
        <div id="editDateEmpty" class="mt-2 border border-dashed border-outline-variant/50 rounded-lg p-4 text-center text-xs text-secondary">
          <i class="fas fa-calendar mb-2 text-secondary/50"></i>
          <p>Add significant anniversaries or birthdays.</p>
        </div>
      </div>
      <div class="flex gap-3 pt-2 border-t border-surface-container">
        <button type="submit" class="flex-1 py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg transition-all">Save Changes</button>
        <button type="button" onclick="closeEditModal()" class="px-6 py-3 bg-surface-container-low text-on-surface text-sm font-semibold rounded-lg hover:bg-surface-container transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
  const customerData = <%- JSON.stringify({
    _id: customer.id,
    name: customer.name,
    address: customer.address,
    phNum: customer.phNum || [],
    CO: customer.CO || [],
    impDates: customer.impDates || []
  }) %>;
  const inputClass = 'flex-1 px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-sm text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors';
  let editPhoneIdx = 0,
    editCoIdx = 0,
    editDateIdx = 0;

  function fmtDateInput(d) {
    const x = new Date(d);
    return x.toISOString().substring(0, 10);
  }

  function escAttr(s) {
    return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  }

  function openEditModal() {
    const c = customerData;
    document.getElementById('editId').value = c._id;
    document.getElementById('editName').value = c.name || '';
    document.getElementById('editAddress').value = c.address || '';
    const editPhoneRows = document.getElementById('editPhoneRows');
    editPhoneRows.innerHTML = '';
    editPhoneIdx = 0;
    (c.phNum || []).forEach((ph) => addEditPhoneRow(ph));
    if (!c.phNum || !c.phNum.length) addEditPhoneRow();
    const editCoRows = document.getElementById('editCoRows');
    editCoRows.innerHTML = '';
    editCoIdx = 0;
    (c.CO || []).forEach((co) => addEditCORow(co));
    document.getElementById('editCoEmpty').classList.toggle('hidden', !!(c.CO && c.CO.length));
    const editDateRows = document.getElementById('editDateRows');
    editDateRows.innerHTML = '';
    editDateIdx = 0;
    (c.impDates || []).forEach((d) => addEditDateRow(d.date, d.remark));
    document.getElementById('editDateEmpty').classList.toggle('hidden', !!(c.impDates && c.impDates.length));
    document.getElementById('editModal').classList.replace('hidden', 'flex');
  }

  function closeEditModal() {
    document.getElementById('editModal').classList.replace('flex', 'hidden');
  }

  function addEditPhoneRow(value = '') {
    const id = editPhoneIdx++;
    const row = document.createElement('div');
    row.className = 'flex gap-2';
    row.id = 'editPh' + id;
    row.innerHTML = `<input type="number" name="phNum[]" min="1111111111" max="9999999999" required value="${escAttr(value)}" placeholder="Enter Phone Number ...." class="${inputClass}"><button type="button" onclick="removeEditRow('editPh${id}')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>`;
    document.getElementById('editPhoneRows').appendChild(row);
  }

  function addEditCORow(value = '') {
    document.getElementById('editCoEmpty').classList.add('hidden');
    const id = editCoIdx++;
    const row = document.createElement('div');
    row.className = 'flex gap-2';
    row.id = 'editCo' + id;
    row.innerHTML = `<input type="text" name="CO[]" value="${escAttr(value)}" placeholder="Enter Care Of ...." class="${inputClass}"><button type="button" onclick="removeEditRow('editCo${id}', 'co')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>`;
    document.getElementById('editCoRows').appendChild(row);
  }

  function addEditDateRow(date = '', remark = '') {
    document.getElementById('editDateEmpty').classList.add('hidden');
    const id = editDateIdx++;
    const row = document.createElement('div');
    row.className = 'flex gap-2 flex-wrap sm:flex-nowrap';
    row.id = 'editDt' + id;
    const dateVal = date ? fmtDateInput(date) : '';
    row.innerHTML = `<input type="date" name="impDates[]" required value="${escAttr(dateVal)}" class="${inputClass} min-w-[140px]"><input type="text" name="remark[]" required value="${escAttr(remark)}" placeholder="Remark ...." class="${inputClass}"><button type="button" onclick="removeEditRow('editDt${id}', 'date')" class="p-3 text-error hover:bg-error-container/20 rounded-lg"><i class="fas fa-trash text-sm"></i></button>`;
    document.getElementById('editDateRows').appendChild(row);
  }

  function removeEditRow(id, type) {
    document.getElementById(id)?.remove();
    if (type === 'co' && !document.getElementById('editCoRows').children.length) document.getElementById('editCoEmpty').classList.remove('hidden');
    if (type === 'date' && !document.getElementById('editDateRows').children.length) document.getElementById('editDateEmpty').classList.remove('hidden');
  }

  function calcFine() {
    const g = document.getElementById('payemntGold');
    const p = document.getElementById('payemntPer');
    const f = document.getElementById('payemntFine');
    if (g && p && f) f.value = (g.value * p.value / 100).toFixed(3);
  }

  function setTxnTabActive(btn, on) {
    btn.classList.toggle('txn-tab-active', on);
    btn.classList.toggle('border-surface-container', on);
    btn.classList.toggle('border-b-0', on);
    btn.classList.toggle('bg-surface-container-lowest', on);
    btn.classList.toggle('text-on-surface', on);
    btn.classList.toggle('z-[1]', on);
    btn.classList.toggle('border-transparent', !on);
    btn.classList.toggle('text-secondary', !on);
  }

  function selectTxnTab(tab) {
    const paymentForm = document.getElementById('paymentForm');
    const goldForm = document.getElementById('goldForm');
    const tabPayment = document.getElementById('txnTabPayment');
    const tabGold = document.getElementById('txnTabGold');
    const showGold = tab === 'gold';
    paymentForm.classList.toggle('hidden', showGold);
    goldForm.classList.toggle('hidden', !showGold);
    setTxnTabActive(tabPayment, !showGold);
    setTxnTabActive(tabGold, showGold);
  }

  document.getElementById('txnTabPayment')?.addEventListener('click', () => selectTxnTab('payment'));
  document.getElementById('txnTabGold')?.addEventListener('click', () => selectTxnTab('gold'));

  const ledgerEntries = <%- JSON.stringify(entries.map(function(e) {
    return {
      id: e.id,
      type: e.type,
      bill: e.bill || '',
      amount: e.amount || 0,
      gold: e.gold || 0,
      date: convertDate(e.date),
      remark: e.remark || '',
      userName: e.user && e.user.name ? e.user.name : ''
    };
  })) %>;
  const ledgerCustomerId = '<%= customer.id %>';
  const fmtLedger = n => new Intl.NumberFormat('en-IN').format(Math.abs(n * 1));

  function escLedger(s) {
    return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function ledgerLabel(e) {
    if (e.bill === 'bill') return 'Bill';
    if (e.bill === 'approval') return 'Approval';
    if (e.type === 'right') return e.gold ? 'Gold Received' : 'Cash Received';
    if (e.gold) return 'Gold Due';
    return 'Payment Out';
  }

  function ledgerActions(e) {
    if (e.bill === 'bill') {
      return `<a href="/bill?id=${e.id}" class="p-2 text-secondary hover:text-primary rounded-lg" title="View Bill"><i class="fas fa-file-invoice"></i></a>
        <a href="/delBillCustomer?id=${e.id}&customer=${ledgerCustomerId}" onclick="return confirm('Delete this bill from customer?')" class="p-2 text-secondary hover:text-error rounded-lg" title="Delete"><i class="fas fa-trash"></i></a>`;
    }
    if (e.bill === 'approval') {
      return `<a href="/approvalRecvPage?id=${e.id}" class="p-2 text-secondary hover:text-primary rounded-lg" title="View Approval"><i class="fa-regular fa-folder-open"></i></a>`;
    }
    if (e.id) {
      return `<a href="/delPaymentCustomer?id=${e.id}&customer=${ledgerCustomerId}" onclick="return confirm('Delete this payment?')" class="p-2 text-secondary hover:text-error rounded-lg" title="Delete"><i class="fas fa-trash"></i></a>`;
    }
    return '';
  }

  function ledgerBody(e, side) {
    const isReceived = e.type === 'right';
    const tone = isReceived ? 'text-emerald-700 dark:text-emerald-400' : 'text-rose-700 dark:text-rose-400';
    const subTone = isReceived ? 'text-emerald-600 dark:text-emerald-400' : 'text-rose-600 dark:text-rose-400';
    const align = side === 'center' ? 'text-center items-center' : 'text-left items-start';
    let amounts = '';
    if (e.amount) amounts += `<p class="font-bold ${tone}">&#8377; ${fmtLedger(e.amount)} /-</p>`;
    if (e.gold) amounts += `<p class="font-bold ${tone}">${fmtLedger(e.gold)} gm</p>`;
    return `
      <div class="min-w-0 flex flex-col ${align}">
        ${amounts}
        <p class="text-xs font-semibold ${subTone} mt-0.5">${ledgerLabel(e)}</p>
        <p class="text-xs text-secondary mt-1">${e.date}${e.remark ? ' &middot; ' + escLedger(e.remark) : ''}</p>
        ${e.userName ? `<p class="text-xs text-secondary mt-0.5">By: ${escLedger(e.userName)}</p>` : ''}
      </div>`;
  }

  function ledgerRow(e) {
    const isReceived = e.type === 'right';
    const actions = ledgerActions(e);
    return `
      <div class="flex items-start gap-3 px-4 sm:px-5 py-4 min-h-[4.5rem] border-b border-surface-container last:border-b-0 hover:bg-surface-container-low/20">
        <div class="flex-1 min-w-0">${isReceived ? '' : ledgerBody(e, 'left')}</div>
        <div class="flex-1 min-w-0">${isReceived ? ledgerBody(e, 'center') : ''}</div>
        <div class="flex items-center gap-1 shrink-0 self-start pt-0.5">${actions}</div>
      </div>`;
  }

  const ledgerPager = new KbPagination({
    perPage: 10,
    paginationId: 'ledgerPagination',
    summaryId: 'ledgerSummary',
    perPageSelectId: 'ledgerPerPage',
    onPageChange: renderLedger,
    formatSummary(page, rows, start) {
      if (!rows.length) return 'No transactions';
      const end = start + page.length;
      return `Showing ${start + 1}-${end} of ${rows.length} entr${rows.length === 1 ? 'y' : 'ies'}`;
    }
  });

  function renderLedger() {
    const { page } = ledgerPager.apply(ledgerEntries);
    const el = document.getElementById('ledgerList');
    if (!page.length) {
      el.innerHTML = '<p class="px-5 py-12 text-center text-sm text-secondary">No transactions recorded yet.</p>';
      return;
    }
    el.innerHTML = page.map(ledgerRow).join('');
  }

  renderLedger();
</script>