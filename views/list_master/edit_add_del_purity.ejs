<% const routes = {
  add: '/list_master/purity/add-purity',
  edit: '/list_master/purity/edit-purity',
  delete: '/list_master/purity/delete-purity'
}; %>
<%- include('_crud_page', { options, lm: {
    entity: 'Purity',
    tableId: 'purityTableBody',
    searchLabel: 'purity name',
    recordLabel: 'purity',
    summaryPrefix: 'standard purity',
    ledgerLabel: 'Purity',
    csvFile: 'purity-records.csv',
    routes,
    columns: [
        { key: 'name', label: 'Purity Name', cell: 'primary' },
        { key: 'wholesaleMultiplier', label: 'Wholesale Multiplier', cell: 'number' },
        { key: 'retailMultiplier', label: 'Retail Multiplier', cell: 'number' },
        { key: 'wastage', label: 'Wastage Value', cell: 'number' },
        { key: 'stockCount', label: 'Stock Count', cell: 'badge' }
    ],
    fields: [
        { name: 'name', editName: 'newname', editId: 'editName', label: 'Purity Name', type: 'text', placeholder: 'Enter Purity Name ....' },
        { name: 'wholesaleMultiplier', editId: 'editWholesale', label: 'Wholesale Multiplier Value', type: 'number', step: '0.01', placeholder: 'Enter WholeSale Multiplier Value' },
        { name: 'retailMultiplier', editId: 'editRetail', label: 'Retail Multiplier Value', type: 'number', step: '0.01', placeholder: 'Enter Retail Multiplier Value ....' },
        { name: 'wastage', editId: 'editWastage', label: 'Wastage Value', type: 'number', step: '0.01', placeholder: 'Enter Wastage Value ....' }
    ],
    labels: {
        addButton: 'Create New Purity',
        createTitle: 'Create New Purity',
        createSubmit: 'Submit',
        editTitle: 'Edit Purity',
        editSubmit: 'Submit',
        deleteQuestion: 'Delete this purity?',
        deleteSubmit: 'Delete'
    }
}}) %>
<%- include('_crud_ajax_script', { routes }) %>
