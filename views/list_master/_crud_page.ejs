<% activeNav='list_master' %>
<% const label="block text-[10px] font-semibold uppercase tracking-widest text-secondary mb-1.5"; %>
<% const field="w-full px-4 py-3 bg-surface-container-low border border-transparent rounded-lg text-body-md text-on-surface placeholder-secondary/60 focus:outline-none focus:border-primary-container transition-colors"; %>
<% const colCount = lm.columns.length + 2; %>
<div class="pb-10">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper overflow-hidden">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4 px-5 py-4 border-b border-surface-container">
      <h3 class="text-sm font-bold text-on-surface shrink-0">Existing <%= lm.entity %> Records</h3>
      <div class="flex items-center gap-3 w-full sm:w-auto sm:ml-auto">
        <input type="search" id="searchInput" oninput="pager.resetPage(); renderTable()" placeholder="Search <%= lm.searchLabel %>..." title="Search by <%= lm.searchLabel %>" class="<%= field %> w-full sm:w-56 text-sm py-2">
        <button type="button" onclick="openCreateModal()" title="<%= lm.labels.addButton %>" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-primary-container hover:brightness-105 text-on-primary text-sm font-semibold rounded-lg shadow-sm transition-all shrink-0">
          <i class="fas fa-plus text-xs"></i> <%= lm.labels.addButton %>
        </button>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface-container-low">
          <tr class="text-[10px] font-semibold uppercase tracking-widest text-secondary">
            <th class="text-center py-3 pl-5 pr-10 w-20 whitespace-nowrap">Sl No.</th>
            <% lm.columns.forEach(function(col) { %>
            <th class="py-3 px-4 <%= col.cell === 'primary' ? 'text-left' : 'text-center w-36' %>"><%= col.label %></th>
            <% }); %>
            <th class="text-center py-3 pl-4 pr-5 w-32">Actions</th>
          </tr>
        </thead>
        <tbody id="<%= lm.tableId %>"></tbody>
      </table>
    </div>
    <%- include('../partials/_pagination_footer') %>
  </div>
</div>
<div id="createModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-md">
    <div class="flex items-center justify-between px-6 py-4 border-b border-surface-container">
      <h3 class="text-lg font-bold text-on-surface"><%= lm.labels.createTitle %></h3>
      <button type="button" onclick="closeCreateModal()" title="Close" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form action="<%= lm.routes.add %>" method="post" class="p-6 space-y-4">
      <% lm.fields.forEach(function(f) { %>
      <div>
        <label class="<%= label %>"><%= f.label %></label>
        <input type="<%= f.type %>" name="<%= f.name %>" <%= f.step ? 'step="' + f.step + '"' : '' %> required placeholder="<%= f.placeholder || '' %>" class="<%= field %>">
      </div>
      <% }); %>
      <button type="submit" title="<%= lm.labels.createSubmit %>" class="w-full py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg transition-all"><%= lm.labels.createSubmit %></button>
    </form>
  </div>
</div>
<div id="editModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-md">
    <div class="flex items-center justify-between px-6 py-4 border-b border-surface-container">
      <h3 class="text-lg font-bold text-on-surface"><%= lm.labels.editTitle %></h3>
      <button type="button" onclick="closeEditModal()" title="Close" class="p-1 text-secondary hover:text-on-surface"><i class="fas fa-times"></i></button>
    </div>
    <form action="<%= lm.routes.edit %>" method="post" class="p-6 space-y-4">
      <input type="hidden" name="oldname" id="editId">
      <% lm.fields.forEach(function(f) { %>
      <div>
        <label class="<%= label %>"><%= f.label %></label>
        <input type="<%= f.type %>" name="<%= f.editName || f.name %>" id="<%= f.editId %>" <%= f.step ? 'step="' + f.step + '"' : '' %> required placeholder="<%= f.placeholder || '' %>" class="<%= field %>">
      </div>
      <% }); %>
      <button type="submit" title="<%= lm.labels.editSubmit %>" class="w-full py-3 bg-primary hover:brightness-110 text-on-primary text-sm font-bold uppercase tracking-wider rounded-lg transition-all"><%= lm.labels.editSubmit %></button>
    </form>
  </div>
</div>
<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-surface-container-lowest rounded-xl border border-surface-container shadow-whisper w-full max-w-sm p-6 text-center">
    <p class="text-on-surface font-semibold mb-2"><%= lm.labels.deleteQuestion %></p>
    <p id="deleteLabel" class="text-sm text-secondary mb-6"></p>
    <form id="deleteForm" action="<%= lm.routes.delete %>" method="post" class="flex gap-3 justify-center">
      <input type="hidden" name="name" id="deleteId">
      <button type="button" onclick="closeDeleteModal()" title="Cancel" class="px-5 py-2.5 border border-surface-container rounded-lg text-sm font-semibold text-secondary hover:bg-surface-container-low">Cancel</button>
      <button type="submit" title="<%= lm.labels.deleteSubmit %>" class="px-5 py-2.5 bg-error text-on-error rounded-lg text-sm font-semibold hover:opacity-90"><%= lm.labels.deleteSubmit %></button>
    </form>
  </div>
</div>
<script>
  const allRows = <%- JSON.stringify(options) %>;
  const lmConfig = <%- JSON.stringify({ tableId: lm.tableId, colCount: colCount, recordLabel: lm.recordLabel, columns: lm.columns, fields: lm.fields, summaryPrefix: lm.summaryPrefix || lm.recordLabel }) %>;
  let displayRows = [];
  const pager = new KbPagination({
    onPageChange: renderTable,
    formatSummary(page, rows) {
      const prefix = lmConfig.summaryPrefix;
      return rows.length ?
        `Showing ${page.length} of ${rows.length} ${prefix} record${rows.length > 1 ? 's' : ''}` :
        'No records';
    }
  });

  function fmt(n) {
    return (n * 1).toFixed(2);
  }

  function cellHtml(col, r) {
    const base = 'py-3 px-4';
    if (col.cell === 'primary') return `<td class="${base} text-left font-semibold text-primary">${r[col.key]}</td>`;
    if (col.cell === 'badge') return `<td class="${base} text-center w-36"><span class="inline-flex min-w-[2rem] justify-center text-xs font-semibold bg-primary-fixed/40 text-primary px-2.5 py-1 rounded-full">${r[col.key]}</span></td>`;
    if (col.cell === 'number') return `<td class="${base} text-center w-36 text-on-surface tabular-nums">${fmt(r[col.key])}</td>`;
    return `<td class="${base} text-center text-on-surface">${r[col.key]}</td>`;
  }

  function filteredRows() {
    const q = (document.getElementById('searchInput')?.value || '').toLowerCase();
    return q ? allRows.filter(r => r.name.toLowerCase().includes(q)) : allRows;
  }

  function renderTable() {
    const rows = filteredRows();
    const {
      page,
      start
    } = pager.apply(rows);
    displayRows = page;
    const tbody = document.getElementById(lmConfig.tableId);
    if (!page.length) {
      tbody.innerHTML = `<tr><td colspan="${lmConfig.colCount}" class="py-12 text-center text-secondary">No ${lmConfig.recordLabel} records found.</td></tr>`;
    } else {
      tbody.innerHTML = page.map((r, i) => `
                <tr class="border-t border-surface-container hover:bg-surface-container-low/40 transition-colors">
                    <td class="py-3 pl-5 pr-10 text-center text-secondary font-medium w-20 whitespace-nowrap">${start + i + 1}</td>
                    ${lmConfig.columns.map(col => cellHtml(col, r)).join('')}
                    <td class="py-3 pl-4 pr-5 text-center w-32 whitespace-nowrap">
                        <div class="inline-flex items-center justify-center gap-1">
                        <button type="button" onclick="openEditModal(${i})" class="p-1.5 text-secondary hover:text-primary transition-colors" title="Edit"><i class="fas fa-pen text-sm"></i></button>
                        <button type="button" onclick="openDeleteModal(${i})" ${r.stockCount > 0 ? 'disabled' : ''} class="p-1.5 text-secondary transition-colors ${r.stockCount > 0 ? 'opacity-40 cursor-not-allowed' : 'hover:text-error'}" title="${r.stockCount > 0 ? 'Cannot delete: stock in use' : 'Delete'}"><i class="fas fa-trash text-sm"></i></button>
                        </div>
                    </td>
                </tr>`).join('');
    }
  }

  function openCreateModal() {
    document.getElementById('createModal').classList.replace('hidden', 'flex');
  }

  function closeCreateModal() {
    document.getElementById('createModal').classList.replace('flex', 'hidden');
  }

  function openEditModal(i) {
    const r = displayRows[i];
    document.getElementById('editId').value = r._id;
    lmConfig.fields.forEach(f => {
      const el = document.getElementById(f.editId);
      if (el) el.value = r[f.name];
    });
    document.getElementById('editModal').classList.replace('hidden', 'flex');
  }

  function closeEditModal() {
    document.getElementById('editModal').classList.replace('flex', 'hidden');
  }

  function openDeleteModal(i) {
    const r = displayRows[i];
    if (r.stockCount > 0) return;
    document.getElementById('deleteId').value = r._id;
    document.getElementById('deleteLabel').textContent = r.name;
    document.getElementById('deleteModal').classList.replace('hidden', 'flex');
  }

  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.replace('flex', 'hidden');
  }
  document.addEventListener('DOMContentLoaded', renderTable);
</script>