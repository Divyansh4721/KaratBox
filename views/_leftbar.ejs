<!-- Left Sidebar Container -->
<% const active = typeof activeNav !== 'undefined' ? activeNav : ''; %>
<% const navItem = "flex items-center gap-3.5 px-4 py-3 rounded-lg transition-all duration-200 group"; %>
<% const navIcon = "w-5 h-5 shrink-0 transition-colors duration-200"; %>
<% const navText = "text-[15px] font-medium transition-colors duration-200"; %>
<% const navActive = navItem + " bg-primary-fixed/35 dark:bg-dark-container text-primary dark:text-dark-brand border border-primary-container shadow-sm"; %>
<% const navIdle = navItem + " text-on-surface/75 dark:text-dark-text/75 border border-surface-container dark:border-dark-container hover:bg-surface-container-low dark:hover:bg-dark-container hover:text-on-surface dark:hover:text-dark-text hover:border-outline-variant/60"; %>

<div class="w-80 h-screen bg-surface-container-lowest dark:bg-dark-surface border-r border-surface-container-high dark:border-dark-container flex flex-col justify-between px-7 py-8 shrink-0 transition-colors duration-300">

    <div class="flex flex-col">
        <div class="mb-10">
            <a href="/" class="block">
                <h1 class="text-[26px] font-bold text-primary tracking-tight leading-none mb-1.5" style="font-family: 'Playfair Display', Georgia, serif;">KaratBox</h1>
                <p class="text-xs text-secondary font-medium tracking-wide">Luxury Management</p>
            </a>
        </div>

        <nav class="space-y-1">
            <a href="/" class="<%= active === 'home' ? navActive : navIdle %>">
                <svg class="<%= navIcon %> <%= active === 'home' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm10 0h8v8h-8z" />
                </svg>
                <span class="<%= navText %> <%= active === 'home' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Home</span>
            </a>

            <a href="/inventory" class="<%= active === 'inventory' ? navActive : navIdle %>">
                <svg class="<%= navIcon %> <%= active === 'inventory' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
                <span class="<%= navText %> <%= active === 'inventory' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Inventory</span>
            </a>

            <a href="/approvalViewPage" class="<%= active === 'approval' ? navActive : navIdle %>">
                <svg class="<%= navIcon %> <%= active === 'approval' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="<%= navText %> <%= active === 'approval' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Approval</span>
            </a>

            <a href="/customerTable" class="<%= active === 'customer' ? navActive : navIdle %>">
                <svg class="<%= navIcon %> <%= active === 'customer' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span class="<%= navText %> <%= active === 'customer' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Customer</span>
            </a>

            <a href="/billPage" class="<%= active === 'bills' ? navActive : navIdle %>">
                <svg class="<%= navIcon %> <%= active === 'bills' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <span class="<%= navText %> <%= active === 'bills' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Bills</span>
            </a>
        </nav>
    </div>

    <div class="flex flex-col gap-1">
        <a href="/analytics" class="<%= active === 'analytics' ? navActive : navIdle %>">
            <svg class="<%= navIcon %> <%= active === 'analytics' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l3-3 3 2 4-5" />
            </svg>
            <span class="<%= navText %> <%= active === 'analytics' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Analytics</span>
        </a>

        <a href="/dataPage" class="<%= active === 'reports' ? navActive : navIdle %>">
            <svg class="<%= navIcon %> <%= active === 'reports' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s8-1.79 8-4" />
            </svg>
            <span class="<%= navText %> <%= active === 'reports' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Reports</span>
        </a>

        <a href="/list_master" class="<%= active === 'list_master' ? navActive : navIdle %>">
            <svg class="<%= navIcon %> <%= active === 'list_master' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface dark:group-hover:text-dark-text' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            <span class="<%= navText %> <%= active === 'list_master' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">List Master</span>
        </a>

        <div class="my-3 border-t border-surface-container dark:border-dark-container"></div>

        <a href="/environment" class="<%= active === 'settings' ? navActive : navIdle %>">
            <svg class="<%= navIcon %> <%= active === 'settings' ? 'text-primary dark:text-dark-brand' : 'text-on-surface-variant/70 group-hover:text-on-surface' %>" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="<%= navText %> <%= active === 'settings' ? 'font-semibold text-primary dark:text-dark-brand' : '' %>">Settings</span>
        </a>

        <a href="/users/signout" class="<%= navItem %> border border-surface-container dark:border-dark-container text-on-surface/75 hover:bg-error/10 hover:text-error hover:border-error/40">
            <svg class="<%= navIcon %> text-on-surface-variant/70 group-hover:text-error" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <span class="<%= navText %>">Logout</span>
        </a>
    </div>
</div>
