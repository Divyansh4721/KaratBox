<%
const cardAction = typeof action !== 'undefined' ? action : 'add';
const cardWrap = typeof wrapForFilter !== 'undefined' ? wrapForFilter : false;
const fmtPrice = n => new Intl.NumberFormat('en-IN').format(Math.round((n || 0) / 1000) * 1000);
const formatPurity = name => {
  if (!name) return '';
  const value = String(name).trim();
  if (/^\d+(\.\d+)?$/.test(value)) return value + 'K';
  if (/k$/i.test(value)) return value.toUpperCase();
  const match = value.match(/(\d{2})\s*(\d{2})/);
  if (match) return match[2] + 'K';
  return value;
};
let stoneCt = null;
if (item.stoneTable && item.stoneTable.length) {
  const total = item.stoneTable.reduce((sum, row) => sum + (row.ctWeight || 0), 0);
  stoneCt = total > 0 ? total.toFixed(2) : null;
}
const imageFiles = (item.stockImage || []).map((i) => i && i.fileName).filter(Boolean);
const imageUrls = imageFiles.map((f) => '/uploads/stock/' + f);
const img = imageUrls[0] || '';
const hasSlideshow = imageUrls.length > 1;
const tagName = generateTagName(item);
const purity = formatPurity(item.purity ? item.purity.name : '');
const itemId = item.index || item.tag || '-';
const ornamentId = item.ornament ? item.ornament._id : '';
const prefixId = item.prefix ? item.prefix._id : '';
const stockTypeId = item.stockType ? item.stockType._id : '';
const stockTypeName = item.stockType && item.stockType.name ? item.stockType.name : '';
const canRemove = item.isInStock !== false;
%>
<% if (cardWrap) { %>
<div class="stock-card-item h-full" data-stock-card data-id="<%= item._id %>" data-in-stock="<%= item.isInStock ? 'true' : 'false' %>" data-purity="<%= item.purity ? item.purity.name : '' %>" data-prefix="<%= prefixId %>" data-ornament="<%= ornamentId %>" data-tag="<%= item.tag || 0 %>" data-gross-wt="<%= item.grossWt || 0 %>" data-net-wt="<%= item.netWt || 0 %>" data-selling-price="<%= item.sellingPrice || 0 %>" data-stock-type-id="<%= stockTypeId %>" data-stock-type="<%= stockTypeName %>">
<% } %>
<article class="h-full flex flex-col bg-surface-container-lowest dark:bg-dark-container rounded-xl sm:rounded-2xl border border-surface-container dark:border-white/10 shadow-whisper overflow-hidden group hover:shadow-card transition-shadow duration-300">
  <a href="/stock/<%= item._id %>" class="block p-2 pb-0 sm:p-4 sm:pb-0">
    <div class="relative aspect-square rounded-lg sm:rounded-xl bg-brand-almond overflow-hidden">
      <% if (hasSlideshow) { %>
      <div class="card-slideshow relative w-full h-full" data-card-slideshow data-images='<%= JSON.stringify(imageUrls) %>'>
        <img src="<%= imageUrls[0] %>" alt="<%= tagName %>" class="card-slideshow-img w-full h-full object-cover transition-opacity duration-300">
        <div class="card-slideshow-dots absolute bottom-1.5 sm:bottom-2 left-0 right-0 flex justify-center gap-1 sm:gap-1.5 pointer-events-none z-[1]">
          <% imageUrls.forEach((_, i) => { %>
          <span class="card-slideshow-dot w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full shadow-sm <%= i === 0 ? 'bg-white' : 'bg-white/50' %>" aria-hidden="true"></span>
          <% }) %>
        </div>
      </div>
      <% } else if (img) { %>
      <img src="<%= img %>" alt="<%= tagName %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
      <% } else { %>
      <div class="w-full h-full flex items-center justify-center"><i class="fas fa-gem text-2xl sm:text-4xl text-secondary/20"></i></div>
      <% } %>
      <span class="absolute top-1.5 right-1.5 sm:top-3 sm:right-3 text-[9px] sm:text-[11px] font-medium text-secondary bg-surface-container-lowest/95 px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-md shadow-sm">ID: <%= itemId %></span>
      <% if (stockTypeName) { %>
      <span class="absolute top-1.5 left-1.5 sm:top-3 sm:left-3 text-[8px] sm:text-[10px] font-semibold uppercase tracking-wide bg-on-surface/70 text-surface-container-lowest px-1.5 py-0.5 sm:px-2 sm:py-1 rounded-md"><%= stockTypeName %></span>
      <% } %>
    </div>
  </a>
  <div class="p-2 pt-2 sm:p-4 sm:pt-3 flex flex-col flex-1">
    <div class="flex items-start justify-between gap-1 sm:gap-2 mb-1.5 sm:mb-2.5">
      <a href="/stock/<%= item._id %>" class="text-[11px] sm:text-[15px] font-bold text-on-surface dark:text-dark-text hover:text-primary leading-snug line-clamp-2"><%= tagName %></a>
      <% if (purity) { %><span class="shrink-0 text-[8px] sm:text-[10px] font-bold uppercase tracking-wide bg-primary-fixed/55 text-primary px-1.5 py-0.5 sm:px-2 rounded"><%= purity %></span><% } %>
    </div>
    <div class="flex items-center gap-2 sm:gap-4 text-[10px] sm:text-xs text-secondary mb-2 sm:mb-4">
      <span class="inline-flex items-center gap-1"><%- include('_weight_icon', { type: 'gross' }) %><%= (item.grossWt || 0).toFixed(2) %>g</span>
      <span class="hidden sm:inline-flex items-center gap-1.5"><%- include('_weight_icon', { type: 'net' }) %><%= (item.netWt || 0).toFixed(2) %>g net</span>
      <% if (stoneCt) { %><span class="inline-flex items-center gap-1"><i class="far fa-gem text-[10px] sm:text-[11px]"></i><%= stoneCt %>ct</span><% } %>
    </div>
    <div class="flex items-center justify-between pt-1 mt-auto gap-1">
      <p class="text-sm sm:text-lg font-bold text-on-surface dark:text-dark-text tracking-tight">&#8377;<%= fmtPrice(item.sellingPrice) %></p>
      <% if (cardAction === 'remove') { %>
        <% if (canRemove) { %>
        <a href="/delFromCart/<%= item._id %>" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-error/10 text-error flex items-center justify-center hover:bg-error/20 transition-colors shrink-0" title="Remove from cart">
          <i class="fas fa-trash text-xs sm:text-sm"></i>
        </a>
        <% } else { %>
        <span class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-surface-container-low text-secondary flex items-center justify-center opacity-50 cursor-not-allowed shrink-0" title="Cannot remove">
          <i class="fas fa-trash text-xs sm:text-sm"></i>
        </span>
        <% } %>
      <% } else if (cardAction === 'add') { %>
      <button type="button" onclick="event.preventDefault(); AddToCart('<%= item._id %>')" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-primary-fixed/45 text-primary flex items-center justify-center hover:bg-primary-fixed/70 transition-colors shrink-0" title="Add to Cart">
        <i class="fas fa-shopping-bag text-xs sm:text-sm"></i>
      </button>
      <% } %>
    </div>
  </div>
</article>
<% if (cardWrap) { %>
</div>
<% } %>
