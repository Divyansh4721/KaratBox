<% const pgSummaryId = typeof summaryId !== 'undefined' ? summaryId : 'tableSummary'; %>
<% const pgPaginationId = typeof paginationId !== 'undefined' ? paginationId : 'pagination'; %>
<% const pgPerPageId = typeof perPageSelectId !== 'undefined' ? perPageSelectId : 'perPageSelect'; %>
<% const pgShowPerPage = typeof showPerPage === 'undefined' ? true : showPerPage; %>
<% const pgSummaryClass = typeof summaryClass !== 'undefined' ? summaryClass : 'text-xs text-secondary'; %>
<div class="flex flex-col items-center justify-center text-center sm:flex-row sm:items-center sm:justify-between sm:text-left gap-3 px-5 py-4 border-t border-surface-container">
  <div class="flex items-center justify-center gap-3 flex-wrap">
    <p id="<%= pgSummaryId %>" class="<%= pgSummaryClass %>"></p>
    <% if (pgShowPerPage) { %>
    <div class="flex items-center justify-center gap-1">
      <label for="<%= pgPerPageId %>" class="text-xs text-secondary">Show</label>
      <select id="<%= pgPerPageId %>" title="Select records per page" class="text-xs font-semibold text-on-surface bg-surface-container-low border border-surface-container rounded-lg pl-2.5 pr-2.5 py-2.5 cursor-pointer hover:border-primary-container focus:outline-none focus:border-primary-container transition-colors">
        <option value="10">10</option>
        <option value="20" selected>20</option>
        <option value="30">30</option>
        <option value="50">50</option>
      </select>
    </div>
    <% } %>
  </div>
  <div id="<%= pgPaginationId %>" class="flex items-center justify-center gap-1.5 w-full sm:w-auto"></div>
</div>
<%- include('_pagination_lib') %>