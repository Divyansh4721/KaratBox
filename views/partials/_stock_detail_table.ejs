<% const items = typeof stockTable !== 'undefined' ? stockTable : []; %>
<% const sectionTitle = typeof title !== 'undefined' ? title : 'Stock List'; %>
<% const showActions = typeof withActions === 'undefined' ? true : withActions; %>
<% const sectionSlug = typeof sectionId !== 'undefined' ? sectionId : (sectionTitle.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')); %>
<% const usePager = typeof paginate !== 'undefined' && paginate && showActions && items.length; %>
<% const tagLabel = function(s) {
    return (s.prefix && s.prefix.name ? s.prefix.name : '') + ' ' +
        (s.ornament && s.ornament.name ? s.ornament.name : '') +
        (s.tag ? '-' + s.tag : '');
}; %>
<% const sum = function(field) {
    return items.reduce(function(total, item) { return total + (item[field] * 1); }, 0).toFixed(3);
}; %>
<div class="<%= sectionCard %> mb-6">
  <div class="px-5 py-4 border-b border-surface-container dark:border-white/10 flex items-center justify-between gap-3">
    <h3 class="text-sm font-bold text-on-surface dark:text-dark-text"><%= sectionTitle %></h3>
    <span class="text-[10px] font-semibold uppercase tracking-widest text-secondary"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %></span>
  </div>
  <% if (!items.length) { %>
  <p class="px-5 py-8 text-sm text-secondary text-center">No records for this section.</p>
  <% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full text-xs sm:text-sm min-w-[720px]">
      <thead>
        <tr class="bg-surface-container-low dark:bg-dark-container text-[10px] font-semibold uppercase tracking-widest text-secondary">
          <th class="px-4 py-3 text-left">S.No</th>
          <th class="px-3 py-3 text-left">SKU</th>
          <th class="px-3 py-3 text-left">Tag No</th>
          <th class="px-3 py-3 text-left">Purity</th>
          <th class="px-3 py-3 text-right">Gross Wt</th>
          <th class="px-3 py-3 text-right">Net Wt</th>
          <th class="px-3 py-3 text-right">Stone (gm)</th>
          <th class="px-3 py-3 text-right">Stone (ct)</th>
          <th class="px-3 py-3 text-left">Stock Type</th>
          <% if (showActions) { %>
          <th class="px-4 py-3 text-center">Actions</th>
          <% } %>
        </tr>
      </thead>
      <tbody id="<%= sectionSlug %>Body" class="divide-y divide-surface-container dark:divide-white/10">
        <% items.forEach(function(s, i) { %>
        <tr class="hover:bg-surface-container-low/50 dark:hover:bg-dark-container/40">
          <td class="px-4 py-2.5 text-on-surface dark:text-dark-text"><%= i + 1 %></td>
          <td class="px-3 py-2.5 text-on-surface dark:text-dark-text"><%= s.index %></td>
          <td class="px-3 py-2.5 text-on-surface dark:text-dark-text whitespace-nowrap"><%= tagLabel(s) %></td>
          <td class="px-3 py-2.5 text-on-surface dark:text-dark-text"><%= s.purity ? s.purity.name : '' %></td>
          <td class="px-3 py-2.5 text-right text-on-surface dark:text-dark-text"><%= s.grossWt.toFixed(3) %></td>
          <td class="px-3 py-2.5 text-right text-on-surface dark:text-dark-text"><%= s.netWt.toFixed(3) %></td>
          <td class="px-3 py-2.5 text-right text-on-surface dark:text-dark-text"><%= s.stoneWt.toFixed(3) %></td>
          <td class="px-3 py-2.5 text-right text-on-surface dark:text-dark-text"><%= (s.stoneWt * 5).toFixed(3) %></td>
          <td class="px-3 py-2.5 text-on-surface dark:text-dark-text"><%= s.stockType ? s.stockType.name : '' %></td>
          <% if (showActions) { %>
          <td class="px-4 py-2.5">
            <div class="flex items-center justify-center gap-2">
              <button type="button" onclick="AddToCart('<%= s._id || s.id %>')" class="p-1.5 rounded-lg text-primary hover:bg-primary-fixed/30 transition-colors" title="Add to cart">
                <i class="fas fa-cart-plus text-sm"></i>
              </button>
              <a href="/stock?id=<%= s._id || s.id %>" class="p-1.5 rounded-lg text-secondary hover:text-primary hover:bg-surface-container-low transition-colors" title="View stock">
                <i class="fas fa-arrow-up-right-from-square text-sm"></i>
              </a>
            </div>
          </td>
          <% } %>
        </tr>
        <% }); %>
        <tr class="bg-primary-fixed/20 font-semibold pager-skip">
          <td class="px-4 py-2.5"><%= items.length %></td>
          <td class="px-3 py-2.5" colspan="3"></td>
          <td class="px-3 py-2.5 text-right"><%= sum('grossWt') %></td>
          <td class="px-3 py-2.5 text-right"><%= sum('netWt') %></td>
          <td class="px-3 py-2.5 text-right"><%= sum('stoneWt') %></td>
          <td class="px-3 py-2.5 text-right"><%= (items.reduce(function(t, item) { return t + item.stoneWt * 5; }, 0)).toFixed(3) %></td>
          <td class="px-3 py-2.5"></td>
          <% if (showActions) { %><td class="px-4 py-2.5"></td><% } %>
        </tr>
      </tbody>
    </table>
  </div>
  <% if (usePager) { %>
  <% const summaryId = sectionSlug + 'Summary'; %>
  <% const paginationId = sectionSlug + 'Pagination'; %>
  <% const perPageSelectId = sectionSlug + 'PerPage'; %>
  <% const pgSummaryId = typeof summaryId !== 'undefined' ? summaryId : 'tableSummary'; %>
  <% const pgPaginationId = typeof paginationId !== 'undefined' ? paginationId : 'pagination'; %>
  <% const pgPerPageId = typeof perPageSelectId !== 'undefined' ? perPageSelectId : 'perPageSelect'; %>
  <%- include('../partials/_table', { summaryId: pgSummaryId, paginationId: pgPaginationId, perPageSelectId: pgPerPageId }) %>
  <% } %>
  <% } %>
</div>